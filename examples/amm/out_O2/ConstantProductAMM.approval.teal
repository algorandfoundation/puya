    assert // sender invalid
    callsub _current_pool_balance
    callsub _current_a_balance
    intc 4 // 10000000000
    uncover 2
    -
    dig 2
    -
    swap
    dig 2
    *
    dig 1
    /
    callsub _current_b_balance
    uncover 3
    *
    uncover 2
    /
    txn Sender
    intc_0 // 0
    bytec_0 // "asset_a"
