contract examples.debug.contract.DebugContract:
    program approval:
        subroutine algopy.arc4.ARC4Contract.approval_program() -> bool:
            block@0: // L-1
                let tmp%0#0: bool = examples.debug.contract.DebugContract.__puya_arc4_router__()
                return tmp%0#0
        
        subroutine examples.debug.contract.DebugContract.__puya_arc4_router__() -> bool:
            block@0: // L4
                let tmp%0#0: uint64 = (txn NumAppArgs)
                let tmp%1#0: bool = (!= tmp%0#0 0u)
                goto tmp%1#0 ? block@1 : block@5
            block@1: // abi_routing_L4
                let tmp%2#0: bytes = (txna ApplicationArgs 0)
                switch tmp%2#0 {method "test(uint64,uint64,uint64)uint64" => block@2, * => block@3}
            block@2: // test_route_L5
                let tmp%3#0: uint64 = (txn OnCompletion)
                let tmp%4#0: bool = (== tmp%3#0 NoOp)
                (assert tmp%4#0) // OnCompletion is NoOp
                let tmp%5#0: uint64 = (txn ApplicationID)
                let tmp%6#0: bool = (!= tmp%5#0 0u)
                (assert tmp%6#0) // is not creating
                let tmp%7#0: bytes = (txna ApplicationArgs 1)
                let tmp%8#0: uint64 = (btoi tmp%7#0)
                let tmp%9#0: bytes = (txna ApplicationArgs 2)
                let tmp%10#0: uint64 = (btoi tmp%9#0)
                let tmp%11#0: bytes = (txna ApplicationArgs 3)
                let tmp%12#0: uint64 = (btoi tmp%11#0)
                let tmp%13#0: uint64 = examples.debug.contract.DebugContract.test(tmp%8#0, tmp%10#0, tmp%12#0)
                let val_as_bytes%0#0: bytes = (itob tmp%13#0)
                let tmp%14#0: bytes = (concat 0x151f7c75 val_as_bytes%0#0)
                (log tmp%14#0)
                return 1u
            block@3: // switch_case_default_L4
                goto block@4
            block@4: // switch_case_next_L4
                goto block@9
            block@5: // bare_routing_L4
                let tmp%15#0: uint64 = (txn OnCompletion)
                switch tmp%15#0 {0u => block@6, * => block@7}
            block@6: // __algopy_default_create_L4
                let tmp%16#0: uint64 = (txn ApplicationID)
                let tmp%17#0: bool = (== tmp%16#0 0u)
                (assert tmp%17#0) // is creating
                examples.debug.contract.DebugContract.__algopy_default_create()
                return 1u
            block@7: // switch_case_default_L4
                goto block@8
            block@8: // switch_case_next_L4
                goto block@9
            block@9: // after_if_else_L4
                return 0u
        
        subroutine examples.debug.contract.DebugContract.test(x: uint64, y: uint64, z: uint64) -> uint64:
            block@0: // L5
                let a#0: uint64 = x#0
                let tmp%0#0: bool = (< x#0 y#0)
                goto tmp%0#0 ? block@1 : block@2
            block@1: // if_body_L10
                let a#1: uint64 = (+ a#0 y#0)
                goto block@5
            block@2: // else_body_L11
                let tmp%1#0: bool = (< x#0 z#0)
                goto tmp%1#0 ? block@3 : block@4
            block@3: // if_body_L12
                let a#2: uint64 = (+ a#0 z#0)
                goto block@4
            block@4: // after_if_else_L11
                let a#4: uint64 = φ(a#0 <- block@2, a#2 <- block@3)
                goto block@5
            block@5: // after_if_else_L9
                let a#3: uint64 = φ(a#1 <- block@1, a#4 <- block@4)
                let tmp%2#0: bool = (< y#0 z#0)
                goto tmp%2#0 ? block@6 : block@7
            block@6: // if_body_L15
                let tmp%3#0: uint64 = examples.debug.contract.some_func(a#3, y#0)
                let a#5: uint64 = (* a#3 tmp%3#0)
                goto block@8
            block@7: // else_body_L17
                let tmp%4#0: uint64 = examples.debug.contract.some_func(a#3, z#0)
                let a#6: uint64 = (* a#3 tmp%4#0)
                goto block@8
            block@8: // after_if_else_L14
                let a#7: uint64 = φ(a#5 <- block@6, a#6 <- block@7)
                let tmp%5#0: bool = (< a#7 x#0)
                goto tmp%5#0 ? block@9 : block@10
            block@9: // if_body_L20
                let a#8: uint64 = (+ a#7 x#0)
                goto block@10
            block@10: // after_if_else_L19
                let a#9: uint64 = φ(a#7 <- block@8, a#8 <- block@9)
                let tmp%6#0: bool = (< a#9 y#0)
                goto tmp%6#0 ? block@11 : block@12
            block@11: // if_body_L22
                let a#10: uint64 = (+ a#9 y#0)
                goto block@12
            block@12: // after_if_else_L21
                let a#11: uint64 = φ(a#9 <- block@10, a#10 <- block@11)
                let tmp%7#0: bool = (< a#11 z#0)
                goto tmp%7#0 ? block@13 : block@14
            block@13: // if_body_L24
                let a#12: uint64 = (+ a#11 z#0)
                goto block@14
            block@14: // after_if_else_L23
                let a#13: uint64 = φ(a#11 <- block@12, a#12 <- block@13)
                return a#13
        
        subroutine examples.debug.contract.some_func(a: uint64, b: uint64) -> uint64:
            block@0: // L29
                let a#1: uint64 = (+ a#0 b#0)
                let b#1: uint64 = (* b#0 a#1)
                let a#2: uint64 = (+ a#1 b#1)
                let a#3: uint64 = (* a#2 2u)
                return a#3
        
        subroutine examples.debug.contract.DebugContract.__algopy_default_create() -> void:
            block@0: // L4
                return 
    
    program clear-state:
        subroutine algopy.arc4.ARC4Contract.clear_state_program() -> bool:
            block@0: // L-1
                return 1u