#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    intcblock 0 1
    // hello_world_arc4/contract.py:10
    // class HelloWorldContract(ARC4Contract):
    txn NumAppArgs
    bz main_bare_routing@6
    pushbytes 0x02bece11 // method "hello(string)string"
    txna ApplicationArgs 0
    match main_hello_route@3

main_after_if_else@10:
    // hello_world_arc4/contract.py:10
    // class HelloWorldContract(ARC4Contract):
    intc_0 // 0
    return

main_hello_route@3:
    // hello_world_arc4/contract.py:11
    // @arc4.abimethod
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    // hello_world_arc4/contract.py:10
    // class HelloWorldContract(ARC4Contract):
    txna ApplicationArgs 1
    extract 2 0
    // hello_world_arc4/contract.py:11
    // @arc4.abimethod
    callsub hello
    dup
    len
    itob
    extract 6 2
    swap
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    intc_1 // 1
    return

main_bare_routing@6:
    // hello_world_arc4/contract.py:10
    // class HelloWorldContract(ARC4Contract):
    txn OnCompletion
    bnz main_after_if_else@10
    txn ApplicationID
    !
    assert // can only call when creating
    intc_1 // 1
    return


// examples.hello_world_arc4.contract.HelloWorldContract.hello(name: bytes) -> bytes:
hello:
    // hello_world_arc4/contract.py:11-12
    // @arc4.abimethod
    // def hello(self, name: String) -> String:
    proto 1 1
    // hello_world_arc4/contract.py:16-20
    // arc4.abi_call(
    //     Foo.verify,
    //     arr,
    //     app_id=1234
    // )
    itxn_begin
    // hello_world_arc4/contract.py:19
    // app_id=1234
    pushint 1234 // 1234
    itxn_field ApplicationID
    // hello_world_arc4/contract.py:16-20
    // arc4.abi_call(
    //     Foo.verify,
    //     arr,
    //     app_id=1234
    // )
    pushbytes 0x343d7236 // method "verify(address[])void"
    itxn_field ApplicationArgs
    // hello_world_arc4/contract.py:15
    // arr = arr.append(arc4.Address())
    pushbytes base32(AABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA)
    itxn_field ApplicationArgs
    // hello_world_arc4/contract.py:16-20
    // arc4.abi_call(
    //     Foo.verify,
    //     arr,
    //     app_id=1234
    // )
    pushint 6 // appl
    itxn_field TypeEnum
    intc_0 // 0
    itxn_field Fee
    itxn_submit
    // hello_world_arc4/contract.py:21
    // return "Hello, " + name
    pushbytes "Hello, "
    frame_dig -1
    concat
    retsub
