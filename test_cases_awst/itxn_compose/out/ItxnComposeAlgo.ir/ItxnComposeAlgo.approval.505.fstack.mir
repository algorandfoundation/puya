        bz main___algots__.defaultCreate@9 ; b main_abi_routing@2

    main_abi_routing@2:
        txn OnCompletion                                                tmp%2#0
        !                                                               tmp%3#0
        assert
        txn ApplicationID                                               tmp%4#0
        assert
        txna ApplicationArgs 0                                          tmp%6#0
        method distribute(address[],pay,uint64)void                     tmp%6#0,Method(distribute(address[],pay,uint64)void)
        method conditionalBegin(uint64)void                             tmp%6#0,Method(distribute(address[],pay,uint64)void),Method(conditionalBegin(uint64)void)
        l-load tmp%6#0 2                                                Method(distribute(address[],pay,uint64)void),Method(conditionalBegin(uint64)void),tmp%6#0
        match main_distribute_route@4 main_conditionalBegin_route@5 ; b main_after_if_else@8 

