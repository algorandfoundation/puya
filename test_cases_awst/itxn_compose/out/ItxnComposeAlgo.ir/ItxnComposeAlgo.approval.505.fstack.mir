        callsub distribute
        b main_after_if_else@8

    main_conditionalBegin_route@5:
        callsub conditionalBegin
        b main_after_if_else@8

    main_after_if_else@8:
        err

    main___algots__.defaultCreate@9:
        txn OnCompletion                                                tmp%7#0
        !                                                               tmp%8#0
        txn ApplicationID                                               tmp%8#0,tmp%9#0
        !                                                               tmp%8#0,tmp%10#0
        l-load tmp%8#0 1                                                tmp%10#0,tmp%8#0
        l-load tmp%10#0 1                                               tmp%8#0,tmp%10#0
        &&                                                              tmp%11#0
        assert
        int 1                                                           1
        return


