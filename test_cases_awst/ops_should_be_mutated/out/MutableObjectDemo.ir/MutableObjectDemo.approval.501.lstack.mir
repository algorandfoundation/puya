        ==                                                        value#0,eq%0#0
        l-load eq%0#0 0                                           value#0,eq%0#0
        assert // invalid number of bytes for Encoded(len+utf8[]) value#0
        l-load value#0 0                                          value#0
        extract 2 0                                               key#0
        byte "plugins"                                            key#0,"plugins"
        l-load key#0 1                                            "plugins",key#0
