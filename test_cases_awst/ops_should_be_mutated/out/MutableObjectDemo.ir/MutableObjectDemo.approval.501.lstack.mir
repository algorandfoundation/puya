// Op                                                             Stack (out)
// @algorandfoundation/algorand-typescript/arc4/index.d.ts::Contract.approvalProgram() -> uint64:
subroutine main:
    main_block@0:
        txn NumAppArgs                                            tmp%0#1
        l-load tmp%0#1 0                                          tmp%0#1
        bz main___algots__.defaultCreate@5 ; b main_abi_routing@2

    main_abi_routing@2:
        txna ApplicationArgs 0                                    tmp%2#0
        method setPlugin(string)void                              tmp%2#0,Method(setPlugin(string)void)
        l-load tmp%2#0 1                                          Method(setPlugin(string)void),tmp%2#0
        match main_setPlugin_route@3 ; b main_switch_case_next@4

    main_setPlugin_route@3:
        txn OnCompletion                                          tmp%3#0
        l-load tmp%3#0 0                                          tmp%3#0
        !                                                         tmp%4#0
        txn ApplicationID                                         tmp%4#0,tmp%5#0
        l-load tmp%4#0 1                                          tmp%5#0,tmp%4#0
        l-load tmp%5#0 1                                          tmp%4#0,tmp%5#0
        &&                                                        tmp%7#0
        l-load tmp%7#0 0                                          tmp%7#0
        assert
        callsub setPlugin
        b main_switch_case_next@4

    main_switch_case_next@4:
        err

    main___algots__.defaultCreate@5:
        txn OnCompletion                                          tmp%8#0
        l-load tmp%8#0 0                                          tmp%8#0
        !                                                         tmp%9#0
        txn ApplicationID                                         tmp%9#0,tmp%10#0
        l-load tmp%10#0 0                                         tmp%9#0,tmp%10#0
        !                                                         tmp%9#0,tmp%11#0
        l-load tmp%9#0 1                                          tmp%11#0,tmp%9#0
        l-load tmp%11#0 1                                         tmp%9#0,tmp%11#0
        &&                                                        tmp%12#0
        l-load tmp%12#0 0                                         tmp%12#0
        assert
        int 1                                                     1
        return


// tests/approvals/mutable-object.algo.ts::MutableObjectDemo.setPlugin[routing]() -> void:
subroutine setPlugin:
    setPlugin_block@0:
        txna ApplicationArgs 1                                    value#0
        l-load-copy value#0 0                                     value#0,value#0 (copy)
        int 0                                                     value#0,value#0 (copy),0
        extract_uint16 // on error: invalid array length header   value#0,aggregate%array_length%0#0
        l-load aggregate%array_length%0#0 0                       value#0,aggregate%array_length%0#0
        int 2                                                     value#0,aggregate%array_length%0#0,2
        +                                                         value#0,add%0#0
        l-load-copy value#0 1                                     value#0,add%0#0,value#0 (copy)
        len                                                       value#0,add%0#0,len%0#0
        l-load len%0#0 0                                          value#0,add%0#0,len%0#0
