    itxn_field ApplicationArgs                                                                   (𝕡) app#0,asset#0 |
    // typed_abi_call/typed_c2c.py:119
    // Global.current_application_address,
    byte 0x01                                                                                    (𝕡) app#0,asset#0 | 0x01
    itxn_field ApplicationArgs                                                                   (𝕡) app#0,asset#0 |
    // typed_abi_call/typed_c2c.py:120
    // app,
    byte 0x01                                                                                    (𝕡) app#0,asset#0 | 0x01
    itxn_field ApplicationArgs                                                                   (𝕡) app#0,asset#0 |
    // typed_abi_call/typed_c2c.py:116-122
    // txn = arc4.abi_call(
    //     Logger.log_asset_account_app,
    //     asset,
    //     Global.current_application_address,
    //     app,
    //     app_id=app,
    // )
    int appl                                                                                     (𝕡) app#0,asset#0 | appl
    itxn_field TypeEnum                                                                          (𝕡) app#0,asset#0 |
    int 0                                                                                        (𝕡) app#0,asset#0 | 0
    itxn_field Fee                                                                               (𝕡) app#0,asset#0 |
    itxn_submit                                                                                  (𝕡) app#0,asset#0 |
    itxn LastLog                                                                                 (𝕡) app#0,asset#0 | txn.LastLog#0
    // typed_abi_call/typed_c2c.py:125
    // == asset.name + Global.current_application_address.bytes + app.address.bytes
    p-load asset#0                                                                               (𝕡) app#0,asset#0 | txn.LastLog#0,asset#0 (copy)
    asset_params_get AssetName                                                                   (𝕡) app#0,asset#0 | txn.LastLog#0,value%0#0,check%0#0
    assert // asset exists                                                                       (𝕡) app#0,asset#0 | txn.LastLog#0,value%0#0
    global CurrentApplicationAddress                                                             (𝕡) app#0,asset#0 | txn.LastLog#0,value%0#0,tmp%1#0
    l-load value%0#0 1                                                                           (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%1#0,value%0#0
    l-load tmp%1#0 1                                                                             (𝕡) app#0,asset#0 | txn.LastLog#0,value%0#0,tmp%1#0
    concat                                                                                       (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%2#0
    p-load app#0                                                                                 (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%2#0,app#0 (copy)
    app_params_get AppAddress                                                                    (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%2#0,value%1#0,check%1#0
    assert // application exists                                                                 (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%2#0,value%1#0
    l-load tmp%2#0 1                                                                             (𝕡) app#0,asset#0 | txn.LastLog#0,value%1#0,tmp%2#0
    l-load value%1#0 1                                                                           (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%2#0,value%1#0
    concat                                                                                       (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%3#0
    // typed_abi_call/typed_c2c.py:124-125
    // txn.last_log
    // == asset.name + Global.current_application_address.bytes + app.address.bytes
    l-load txn.LastLog#0 1                                                                       (𝕡) app#0,asset#0 | tmp%3#0,txn.LastLog#0
    l-load tmp%3#0 1                                                                             (𝕡) app#0,asset#0 | txn.LastLog#0,tmp%3#0
    ==                                                                                           (𝕡) app#0,asset#0 | tmp%4#0
    // typed_abi_call/typed_c2c.py:123-126
    // assert (
    //     txn.last_log
    //     == asset.name + Global.current_application_address.bytes + app.address.bytes
    // )
    assert                                                                                       (𝕡) app#0,asset#0 |
    retsub


