    block@10: // switch_case_default_L9
        goto block@11
    block@11: // switch_case_next_L9
        goto block@12
    block@12: // after_if_else_L9
        exit 0u

subroutine test_cases.avm_12.contract.Contract.test_new_ops[routing]() -> void:
