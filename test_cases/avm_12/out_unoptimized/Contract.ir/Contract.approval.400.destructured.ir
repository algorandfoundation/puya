subroutine test_cases.avm_12.contract.Contract.test_new_ops() -> void:
    block@0: // L10
        let tmp%0#0: bytes = (bzero 1793u)
        let tmp%1#0: bool = (falcon_verify 0x 0x tmp%0#0)
        let tmp%2#0: bool = (! tmp%1#0)
