#pragma version 12
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@9
    txn ApplicationID
    !
    txn OnCompletion
    pushint 1 // 1
    shl
    +
    !
    assert
    pushbytes 0xc2b8dd8a // method "test_new_ops()void"
    txna ApplicationArgs 0
    match main_test_new_ops_route@4
    err

main_test_new_ops_route@4:
    pushint 1793 // 1793
    bzero
    pushbytes 0x
    dup
    uncover 2
    falcon_verify
    !
    assert
    return

main_bare_routing@9:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
