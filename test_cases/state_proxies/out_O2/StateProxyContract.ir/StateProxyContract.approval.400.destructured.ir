    block@2: // after_if_else_L1
        let tmp%0#3: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%0#3 {method "create()void" => block@4, method "clear()void" => block@5, method "order_of_eval_global()void" => block@6, method "order_of_eval_local()void" => block@7, method "order_of_eval_box()void" => block@8, * => block@9}
