main test_cases.biguint_binary_ops.contract.BiguintBinaryOps.approval_program:
    block@0: // L5
        let value#0: biguint = 58446744073709552000b
        goto block@1
    block@1: // L32
        let tmp%3#0: biguint = (b^ value#0 0x00000000000000000000000000000000ffffffffffffffffffffffffffffffff)
        let wide_value_compl#0: biguint = (b+ tmp%3#0 1b)
        let tmp%4#0: biguint = (b& wide_value_compl#0 0x00000000000000000000000000000000ffffffffffffffffffffffffffffffff)
        goto block@2
    block@2: // split from inlining callsub op of 0 at index 0_L5
        let value#1: biguint = 58446744073709552000b
        goto block@3
    block@3: // L32
        let tmp%3#1: biguint = (b^ value#1 0x00000000000000000000000000000000ffffffffffffffffffffffffffffffff)
        let wide_value_compl#1: biguint = (b+ tmp%3#1 1b)
        let tmp%4#1: biguint = (b& wide_value_compl#1 0x00000000000000000000000000000000ffffffffffffffffffffffffffffffff)
        goto block@4
    block@4: // split from inlining callsub op of 2 at index 0_L5
        let tmp%27#0: bool = (b== tmp%4#0 tmp%4#1)
        (assert tmp%27#0)
        return 1u