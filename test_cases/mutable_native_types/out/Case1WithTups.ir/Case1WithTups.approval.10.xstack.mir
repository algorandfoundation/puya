        l-load-copy array%encoded_element%0#1 0                                                               (𝕡) tups#0 | item_index_internal%0#0,array%encoded_element%0#1,array%encoded_element%0#1 (copy)
        int 0                                                                                                 (𝕡) tups#0 | item_index_internal%0#0,array%encoded_element%0#1,array%encoded_element%0#1 (copy),0
