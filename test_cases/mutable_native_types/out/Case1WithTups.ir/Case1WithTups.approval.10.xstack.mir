        box_get                                                                                               (𝕡) index#0 | maybe_value%0#0,maybe_exists%0#0
        assert // check self.tup_bag exists                                                                   (𝕡) index#0 | maybe_value%0#0
        l-load-copy maybe_value%0#0 0                                                                         (𝕡) index#0 | maybe_value%0#0,maybe_value%0#0 (copy)
        int 0                                                                                                 (𝕡) index#0 | maybe_value%0#0,maybe_value%0#0 (copy),0
        extract_uint64                                                                                        (𝕡) index#0 | maybe_value%0#0,tmp%0#0
        p-load index#0                                                                                        (𝕡) index#0 | maybe_value%0#0,tmp%0#0,index#0 (copy)
        l-load tmp%0#0 1                                                                                      (𝕡) index#0 | maybe_value%0#0,index#0 (copy),tmp%0#0
        <                                                                                                     (𝕡) index#0 | maybe_value%0#0,tmp%1#0
        assert // index out of bounds                                                                         (𝕡) index#0 | maybe_value%0#0
        // mutable_native_types/case1_with_tups.py:55
        // return self.tup_bag.value.items[index]
        l-load maybe_value%0#0 0                                                                              (𝕡) index#0 | maybe_value%0#0
        extract 8 128                                                                                         (𝕡) index#0 | array%extract%1#1
        p-load index#0                                                                                        (𝕡) index#0 | array%extract%1#1,index#0 (copy)
        int 16                                                                                                (𝕡) index#0 | array%extract%1#1,index#0 (copy),16
        *                                                                                                     (𝕡) index#0 | array%extract%1#1,array%bytes_offset%0#1
        l-load array%extract%1#1 1                                                                            (𝕡) index#0 | array%bytes_offset%0#1,array%extract%1#1
        l-load array%bytes_offset%0#1 1                                                                       (𝕡) index#0 | array%extract%1#1,array%bytes_offset%0#1
        int 16                                                                                                (𝕡) index#0 | array%extract%1#1,array%bytes_offset%0#1,16
        extract3 // on error: index access is out of bounds                                                   (𝕡) index#0 | array%encoded_element%0#1
        l-load-copy array%encoded_element%0#1 0                                                               (𝕡) index#0 | array%encoded_element%0#1,array%encoded_element%0#1 (copy)
        int 0                                                                                                 (𝕡) index#0 | array%encoded_element%0#1,array%encoded_element%0#1 (copy),0
