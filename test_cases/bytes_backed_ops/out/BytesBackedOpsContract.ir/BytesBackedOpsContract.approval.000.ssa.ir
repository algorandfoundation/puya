subroutine test_cases.bytes_backed_ops.contract.test_byte_manipulation_ops() -> void:
    block@0: // L94
        let fb#0: bytes[5] = 0x68656c6c6f
        let s#0: string = "hello"
        let awst_tmp%0#0: account = (txn Sender)
        let tmp%0#0: uint64 = (len awst_tmp%0#0)
        let tmp%1#0: bool = (== 32u tmp%0#0)
        (assert tmp%1#0) // Address length is 32 bytes
        let acct#0: account = awst_tmp%0#0
        let tmp%2#0: bytes = (concat fb#0 s#0)
        let result#0: bytes = tmp%2#0
        let tmp%3#0: uint64 = (len result#0)
        let tmp%4#0: bool = (== tmp%3#0 10u)
        (assert tmp%4#0)
        let tmp%5#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%6#0: bytes = (concat tmp%5#0 acct#0)
        let tmp%7#0: uint64 = (len tmp%6#0)
        let tmp%8#0: bool = (!= tmp%7#0 0u)
        (assert tmp%8#0)
        let tmp%9#0: bytes = (concat acct#0 s#0)
        let tmp%10#0: uint64 = (len tmp%9#0)
        let tmp%11#0: bool = (!= tmp%10#0 0u)
        (assert tmp%11#0)
        let tmp%12#0: bytes = (concat 1000b 1000b)
        let tmp%13#0: uint64 = (len tmp%12#0)
        let tmp%14#0: bool = (!= tmp%13#0 0u)
        (assert tmp%14#0)
        let tmp%15#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0x00026869)
        let tmp%16#0: bytes = (concat tmp%15#0 fb#0)
        let tmp%17#0: uint64 = (len tmp%16#0)
        let tmp%18#0: bool = (!= tmp%17#0 0u)
        (assert tmp%18#0)
        let tmp%19#0: bytes = (concat 0x000000000000002a 0x000000000000002b)
        let tmp%20#0: uint64 = (len tmp%19#0)
        let tmp%21#0: bool = (!= tmp%20#0 0u)
        (assert tmp%21#0)
        let encoded_array%0#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(10u, 20u)
        let tmp%22#0: bytes = (concat encoded_array%0#0 fb#0)
        let tmp%23#0: uint64 = (len tmp%22#0)
        let tmp%24#0: bool = (!= tmp%23#0 0u)
        (assert tmp%24#0)
        let encoded_array%1#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(1u)
        let tmp%25#0: Encoded(uint64,uint64) = bytes_encode<(uint64,uint64)>(1u, 2u)
        let tmp%26#0: bytes = (concat encoded_array%1#0 tmp%25#0)
        let tmp%27#0: uint64 = (len tmp%26#0)
        let tmp%28#0: bool = (!= tmp%27#0 0u)
        (assert tmp%28#0)
        let tmp%29#0: bytes = ((extract 1 3) s#0)
        let tmp%30#0: bool = (== tmp%29#0 0x656c6c)
        (assert tmp%30#0)
        let tmp%31#0: bytes = ((extract 0 4) acct#0)
        let tmp%32#0: uint64 = (len tmp%31#0)
        let tmp%33#0: bool = (!= tmp%32#0 0u)
        (assert tmp%33#0)
        let tmp%34#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%35#0: bytes = ((extract 0 2) tmp%34#0)
        let tmp%36#0: uint64 = (len tmp%35#0)
        let tmp%37#0: bool = (!= tmp%36#0 0u)
        (assert tmp%37#0)
        let tmp%38#0: bytes = ((substring 1 4) fb#0)
        let tmp%39#0: bool = (== tmp%38#0 0x656c6c)
        (assert tmp%39#0)
        let tmp%40#0: bytes = ((substring 0 4) 0x000000000000002a)
        let tmp%41#0: uint64 = (len tmp%40#0)
        let tmp%42#0: bool = (!= tmp%41#0 0u)
        (assert tmp%42#0)
        let tmp%43#0: uint64 = (getbyte 0x000000000000002a 7u)
        let tmp%44#0: bool = (== tmp%43#0 42u)
        (assert tmp%44#0)
        let tmp%45#0: uint64 = (getbyte 1000b 0u)
        let tmp%46#0: bool = (>= tmp%45#0 0u)
        (assert tmp%46#0)
        let tmp%47#0: uint64 = (getbyte s#0 0u)
        let tmp%48#0: bool = (== tmp%47#0 104u)
        (assert tmp%48#0)
        let tmp%49#0: bytes = (setbyte fb#0 0u 72u)
        let modified#0: bytes = tmp%49#0
        let tmp%50#0: bool = (== modified#0 0x48656c6c6f)
        (assert tmp%50#0)
        let tmp%51#0: bytes = ((replace2 0) 256b 0x00)
        let replaced#0: bytes = tmp%51#0
        let tmp%52#0: uint64 = (len replaced#0)
        let tmp%53#0: bool = (!= tmp%52#0 0u)
        (assert tmp%53#0)
        let tmp%54#0: bytes = ((replace2 0) acct#0 0x00)
        let replaced2#0: bytes = tmp%54#0
        let tmp%55#0: uint64 = (len replaced2#0)
        let tmp%56#0: bool = (!= tmp%55#0 0u)
        (assert tmp%56#0)
        let fb8#0: bytes[8] = 0x000000000000002a
        let tmp%57#0: uint64 = (extract_uint64 fb8#0 0u)
        let tmp%58#0: bool = (== tmp%57#0 42u)
        (assert tmp%58#0)
        let tmp%59#0: uint64 = (extract_uint16 0x000003e8 0u)
        let tmp%60#0: bool = (>= tmp%59#0 0u)
        (assert tmp%60#0)
        let tmp%61#0: uint64 = (extract_uint32 0x000003e8 0u)
        let tmp%62#0: bool = (>= tmp%61#0 0u)
        (assert tmp%62#0)
        return 

subroutine test_cases.bytes_backed_ops.contract.test_conversion_ops() -> void:
    block@0: // L144
        let fb#0: bytes[8] = 0x000000000000002a
        let tmp%0#0: uint64 = (btoi fb#0)
        let tmp%1#0: bool = (== tmp%0#0 42u)
        (assert tmp%1#0)
        let tmp%2#0: uint64 = (btoi 0x0000000000000064)
        let tmp%3#0: bool = (== tmp%2#0 100u)
        (assert tmp%3#0)
        let tmp%4#0: uint64 = (btoi 0x2a)
        let tmp%5#0: bool = (== tmp%4#0 42u)
        (assert tmp%5#0)
        let encoded#0: bytes = 0x614756736247383d
        let tmp%6#0: bytes = ((base64_decode StdEncoding) encoded#0)
        let decoded#0: bytes = tmp%6#0
        let tmp%7#0: bool = (== decoded#0 0x68656c6c6f)
        (assert tmp%7#0)
        return 

subroutine test_cases.bytes_backed_ops.contract.test_bitwise_ops() -> void:
    block@0: // L158
        let fb#0: bytes[4] = 0x74657374
        let s#0: string = "test"
        let awst_tmp%0#0: account = (txn Sender)
        let tmp%0#0: uint64 = (len awst_tmp%0#0)
        let tmp%1#0: bool = (== 32u tmp%0#0)
        (assert tmp%1#0) // Address length is 32 bytes
        let acct#0: account = awst_tmp%0#0
        let tmp%2#0: uint64 = (bitlen fb#0)
        let tmp%3#0: bool = (> tmp%2#0 0u)
        (assert tmp%3#0)
        let tmp%4#0: uint64 = (bitlen s#0)
        let tmp%5#0: bool = (> tmp%4#0 0u)
        (assert tmp%5#0)
        let tmp%6#0: uint64 = (bitlen acct#0)
        let tmp%7#0: bool = (> tmp%6#0 0u)
        (assert tmp%7#0)
        let tmp%8#0: uint64 = (bitlen 1000b)
        let tmp%9#0: bool = (> tmp%8#0 0u)
        (assert tmp%9#0)
        let tmp%10#0: uint64 = (bitlen 0x000000000000002a)
        let tmp%11#0: bool = (> tmp%10#0 0u)
        (assert tmp%11#0)
        let tmp%12#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%13#0: uint64 = (bitlen tmp%12#0)
        let tmp%14#0: bool = (> tmp%13#0 0u)
        (assert tmp%14#0)
        let tmp%15#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0x00026869)
        let tmp%16#0: uint64 = (bitlen tmp%15#0)
        let tmp%17#0: bool = (> tmp%16#0 0u)
        (assert tmp%17#0)
        let tmp%18#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%19#0: Encoded(uint8,(len+utf8[])) = bytes_encode<(uint8,(len+utf8[]))>(0x01, tmp%18#0)
        let tmp%20#0: uint64 = (bitlen tmp%19#0)
        let tmp%21#0: bool = (> tmp%20#0 0u)
        (assert tmp%21#0)
        let tmp%22#0: Encoded(uint64,uint8) = bytes_encode<(uint64,uint8)>(0x000000000000002a, 0x07)
        let tmp%23#0: uint64 = (bitlen tmp%22#0)
        let tmp%24#0: bool = (> tmp%23#0 0u)
        (assert tmp%24#0)
        let encoded_array%0#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(1u, 2u, 3u)
        let tmp%25#0: uint64 = (bitlen encoded_array%0#0)
        let tmp%26#0: bool = (> tmp%25#0 0u)
        (assert tmp%26#0)
        let tmp%27#0: Encoded(uint64,uint64) = bytes_encode<(uint64,uint64)>(1u, 2u)
        let tmp%28#0: uint64 = (bitlen tmp%27#0)
        let tmp%29#0: bool = (> tmp%28#0 0u)
        (assert tmp%29#0)
        let tmp%30#0: bool = (getbit s#0 0u)
        let bit#0: bool = tmp%30#0
        let tmp%31#0: bool = (! bit#0)
        let tmp%32#0: bytes = (setbit s#0 0u tmp%31#0)
        let result#0: bytes = tmp%32#0
        let tmp%33#0: bool = (!= result#0 s#0)
        (assert tmp%33#0)
        let tmp%34#0: bool = (getbit fb#0 0u)
        let bit2#0: bool = tmp%34#0
        let tmp%35#0: bool = (! bit2#0)
        let tmp%36#0: bytes = (setbit fb#0 0u tmp%35#0)
        let result2#0: bytes = tmp%36#0
        let tmp%37#0: bool = (!= result2#0 fb#0)
        (assert tmp%37#0)
        let tmp%38#0: Encoded(bool8) = bytes_encode<bool8>(1u)
        let arc4_bool#0: Encoded(bool8) = tmp%38#0
        let tmp%39#0: bytes = (setbit arc4_bool#0 0u 0u)
        let toggled#0: bytes = tmp%39#0
        let tmp%40#0: bool = (!= toggled#0 arc4_bool#0)
        (assert tmp%40#0)
        let tmp%41#0: bool = (getbit acct#0 0u)
        let tmp%42#0: bool = (<= 0u tmp%41#0)
        (assert tmp%42#0)
        let tmp%43#0: bool = (getbit 0x000000000000002a 63u)
        let tmp%44#0: bool = (<= 0u tmp%43#0)
        (assert tmp%44#0)
        return 