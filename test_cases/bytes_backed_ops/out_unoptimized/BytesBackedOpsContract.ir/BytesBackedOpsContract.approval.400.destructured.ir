subroutine test_cases.bytes_backed_ops.contract.test_byte_manipulation_ops() -> void:
    block@0: // L96
        let awst_tmp%0#0: account = (txn Sender)
        let tmp%0#0: uint64 = (len awst_tmp%0#0)
        let tmp%1#0: bool = (== 32u tmp%0#0)
        (assert tmp%1#0) // Address length is 32 bytes
        let acct#0: account = awst_tmp%0#0
        let tmp%2#0: bytes = (concat 0x68656c6c6f "hello")
        let result#0: bytes = tmp%2#0
        let tmp%3#0: uint64 = (len result#0)
        let tmp%4#0: bool = (== tmp%3#0 10u)
        (assert tmp%4#0)
        let aggregate%length%0#0: uint64 = (len "hello")
        let aggregate%as_bytes%0#0: bytes[8] = (itob aggregate%length%0#0)
        let aggregate%length_uint16%0#0: bytes = ((extract 6 2) aggregate%as_bytes%0#0)
        let aggregate%encoded_value%0#0: bytes = (concat aggregate%length_uint16%0#0 "hello")
        let aggregate%as_Encoded(len+utf8[])%0#0: Encoded(len+utf8[]) = aggregate%encoded_value%0#0
        let tmp%5#0: Encoded(len+utf8[]) = aggregate%as_Encoded(len+utf8[])%0#0
