test_conversion_ops_block@0:
    // bytes_backed_ops/contract.py:148-149
    // # btoi of various types
    // fb = FixedBytes[typing.Literal[8]](b"\x00\x00\x00\x00\x00\x00\x00\x2a")
    bytec_2 // 0x000000000000002a
    // bytes_backed_ops/contract.py:150
    // assert op.btoi(fb) == 42
    btoi
    pushint 42
    ==
    assert
    // bytes_backed_ops/contract.py:151
    // assert op.btoi(arc4.UInt64(100)) == 100
    pushbytes 0x0000000000000064
    btoi
    pushint 100
    ==
    assert
    // bytes_backed_ops/contract.py:152
    // assert op.btoi(Bytes(b"\x2a")) == 42
    bytec 9 // 0x2a
    btoi
    pushint 42
    ==
    assert
    // bytes_backed_ops/contract.py:154-155
    // # base64_decode
    // encoded = Bytes(b"aGVsbG8=")
    pushbytes 0x614756736247383d
    // bytes_backed_ops/contract.py:156
    // decoded = op.base64_decode(op.Base64.StdEncoding, encoded)
    base64_decode StdEncoding
    // bytes_backed_ops/contract.py:157
    // assert decoded == b"hello"
    bytec_1 // 0x68656c6c6f
    ==
    assert
    retsub


