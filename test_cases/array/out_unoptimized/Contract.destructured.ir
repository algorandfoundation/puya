contract test_cases.array.contract.Contract:
    program approval:
        subroutine algopy.arc4.ARC4Contract.approval_program() -> bool:
            block@0: // L1
                let tmp%0#0: bytes = (bzero 255u)
                let tmp%1#0: bytes = (b| tmp%0#0 0x7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff)
                write(0u, tmp%1#0)
                let tmp%2#0: bool = test_cases.array.contract.Contract.__puya_arc4_router__()
                return tmp%2#0
        
        subroutine test_cases.array.contract.Contract.__puya_arc4_router__() -> bool:
            block@0: // L4
                let tmp%0#0: uint64 = (txn NumAppArgs)
                let tmp%1#0: bool = (!= tmp%0#0 0u)
                goto tmp%1#0 ? block@1 : block@8
            block@1: // abi_routing_L4
                let tmp%2#0: bytes = (txna ApplicationArgs 0)
                switch tmp%2#0 {method "test_array()void" => block@2, method "overhead()void" => block@3, method "test_array_too_long()void" => block@4, method "test_quicksort()void" => block@5, * => block@6}
            block@2: // test_array_route_L6
                let tmp%3#0: uint64 = (txn OnCompletion)
                let tmp%4#0: bool = (== tmp%3#0 NoOp)
                (assert tmp%4#0) // OnCompletion is not NoOp
                let tmp%5#0: uint64 = (txn ApplicationID)
                let tmp%6#0: bool = (!= tmp%5#0 0u)
                (assert tmp%6#0) // can only call when not creating
                test_cases.array.contract.Contract.test_array()
                return 1u
            block@3: // overhead_route_L44
                let tmp%7#0: uint64 = (txn OnCompletion)
                let tmp%8#0: bool = (== tmp%7#0 NoOp)
                (assert tmp%8#0) // OnCompletion is not NoOp
                let tmp%9#0: uint64 = (txn ApplicationID)
                let tmp%10#0: bool = (!= tmp%9#0 0u)
                (assert tmp%10#0) // can only call when not creating
                test_cases.array.contract.Contract.overhead()
                return 1u
            block@4: // test_array_too_long_route_L48
                let tmp%11#0: uint64 = (txn OnCompletion)
                let tmp%12#0: bool = (== tmp%11#0 NoOp)
                (assert tmp%12#0) // OnCompletion is not NoOp
                let tmp%13#0: uint64 = (txn ApplicationID)
                let tmp%14#0: bool = (!= tmp%13#0 0u)
                (assert tmp%14#0) // can only call when not creating
                test_cases.array.contract.Contract.test_array_too_long()
                return 1u
            block@5: // test_quicksort_route_L58
                let tmp%15#0: uint64 = (txn OnCompletion)
                let tmp%16#0: bool = (== tmp%15#0 NoOp)
                (assert tmp%16#0) // OnCompletion is not NoOp
                let tmp%17#0: uint64 = (txn ApplicationID)
                let tmp%18#0: bool = (!= tmp%17#0 0u)
                (assert tmp%18#0) // can only call when not creating
                test_cases.array.contract.Contract.test_quicksort()
                return 1u
            block@6: // switch_case_default_L4
                goto block@7
            block@7: // switch_case_next_L4
                goto block@12
            block@8: // bare_routing_L4
                let tmp%19#0: uint64 = (txn OnCompletion)
                switch tmp%19#0 {0u => block@9, * => block@10}
            block@9: // __algopy_default_create_L1
                let tmp%20#0: uint64 = (txn ApplicationID)
                let tmp%21#0: bool = (== tmp%20#0 0u)
                (assert tmp%21#0) // can only call when creating
                test_cases.array.contract.Contract.__algopy_default_create()
                return 1u
            block@10: // switch_case_default_L4
                goto block@11
            block@11: // switch_case_next_L4
                goto block@12
            block@12: // after_if_else_L4
                return 0u
        
        subroutine test_cases.array.contract.Contract.test_array() -> void:
            block@0: // L6
