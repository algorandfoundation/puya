                let tmp%20#0: slot = test_cases.array.contract.return_ref(arr#0, arr#0)
                let array_contents%27#0: bytes = read(tmp%20#0)
                let contents_index%7#0: uint64 = (* 0u 8u)
                let value%7#0: uint64 = (extract_uint64 array_contents%27#0 contents_index%7#0)
                let array_contents%28#0: bytes = read(tmp%20#0)
                let contents_index%8#0: uint64 = (* 0u 8u)
                let value%8#0: uint64 = (+ value%7#0 2u)
                let value_bytes%0#0: bytes = (itob value%8#0)
                let updated_array_contents%0#0: bytes = (replace3 array_contents%28#0 contents_index%8#0 value_bytes%0#0)
                write(tmp%20#0, updated_array_contents%0#0)
                let array_contents%29#0: bytes = read(arr#0)
                let contents_length%13#0: uint64 = (len array_contents%29#0)
                let array_length%13#0: uint64 = (/ contents_length%13#0 8u)
                let tmp%21#0: bool = (== array_length%13#0 17u)
                (assert tmp%21#0)
                let array_contents%30#0: bytes = read(arr#0)
                let contents_index%9#0: uint64 = (* 0u 8u)
                let value%9#0: uint64 = (extract_uint64 array_contents%30#0 contents_index%9#0)
                let tmp%22#0: bool = (== value%9#0 44u)
                (assert tmp%22#0)
                let array_contents%31#0: bytes = read(arr#0)
                let contents_length%14#0: uint64 = (len array_contents%31#0)
                let array_length%14#0: uint64 = (/ contents_length%14#0 8u)
                let tmp%23#0: uint64 = (- array_length%14#0 2u)
                let array_contents%32#0: bytes = read(arr#0)
