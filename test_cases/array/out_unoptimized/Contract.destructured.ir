                let array_contents%17#0: bytes = read(arr#0)
                let contents_length%8#0: uint64 = (len array_contents%17#0)
                let array_length%8#0: uint64 = (/ contents_length%8#0 8u)
                let tmp%12#0: uint64 = (- array_length%8#0 1u)
                let array_contents%18#0: bytes = read(arr#0)
                let contents_index%4#0: uint64 = (* tmp%12#0 8u)
                let value%4#0: uint64 = (extract_uint64 array_contents%18#0 contents_index%4#0)
                let tmp%13#0: bool = (== value%4#0 2u)
                (assert tmp%13#0)
                test_cases.array.contract.add_x(arr#0, 10u)
                let array_contents%19#0: bytes = read(arr#0)
                let contents_length%9#0: uint64 = (len array_contents%19#0)
                let array_length%9#0: uint64 = (/ contents_length%9#0 8u)
                let tmp%14#0: bool = (== array_length%9#0 14u)
                (assert tmp%14#0)
                let array_contents%20#0: bytes = read(arr#0)
                let contents_length%10#0: uint64 = (len array_contents%20#0)
