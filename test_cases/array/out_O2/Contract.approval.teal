// test_cases.array.contract.add_x(arr: uint64, x: uint64) -> uint64:
add_x:
    proto 2 1
    intc_2 // 0

add_x_for_header@1:
    frame_dig 0
    frame_dig -1
    <
    bz add_x_after_for@4
    frame_dig -2
    loads
    frame_dig 0
    dup
    cover 2
    itob
    concat
    frame_dig -2
    swap
    stores
    intc_1 // 1
    +
    frame_bury 0
    b add_x_for_header@1

add_x_after_for@4:
    frame_dig -2
    swap
    retsub


// test_cases.array.contract.pop_x(arr: uint64, x: uint64) -> uint64:
pop_x:
    proto 2 1
    intc_2 // 0

pop_x_for_header@1:
    frame_dig 0
    frame_dig -1
    <
    bz pop_x_after_for@4
    frame_dig -2
    loads
    dup
    len
    intc_0 // 8
    -
    intc_2 // 0
    swap
    extract3
    frame_dig -2
    swap
    stores
    frame_dig 0
    intc_1 // 1
    +
    frame_bury 0
    b pop_x_for_header@1

pop_x_after_for@4:
    frame_dig -2
    swap
    retsub


// _puya_lib.mem.new_slot(allocation_slot: uint64) -> uint64:
new_slot:
    proto 1 1
    frame_dig -1
    loads
    dup
    bitlen
    dup
    assert // no available slots
    swap
    dig 1
    intc_2 // 0
    setbit
    frame_dig -1
    swap
    stores
    retsub
