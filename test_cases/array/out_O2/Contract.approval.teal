#pragma version 10

test_cases.array.contract.Contract.approval_program:
    intcblock 1 8 0 2 512
    bytecblock 0x
    pushint 255 // 255
    bzero
    pushbytes 0x7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
    b|
