#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    intcblock 0 1 8 48
    intc_0 // 0
    dupn 2
    pushbytes ""
    dupn 6
    txn NumAppArgs
    bz main_bare_routing@6
    pushbytes 0x28d7c1b8 // method "test_array(uint64,uint64,uint64,uint64)uint64"
    txna ApplicationArgs 0
    match main_test_array_route@3

main_after_if_else@10:
    intc_0 // 0
    return

main_test_array_route@3:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    txna ApplicationArgs 1
    txna ApplicationArgs 2
    btoi
    txna ApplicationArgs 3
    txna ApplicationArgs 4
    btoi
    pushbytes 0x00000000000000000000000000000000
    txn Sender
    concat
    txn Sender
    uncover 4
    itob
    uncover 5
    swap
    concat
    swap
    concat
    concat // on error: max array length exceeded
    txn Sender
    uncover 2
    itob
    uncover 3
    swap
    concat
    swap
    concat
    concat // on error: max array length exceeded
    dup
    bury 11
    dup
    bury 9
    dup
    extract 0 8
    bury 10
    dup
    intc_2 // 8
    extract_uint64
    bury 5
    intc_0 // 0
    bury 4
    len
    intc_3 // 48
    /
    bury 7
    intc_1 // 1
    bury 1

main_for_header@15:
    dup
    dig 7
    <
    bz main_after_for@23
    dig 7
    dup
    dig 2
    intc_3 // 48
    *
    dup
    bury 9
    dup2
    intc_3 // 48
    extract3
    cover 2
    intc_2 // 8
    extract3
    swap
    intc_2 // 8
    extract_uint64
    bury 4
    dig 10
    b<
    bz main_else_body@18
    dig 10
    intc_0 // 0
    extract_uint64
    swap
    dig 7
    extract_uint64
    -
    bury 5

main_after_if_else@19:
    dig 1
    dig 4
    <
    bz main_else_body@21
    dig 3
    dig 2
    -

main_after_if_else@22:
    dig 5
    dup
    *
    swap
    dup
    *
    +
    sqrt
    dig 3
    +
    bury 3
    dup
    intc_1 // 1
    +
    bury 1
    b main_for_header@15

main_else_body@21:
    dig 1
    dig 4
    -
    b main_after_if_else@22

main_else_body@18:
    dig 6
    extract_uint64
    dig 10
    intc_0 // 0
    extract_uint64
    -
    bury 5
    b main_after_if_else@19

main_after_for@23:
    dig 2
    itob
    pushbytes 0x151f7c75
    swap
    concat
    log
    intc_1 // 1
    return

main_bare_routing@6:
    txn OnCompletion
    bnz main_after_if_else@10
    txn ApplicationID
    !
    assert // can only call when creating
    intc_1 // 1
    return
