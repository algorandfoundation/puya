contract test_cases.array.contract.Contract:
    program approval:
        subroutine algopy.arc4.ARC4Contract.approval_program() -> bool:
            block@0: // L1
                let tmp%0#0: bytes = (bzero 255u)
                let tmp%1#0: bytes = (b| tmp%0#0 0x7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff)
                write(0u, tmp%1#0)
                let tmp%2#0: bool = test_cases.array.contract.Contract.__puya_arc4_router__()
                return tmp%2#0
        
        subroutine test_cases.array.contract.Contract.__puya_arc4_router__() -> bool:
            block@0: // L4
                let tmp%0#0: uint64 = (txn NumAppArgs)
                goto tmp%0#0 ? block@1 : block@5
            block@1: // abi_routing_L4
                let tmp%2#0: bytes = (txna ApplicationArgs 0)
                switch tmp%2#0 {method "test_array()void" => block@2, * => return 0u}
            block@2: // test_array_route_L6
                let tmp%3#0: uint64 = (txn OnCompletion)
                let tmp%4#0: bool = (! tmp%3#0)
                (assert tmp%4#0) // OnCompletion is not NoOp
                let tmp%5#0: uint64 = (txn ApplicationID)
                (assert tmp%5#0) // can only call when not creating
                test_cases.array.contract.Contract.test_array()
                return 1u
            block@5: // bare_routing_L4
                let tmp%7#0: uint64 = (txn OnCompletion)
                goto tmp%7#0 ? block@9 : block@6
            block@6: // __algopy_default_create_L1
                let tmp%8#0: uint64 = (txn ApplicationID)
                let tmp%9#0: bool = (! tmp%8#0)
                (assert tmp%9#0) // can only call when creating
                return 1u
            block@9: // after_if_else_L4
                return 0u
        
        subroutine test_cases.array.contract.Contract.test_array() -> void:
            block@0: // L6
                let arr#0: slot = _puya_lib.mem.new_slot(0u)
                write(arr#0, 0x)
                let array_contents%1#0: bytes = read(arr#0)
                let contents_length%0#0: uint64 = (len array_contents%1#0)
                let array_length%0#0: uint64 = (/ contents_length%0#0 8u)
                let tmp%0#0: bool = (! array_length%0#0)
                (assert tmp%0#0)
                let array_contents%2#0: bytes = read(arr#0)
                let item_bytes%0#0: bytes = (itob 42u)
                let concat%0#0: bytes = (concat array_contents%2#0 item_bytes%0#0)
                write(arr#0, concat%0#0)
                let array_contents%4#0: bytes = read(arr#0)
                let contents_length%1#0: uint64 = (len array_contents%4#0)
                let array_length%1#0: uint64 = (/ contents_length%1#0 8u)
                let tmp%1#0: bool = (== array_length%1#0 1u)
                (assert tmp%1#0)
                let array_contents%5#0: bytes = read(arr#0)
                let contents_length%2#0: uint64 = (len array_contents%5#0)
                let array_length%2#0: uint64 = (/ contents_length%2#0 8u)
                let array_contents%6#0: bytes = read(arr#0)
                let contents_length%3#0: uint64 = (len array_contents%6#0)
                let array_length%3#0: uint64 = (/ contents_length%3#0 8u)
                let tmp%3#0: uint64 = (- array_length%3#0 1u)
                let array_contents%7#0: bytes = read(arr#0)
                let value%0#0: uint64 = (extract_uint64 array_contents%7#0 tmp%3#0)
                let tmp%4#0: bool = (== value%0#0 42u)
                (assert tmp%4#0)
                let arr#1: slot = test_cases.array.contract.add_x(arr#0, 5u)
                let array_contents%8#0: bytes = read(arr#1)
                let contents_length%4#0: uint64 = (len array_contents%8#0)
                let array_length%4#0: uint64 = (/ contents_length%4#0 8u)
                let tmp%5#0: bool = (== array_length%4#0 6u)
                (assert tmp%5#0)
                let array_contents%9#0: bytes = read(arr#1)
                let contents_length%5#0: uint64 = (len array_contents%9#0)
                let array_length%5#0: uint64 = (/ contents_length%5#0 8u)
                let array_contents%10#0: bytes = read(arr#1)
                let contents_length%6#0: uint64 = (len array_contents%10#0)
                let array_length%6#0: uint64 = (/ contents_length%6#0 8u)
                let tmp%7#0: uint64 = (- array_length%6#0 1u)
                let array_contents%11#0: bytes = read(arr#1)
                let value%1#0: uint64 = (extract_uint64 array_contents%11#0 tmp%7#0)
                let tmp%8#0: bool = (== value%1#0 4u)
                (assert tmp%8#0)
                let array_contents%12#0: bytes = read(arr#1)
                let item_bytes%1#0: bytes = (itob 43u)
                let concat%1#0: bytes = (concat array_contents%12#0 item_bytes%1#0)
                write(arr#1, concat%1#0)
                let array_contents%14#0: bytes = read(arr#1)
                let contents_length%7#0: uint64 = (len array_contents%14#0)
                let array_length%7#0: uint64 = (/ contents_length%7#0 8u)
                let tmp%9#0: bool = (== array_length%7#0 7u)
                (assert tmp%9#0)
                let array_contents%15#0: bytes = read(arr#1)
                let contents_length%8#0: uint64 = (len array_contents%15#0)
                let array_length%8#0: uint64 = (/ contents_length%8#0 8u)
                let array_contents%16#0: bytes = read(arr#1)
                let contents_length%9#0: uint64 = (len array_contents%16#0)
                let array_length%9#0: uint64 = (/ contents_length%9#0 8u)
                let tmp%11#0: uint64 = (- array_length%9#0 1u)
                let array_contents%17#0: bytes = read(arr#1)
                let value%2#0: uint64 = (extract_uint64 array_contents%17#0 tmp%11#0)
                let tmp%12#0: bool = (== value%2#0 43u)
                (assert tmp%12#0)
                let array_contents%18#0: bytes = read(arr#1)
                let value%3#0: uint64 = (extract_uint64 array_contents%18#0 0u)
                let tmp%13#0: bool = (== value%3#0 42u)
                (assert tmp%13#0)
                let arr#2: slot = test_cases.array.contract.pop_x(arr#1, 3u)
                let array_contents%19#0: bytes = read(arr#2)
                let contents_length%10#0: uint64 = (len array_contents%19#0)
                let array_length%10#0: uint64 = (/ contents_length%10#0 8u)
                let tmp%14#0: bool = (== array_length%10#0 4u)
                (assert tmp%14#0)
                let array_contents%20#0: bytes = read(arr#2)
                let contents_length%11#0: uint64 = (len array_contents%20#0)
                let array_length%11#0: uint64 = (/ contents_length%11#0 8u)
                let array_contents%21#0: bytes = read(arr#2)
                let contents_length%12#0: uint64 = (len array_contents%21#0)
                let array_length%12#0: uint64 = (/ contents_length%12#0 8u)
                let tmp%16#0: uint64 = (- array_length%12#0 1u)
                let array_contents%22#0: bytes = read(arr#2)
                let value%4#0: uint64 = (extract_uint64 array_contents%22#0 tmp%16#0)
                let tmp%17#0: bool = (== value%4#0 2u)
                (assert tmp%17#0)
                let arr#3: slot = test_cases.array.contract.add_x(arr#2, 10u)
                let array_contents%23#0: bytes = read(arr#3)
                let contents_length%13#0: uint64 = (len array_contents%23#0)
                let array_length%13#0: uint64 = (/ contents_length%13#0 8u)
                let tmp%18#0: bool = (== array_length%13#0 14u)
                (assert tmp%18#0)
                let array_contents%24#0: bytes = read(arr#3)
                let contents_length%14#0: uint64 = (len array_contents%24#0)
                let array_length%14#0: uint64 = (/ contents_length%14#0 8u)
                let array_contents%25#0: bytes = read(arr#3)
                let contents_length%15#0: uint64 = (len array_contents%25#0)
                let array_length%15#0: uint64 = (/ contents_length%15#0 8u)
                let tmp%20#0: uint64 = (- array_length%15#0 1u)
                let array_contents%26#0: bytes = read(arr#3)
                let value%5#0: uint64 = (extract_uint64 array_contents%26#0 tmp%20#0)
                let tmp%21#0: bool = (== value%5#0 9u)
                (assert tmp%21#0)
                let array_contents%27#0: bytes = read(arr#3)
                let item_bytes%2#0: bytes = (itob 44u)
                let concat%2#0: bytes = (concat array_contents%27#0 item_bytes%2#0)
                write(arr#3, concat%2#0)
                let array_contents%29#0: bytes = read(arr#3)
                let contents_length%16#0: uint64 = (len array_contents%29#0)
                let array_length%16#0: uint64 = (/ contents_length%16#0 8u)
                let tmp%22#0: bool = (== array_length%16#0 15u)
                (assert tmp%22#0)
                let array_contents%30#0: bytes = read(arr#3)
                let contents_length%17#0: uint64 = (len array_contents%30#0)
                let array_length%17#0: uint64 = (/ contents_length%17#0 8u)
                let array_contents%31#0: bytes = read(arr#3)
                let contents_length%18#0: uint64 = (len array_contents%31#0)
                let array_length%18#0: uint64 = (/ contents_length%18#0 8u)
                let tmp%24#0: uint64 = (- array_length%18#0 1u)
                let array_contents%32#0: bytes = read(arr#3)
                let value%6#0: uint64 = (extract_uint64 array_contents%32#0 tmp%24#0)
                let tmp%25#0: bool = (== value%6#0 44u)
                (assert tmp%25#0)
                return 
        
        subroutine test_cases.array.contract.add_x(arr: slot, x: uint64) -> slot:
            block@0: // L39
                let i#0: uint64 = 0u
                goto block@1
            block@1: // for_header_L41
                let i#1: uint64 = φ(i#0 <- block@0, i#2 <- block@2)
                let continue_looping%0#0: bool = (< i#1 x#0)
                goto continue_looping%0#0 ? block@2 : block@4
            block@2: // for_body_L42
                let array_contents%0#0: bytes = read(arr#0)
                let item_bytes%0#0: bytes = (itob i#1)
                let concat%0#0: bytes = (concat array_contents%0#0 item_bytes%0#0)
                write(arr#0, concat%0#0)
                let i#2: uint64 = (+ i#1 1u)
                goto block@1
            block@4: // after_for_L41
                return arr#0
        
        subroutine test_cases.array.contract.pop_x(arr: slot, x: uint64) -> slot:
            block@0: // L45
                let _i#0: uint64 = 0u
                goto block@1
            block@1: // for_header_L47
                let _i#1: uint64 = φ(_i#0 <- block@0, _i#2 <- block@2)
                let continue_looping%0#0: bool = (< _i#1 x#0)
                goto continue_looping%0#0 ? block@2 : block@4
            block@2: // for_body_L48
                let array_contents%0#0: bytes = read(arr#0)
                let length%0#0: uint64 = (len array_contents%0#0)
                let new_length%0#0: uint64 = (- length%0#0 8u)
                let new_contents%0#0: bytes = (extract3 array_contents%0#0 0u new_length%0#0)
                write(arr#0, new_contents%0#0)
                let _i#2: uint64 = (+ _i#1 1u)
                goto block@1
            block@4: // after_for_L47
                return arr#0
        
        subroutine _puya_lib.mem.new_slot(allocation_slot: uint64) -> uint64:
            block@0: // L4
                let allocation#0: bytes = (loads allocation_slot#0)
                let next_slot#0: uint64 = (bitlen allocation#0)
                (assert next_slot#0) // no available slots
                let allocation#1: bytes = (setbit allocation#0 next_slot#0 0u)
                (stores allocation_slot#0 allocation#1)
                return next_slot#0
    
    program clear-state:
        subroutine algopy.arc4.ARC4Contract.clear_state_program() -> bool:
            block@0: // L1
                let tmp%0#0: bytes = (bzero 255u)
                let tmp%1#0: bytes = (b| tmp%0#0 0x7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff)
                write(0u, tmp%1#0)
                return 1u