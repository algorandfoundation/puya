        let slot_contents%1#0: (bytes[8],uint64,bytes[32])[] = read(path#0)
        let tmp%0#0: uint64 = slot_contents%1#0.length
        (assert 1u) // Step cannot be zero
        let point_idx#0: uint64 = 1u
        goto block@1
    block@1: // for_header_L29
