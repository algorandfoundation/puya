subroutine test_cases.array.fixed_size.path_length(path: (bytes[8],uint64,bytes[32])[]*) -> uint64:
    block@0: // L25
        let slot_contents%0#0: (bytes[8],uint64,bytes[32])[] = read(path#0)
        let (last_point.x#0: bytes[8], last_point.y#0: uint64, last_point.z#0: bytes[32]) = slot_contents%0#0[0u]
