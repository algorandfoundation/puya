#pragma version 10
#pragma typetrack false

// test_cases.diamond_mro.derived.Derived.__algopy_entrypoint_with_init() -> uint64:
main:
    pushint 1 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    pushbytes "derived.__init__"
    log
    pushbytes "base1.__init__"
    log
    pushbytes "base2.__init__"
    log
    pushbytes "gp.__init__"
    log

main_after_if_else@2:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    pushbytess 0x4f045d84 0x4c5c61ba // method "method()void", method "create()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_method_route@4 main_create_route@5
    err

main_create_route@5:
    txn ApplicationID
    !
    assert // can only call when creating
    return

main_method_route@4:
    txn ApplicationID
    assert // can only call when not creating
    pushbytes "derived.method"
    log
    pushbytes "base1.method"
    log
    pushbytes "base2.method"
    log
    pushbytes "gp.method"
    log
    return
