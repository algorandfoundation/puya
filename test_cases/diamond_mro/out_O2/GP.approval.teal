#pragma version 10
#pragma typetrack false

// test_cases.diamond_mro.gp.GP.__algopy_entrypoint_with_init() -> uint64:
main:
    pushint 1 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    pushbytes "gp.__init__"
    log

main_after_if_else@2:
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    switch main_switch_case_1@6 main_switch_case_0@4
    err

main_switch_case_0@4:
    pushbytes 0x4c5c61ba // method "create()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_create_route@5
    err

main_create_route@5:
    return

main_switch_case_1@6:
    pushbytes 0x4f045d84 // method "method()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_method_route@7
    err

main_method_route@7:
    pushbytes "gp.method"
    log
    return
