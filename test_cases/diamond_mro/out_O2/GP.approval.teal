#pragma version 10

// test_cases.diamond_mro.gp.GP.__algopy_entrypoint_with_init() -> uint64:
main:
    txn ApplicationID
    bnz main_after_if_else@2
    pushbytes "gp.__init__"
    log

main_after_if_else@2:
    txn NumAppArgs
    bz main_after_if_else@12
    pushbytess 0x4c5c61ba 0x4f045d84 // method "create()void", method "method()void"
    txna ApplicationArgs 0
    match main_create_route@7 main_method_route@8

main_after_if_else@12:
    pushint 0 // 0
    return

main_method_route@8:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    callsub method
    pushint 1 // 1
    return

main_create_route@7:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    !
    assert // can only call when creating
    pushint 1 // 1
    return


// test_cases.diamond_mro.gp.GP.method() -> void:
method:
    proto 0 0
    pushbytes "gp.method"
    log
    retsub
