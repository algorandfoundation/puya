#pragma version 10
#pragma typetrack false

// test_cases.diamond_mro.gp.GP.__algopy_entrypoint_with_init() -> uint64:
main:
    pushint 1 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    pushbytes "gp.__init__"
    log

main_after_if_else@2:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    pushbytess 0x4c5c61ba 0x4f045d84 // method "create()void", method "method()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_create_route@4 main_method_route@5
    err

main_method_route@5:
    txn ApplicationID
    assert // can only call when not creating
    pushbytes "gp.method"
    log
    dup
    return

main_create_route@4:
    txn ApplicationID
    !
    assert // can only call when creating
    dup
    return
