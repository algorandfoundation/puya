main test_cases.diamond_mro.gp.GP.__algopy_entrypoint_with_init:
    block@0: // L1
        let lifted%return#0: bool = 1u
        let tmp%0#0: bool = (txn ApplicationID)
        goto tmp%0#0 ? block@2 : block@1
    block@1: // call __init___L1
        (log "gp.__init__")
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#0: bool = (txn ApplicationID)
        let tmp%1#0: bool = (! tmp%0#0)
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: uint64 = (shl 1u tmp%2#0)
        let tmp%4#0: uint64 = (+ tmp%1#0 tmp%3#0)
        goto_nth [block@6, block@4][tmp%4#0] else goto block@8
    block@4: // switch_case_0_L6
        let tmp%5#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%5#0 {method "create()void" => block@5, * => block@8}
    block@5: // create_route_L11
        exit lifted%return#0
    block@6: // switch_case_1_L6
        let tmp%6#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%6#0 {method "method()void" => block@7, * => block@8}
    block@7: // method_route_L15
        (log "gp.method")
        exit lifted%return#0
    block@8: // switch_case_next_L6
        fail