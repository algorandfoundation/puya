main test_cases.diamond_mro.base2.Base2.__algopy_entrypoint_with_init:
    block@0: // L1
        let tmp%0#0: bool = (txn ApplicationID)
        goto tmp%0#0 ? block@2 : block@1
    block@1: // call __init___L1
        (log "base2.__init__")
        (log "gp.__init__")
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#2: uint64 = (txn OnCompletion)
        let tmp%1#0: bool = (! tmp%0#2)
        (assert tmp%1#0) // OnCompletion is not NoOp
        let tmp%2#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%2#0 {method "method()void" => block@4, method "create()void" => block@5, * => block@6}
    block@4: // method_route_L11
        let tmp%3#0: uint64 = (txn ApplicationID)
        (assert tmp%3#0) // can only call when not creating
        (log "base2.method")
        (log "gp.method")
        exit 1u
    block@5: // create_route_L11
        let tmp%5#0: uint64 = (txn ApplicationID)
        let tmp%6#0: bool = (! tmp%5#0)
        (assert tmp%6#0) // can only call when creating
        exit 1u
    block@6: // switch_case_default_L6
        fail