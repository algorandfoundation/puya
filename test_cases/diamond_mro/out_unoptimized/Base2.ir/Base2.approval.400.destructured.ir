        exit 1u
    block@4: // switch_case_default_L6
        goto block@5
    block@5: // switch_case_next_L6
        exit 0u
    block@6: // after_inlined_test_cases.diamond_mro.base2.Base2.__puya_arc4_router___L1
        let tmp%0#0: bool = undefined
        return tmp%0#0

