main_method_route@4:
    // diamond_mro/base2.py:11
    // @arc4.abimethod
    txn ApplicationID
    assert // can only call when not creating
    // diamond_mro/base2.py:6
    // class Base2(GP):
    callsub method
    // diamond_mro/base2.py:11
    // @arc4.abimethod
    dup
    return


