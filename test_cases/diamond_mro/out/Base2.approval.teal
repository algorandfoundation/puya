#pragma version 10
#pragma typetrack false

// test_cases.diamond_mro.base2.Base2.__algopy_entrypoint_with_init() -> uint64:
main:
    pushbytes ""
    txn ApplicationID
    bnz main_after_if_else@2
    // diamond_mro/base2.py:8
    // log("base2.__init__")
    pushbytes "base2.__init__"
    log
    // diamond_mro/gp.py:8
    // log("gp.__init__")
    pushbytes "gp.__init__"
    log

main_after_if_else@2:
    // diamond_mro/base2.py:11
    // @arc4.abimethod
    pushint 1 // 1
    bury 1
    // diamond_mro/base2.py:6
    // class Base2(GP):
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    pushbytess 0x4f045d84 0x4c5c61ba // method "method()void", method "create()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_method_route@4 main_create_route@5
