main test_cases.diamond_mro.base1.Base1.__algopy_entrypoint_with_init:
    block@0: // L1
        let tmp%0#0: bool = (txn ApplicationID)
        goto tmp%0#0 ? block@2 : block@1
    block@1: // call __init___L1
        (log "base1.__init__")
        (log "gp.__init__")
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#2: bool = (txn ApplicationID)
        let tmp%1#0: bool = (! tmp%0#2)
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: uint64 = (shl 1u tmp%2#0)
        let tmp%4#0: uint64 = (+ tmp%1#0 tmp%3#0)
        goto_nth [block@4, block@6][tmp%4#0] else goto block@8
    block@4: // switch_case_0_L6
        let tmp%5#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%5#0 {method "method()void" => block@5, * => block@8}
    block@5: // method_route_L11
        test_cases.diamond_mro.base1.Base1.method[routing]()
        goto block@8
    block@6: // switch_case_1_L6
        let tmp%6#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%6#0 {method "create()void" => block@7, * => block@8}
    block@7: // create_route_L11
        exit 1u
    block@8: // switch_case_next_L6
        fail

subroutine test_cases.diamond_mro.base1.Base1.method[routing]() -> void:
    block@0: // L6
        (log "base1.method")
        (log "gp.method")
        exit 1u