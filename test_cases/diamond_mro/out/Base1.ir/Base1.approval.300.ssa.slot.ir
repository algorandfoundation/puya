main test_cases.diamond_mro.base1.Base1.__algopy_entrypoint_with_init:
    block@0: // L1
        let tmp%0#0: bool = (txn ApplicationID)
        goto tmp%0#0 ? block@2 : block@1
    block@1: // call __init___L1
        (log "base1.__init__")
        (log "gp.__init__")
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#2: uint64 = (txn OnCompletion)
        goto tmp%0#2 ? block@6 : block@4
    block@4: // simple_routes_L6
        let tmp%2#0: uint64 = (txn ApplicationID)
        (assert tmp%2#0) // can only call when not creating
        let tmp%4#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%4#0 {method "method()void" => block@5, * => block@8}
    block@5: // method_route_L11
        test_cases.diamond_mro.base1.Base1.method[routing]()
        exit 1u
    block@6: // other_routes_L6
        let tmp%5#0: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%5#0 {method "create()void" => block@7, * => block@8}
    block@7: // create_route_L11
        let tmp%6#0: uint64 = (txn OnCompletion)
        let tmp%7#0: bool = (! tmp%6#0)
        (assert tmp%7#0) // OnCompletion is not NoOp
        let tmp%8#0: uint64 = (txn ApplicationID)
        let tmp%9#0: bool = (! tmp%8#0)
        (assert tmp%9#0) // can only call when creating
        exit 1u
    block@8: // after_if_else_L6
        fail

subroutine test_cases.diamond_mro.base1.Base1.method[routing]() -> void:
    block@0: // L6
        (log "base1.method")
        (log "gp.method")
        return 