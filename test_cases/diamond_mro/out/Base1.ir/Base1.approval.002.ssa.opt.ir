main test_cases.diamond_mro.base1.Base1.__algopy_entrypoint_with_init:
    block@0: // L1
        let tmp%0#0: bool = (txn ApplicationID)
        goto tmp%0#0 ? block@2 : block@1
    block@1: // call __init___L1
        (log "base1.__init__")
        (log "gp.__init__")
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#2: bytes = (txna ApplicationArgs 0) // on error: contract does not allow bare method calls
        switch tmp%0#2 {method "method()void" => block@4, method "create()void" => block@5, * => block@6}
    block@4: // method_route_L11
        let tmp%1#0: uint64 = (txn OnCompletion)
        let tmp%2#0: bool = (! tmp%1#0)
        (assert tmp%2#0) // OnCompletion is not NoOp
        let tmp%3#0: uint64 = (txn ApplicationID)
        (assert tmp%3#0) // can only call when not creating
        test_cases.diamond_mro.base1.Base1.method[routing]()
        exit 1u
    block@5: // create_route_L11
        let tmp%5#0: uint64 = (txn OnCompletion)
        let tmp%6#0: bool = (! tmp%5#0)
        (assert tmp%6#0) // OnCompletion is not NoOp
        let tmp%7#0: uint64 = (txn ApplicationID)
        let tmp%8#0: bool = (! tmp%7#0)
        (assert tmp%8#0) // can only call when creating
        test_cases.diamond_mro.gp.GP.create[routing]()
        exit 1u
    block@6: // switch_case_default_L6
        fail

subroutine test_cases.diamond_mro.base1.Base1.method[routing]() -> void:
    block@0: // L6
        (log "base1.method")
        (log "gp.method")
        return 

subroutine test_cases.diamond_mro.gp.GP.create[routing]() -> void:
    block@0: // L6
        return 