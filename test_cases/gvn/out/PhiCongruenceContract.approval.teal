#pragma version 11
#pragma typetrack false

// test_cases.gvn.phi_congruence.PhiCongruenceContract.approval_program() -> uint64:
main:
    intcblock 0 5 1 10
    // gvn/phi_congruence.py:13
    // assert test_cross_assignment(UInt64(42)) == 84
    pushint 42
    callsub test_cross_assignment
    pushint 84
    ==
    assert
    // gvn/phi_congruence.py:14
    // assert test_cross_assignment(UInt64(0)) == 0
    intc_0 // 0
    callsub test_cross_assignment
    !
    assert
    // gvn/phi_congruence.py:15
    // assert test_triple_cycle(UInt64(10)) == 30
    intc_3 // 10
    callsub test_triple_cycle
    pushint 30
    ==
    assert
    // gvn/phi_congruence.py:16
    // assert test_redundant_phi(Txn.num_app_args, UInt64(5)) == Txn.num_app_args | 5
    txn NumAppArgs
    intc_1 // 5
    callsub test_redundant_phi
    txn NumAppArgs
    intc_1 // 5
    |
    ==
    assert
    // gvn/phi_congruence.py:17
    // return True
    intc_2 // 1
    return


// test_cases.gvn.phi_congruence.test_redundant_phi(a: uint64, b: uint64) -> uint64:
test_redundant_phi:
    // gvn/phi_congruence.py:23-24
    // @subroutine(inline=False)
    // def test_redundant_phi(a: UInt64, b: UInt64) -> UInt64:
    proto 2 1
    // gvn/phi_congruence.py:40
    // val1 = a | b
    frame_dig -2
    frame_dig -1
    |
    // gvn/phi_congruence.py:42
    // if a > b:
    frame_dig -2
    frame_dig -1
    >
    bz test_redundant_phi_else_body@2
    // gvn/phi_congruence.py:43
    // log(op.itob(a))  # side effect to keep branch alive
    frame_dig -2
    itob
    log

test_redundant_phi_after_if_else@3:
    // gvn/phi_congruence.py:48
    // return result
    frame_dig 0
    swap
    retsub

test_redundant_phi_else_body@2:
    // gvn/phi_congruence.py:46
    // log(op.itob(b))
    frame_dig -1
    itob
    log
    b test_redundant_phi_after_if_else@3


// test_cases.gvn.phi_congruence.test_cross_assignment(n: uint64) -> uint64:
test_cross_assignment:
    // gvn/phi_congruence.py:51-52
    // @subroutine(inline=False)
    // def test_cross_assignment(n: UInt64) -> UInt64:
    proto 1 1
    // gvn/phi_congruence.py:63
    // for _i in urange(10):
    intc_0 // 0

test_cross_assignment_for_header@1:
    // gvn/phi_congruence.py:63
    // for _i in urange(10):
    frame_dig 0
    intc_3 // 10
    <
    bz test_cross_assignment_after_for@4
    frame_dig 0
    intc_2 // 1
    +
    frame_bury 0
    b test_cross_assignment_for_header@1

test_cross_assignment_after_for@4:
    // gvn/phi_congruence.py:67-68
    // # x == y == n, so x + y == 2*n
    // return x + y
    frame_dig -1
    dup
    +
    swap
    retsub


// test_cases.gvn.phi_congruence.test_triple_cycle(n: uint64) -> uint64:
test_triple_cycle:
    // gvn/phi_congruence.py:71-72
    // @subroutine(inline=False)
    // def test_triple_cycle(n: UInt64) -> UInt64:
    proto 1 1
    // gvn/phi_congruence.py:84
    // for _i in urange(5):
    intc_0 // 0

test_triple_cycle_for_header@1:
    // gvn/phi_congruence.py:84
    // for _i in urange(5):
    frame_dig 0
    intc_1 // 5
    <
    bz test_triple_cycle_after_for@4
    frame_dig 0
    intc_2 // 1
    +
    frame_bury 0
    b test_triple_cycle_for_header@1

test_triple_cycle_after_for@4:
    // gvn/phi_congruence.py:90-91
    // # a == b == c == n, so a + b + c == 3*n
    // return a + b + c
    frame_dig -1
    dup
    +
    frame_dig -1
    +
    swap
    retsub
