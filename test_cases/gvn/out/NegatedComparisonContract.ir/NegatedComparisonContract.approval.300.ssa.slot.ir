main test_cases.gvn.negated_comparisons.NegatedComparisonContract.approval_program:
    block@0: // L11
        let a#0: uint64 = (txn NumAppArgs)
        let b#0: uint64 = (+ a#0 1u)
        test_cases.gvn.negated_comparisons.test_uint64_negated(a#0, b#0)
        let tmp%2#0: biguint = (itob a#0)
        let tmp%3#0: biguint = (itob b#0)
        test_cases.gvn.negated_comparisons.test_biguint_negated(tmp%2#0, tmp%3#0)
        return 1u

subroutine test_cases.gvn.negated_comparisons.test_uint64_negated(a: uint64, b: uint64) -> void:
    block@0: // L22
        let tmp%0#0: bool = (< a#0 b#0)
        (assert tmp%0#0)
        let tmp%1#0: bool = (>= a#0 b#0)
        let tmp%2#0: bool = (! tmp%1#0)
        (assert tmp%2#0)
        let tmp%3#0: bool = (<= a#0 b#0)
        (assert tmp%3#0)
        let tmp%4#0: bool = (> a#0 b#0)
        let tmp%5#0: bool = (! tmp%4#0)
        (assert tmp%5#0)
        let tmp%6#0: bool = (!= a#0 b#0)
        (assert tmp%6#0)
        let eq_result#0: bool = (== a#0 b#0)
        let tmp%8#0: bool = (! eq_result#0)
        (assert tmp%8#0)
        return 

subroutine test_cases.gvn.negated_comparisons.test_biguint_negated(a: biguint, b: biguint) -> void:
    block@0: // L40
        let tmp%0#0: bool = (b< a#0 b#0)
        (assert tmp%0#0)
        let tmp%1#0: bool = (b>= a#0 b#0)
        let tmp%2#0: bool = (! tmp%1#0)
        (assert tmp%2#0)
        let tmp%3#0: bool = (b<= a#0 b#0)
        (assert tmp%3#0)
        let tmp%4#0: bool = (b> a#0 b#0)
        let tmp%5#0: bool = (! tmp%4#0)
        (assert tmp%5#0)
        let tmp%6#0: bool = (b!= a#0 b#0)
        (assert tmp%6#0)
        let eq_result#0: bool = (b== a#0 b#0)
        let tmp%8#0: bool = (! eq_result#0)
        (assert tmp%8#0)
        return 