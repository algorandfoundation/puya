// Op                                                               Stack (out)
// test_cases.gvn.negated_comparisons.NegatedComparisonContract.approval_program() -> uint64:
subroutine main:
    main_block@0:
        // gvn/negated_comparisons.py:12
        // a = Txn.num_app_args
        txn NumAppArgs                                              a#0
        v-store a#0
        // gvn/negated_comparisons.py:13
        // b = a + 1  # a < b always holds
        v-load a#0                                                  a#0
        int 1                                                       a#0,1
        +                                                           b#0
        v-store b#0
        // gvn/negated_comparisons.py:14
        // test_uint64_negated(a, b)
        v-load a#0                                                  a#0
        v-load b#0                                                  a#0,b#0
        callsub test_uint64_negated
        // gvn/negated_comparisons.py:15
        // test_biguint_negated(BigUInt(a), BigUInt(b))
        v-load a#0                                                  a#0
        itob                                                        tmp%2#0
        v-store tmp%2#0
        v-load b#0                                                  b#0
        itob                                                        tmp%3#0
        v-store tmp%3#0
        v-load tmp%2#0                                              tmp%2#0
        v-load tmp%3#0                                              tmp%2#0,tmp%3#0
        callsub test_biguint_negated
        // gvn/negated_comparisons.py:16
        // return True
        int 1                                                       1
        return


// test_cases.gvn.negated_comparisons.test_uint64_negated(a: uint64, b: uint64) -> void:
subroutine test_uint64_negated:
    test_uint64_negated_block@0:                                    (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:29
        // assert a < b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        <                                                           (𝕡) a#0,b#0 | tmp%0#0
        v-store tmp%0#0                                             (𝕡) a#0,b#0 |
        v-load tmp%0#0                                              (𝕡) a#0,b#0 | tmp%0#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:30
        // assert not (a >= b)  # inverse of <
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        >=                                                          (𝕡) a#0,b#0 | tmp%1#0
        v-store tmp%1#0                                             (𝕡) a#0,b#0 |
        v-load tmp%1#0                                              (𝕡) a#0,b#0 | tmp%1#0
        !                                                           (𝕡) a#0,b#0 | tmp%2#0
        v-store tmp%2#0                                             (𝕡) a#0,b#0 |
        v-load tmp%2#0                                              (𝕡) a#0,b#0 | tmp%2#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:32
        // assert a <= b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        <=                                                          (𝕡) a#0,b#0 | tmp%3#0
        v-store tmp%3#0                                             (𝕡) a#0,b#0 |
        v-load tmp%3#0                                              (𝕡) a#0,b#0 | tmp%3#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:33
        // assert not (a > b)  # inverse of <=
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        >                                                           (𝕡) a#0,b#0 | tmp%4#0
        v-store tmp%4#0                                             (𝕡) a#0,b#0 |
        v-load tmp%4#0                                              (𝕡) a#0,b#0 | tmp%4#0
        !                                                           (𝕡) a#0,b#0 | tmp%5#0
        v-store tmp%5#0                                             (𝕡) a#0,b#0 |
        v-load tmp%5#0                                              (𝕡) a#0,b#0 | tmp%5#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:35
        // assert a != b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        !=                                                          (𝕡) a#0,b#0 | tmp%6#0
        v-store tmp%6#0                                             (𝕡) a#0,b#0 |
        v-load tmp%6#0                                              (𝕡) a#0,b#0 | tmp%6#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:36
        // eq_result = a == b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        ==                                                          (𝕡) a#0,b#0 | eq_result#0
        v-store eq_result#0                                         (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:37
        // assert not eq_result  # !(==) should get same VN as !=
        v-load eq_result#0                                          (𝕡) a#0,b#0 | eq_result#0
        !                                                           (𝕡) a#0,b#0 | tmp%8#0
        v-store tmp%8#0                                             (𝕡) a#0,b#0 |
        v-load tmp%8#0                                              (𝕡) a#0,b#0 | tmp%8#0
        assert                                                      (𝕡) a#0,b#0 |
        retsub


// test_cases.gvn.negated_comparisons.test_biguint_negated(a: bytes, b: bytes) -> void:
subroutine test_biguint_negated:
    test_biguint_negated_block@0:                                   (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:43
        // assert a < b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b<                                                          (𝕡) a#0,b#0 | tmp%0#0
        v-store tmp%0#0                                             (𝕡) a#0,b#0 |
        v-load tmp%0#0                                              (𝕡) a#0,b#0 | tmp%0#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:44
        // assert not (a >= b)  # inverse of b<
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b>=                                                         (𝕡) a#0,b#0 | tmp%1#0
        v-store tmp%1#0                                             (𝕡) a#0,b#0 |
        v-load tmp%1#0                                              (𝕡) a#0,b#0 | tmp%1#0
        !                                                           (𝕡) a#0,b#0 | tmp%2#0
        v-store tmp%2#0                                             (𝕡) a#0,b#0 |
        v-load tmp%2#0                                              (𝕡) a#0,b#0 | tmp%2#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:46
        // assert a <= b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b<=                                                         (𝕡) a#0,b#0 | tmp%3#0
        v-store tmp%3#0                                             (𝕡) a#0,b#0 |
        v-load tmp%3#0                                              (𝕡) a#0,b#0 | tmp%3#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:47
        // assert not (a > b)  # inverse of b<=
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b>                                                          (𝕡) a#0,b#0 | tmp%4#0
        v-store tmp%4#0                                             (𝕡) a#0,b#0 |
        v-load tmp%4#0                                              (𝕡) a#0,b#0 | tmp%4#0
        !                                                           (𝕡) a#0,b#0 | tmp%5#0
        v-store tmp%5#0                                             (𝕡) a#0,b#0 |
        v-load tmp%5#0                                              (𝕡) a#0,b#0 | tmp%5#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:49
        // assert a != b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b!=                                                         (𝕡) a#0,b#0 | tmp%6#0
        v-store tmp%6#0                                             (𝕡) a#0,b#0 |
        v-load tmp%6#0                                              (𝕡) a#0,b#0 | tmp%6#0
        assert                                                      (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:50
        // eq_result = a == b
        p-load a#0                                                  (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                  (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b==                                                         (𝕡) a#0,b#0 | eq_result#0
        v-store eq_result#0                                         (𝕡) a#0,b#0 |
        // gvn/negated_comparisons.py:51
        // assert not eq_result  # !(b==) should get same VN as b!=
        v-load eq_result#0                                          (𝕡) a#0,b#0 | eq_result#0
        !                                                           (𝕡) a#0,b#0 | tmp%8#0
        v-store tmp%8#0                                             (𝕡) a#0,b#0 |
        v-load tmp%8#0                                              (𝕡) a#0,b#0 | tmp%8#0
        assert                                                      (𝕡) a#0,b#0 |
        retsub


