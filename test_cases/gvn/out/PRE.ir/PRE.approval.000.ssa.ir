main test_cases.gvn.partial_redundancy_elimination.PRE.approval_program:
    block@0: // L5
        let a#0: uint64 = 3u
        let b#0: uint64 = 5u
        let loop_counter%0#0: uint64 = 0u
        let cond#0: bool = 1u
        goto block@1
    block@1: // for_body_L9
        let loop_counter%0#1: uint64 = φ(loop_counter%0#0 <- block@0, loop_counter%0#2 <- block@3)
        let cond#1: bool = φ(cond#0 <- block@0, cond#2 <- block@3)
        let tmp%0#0: uint64 = test_cases.gvn.partial_redundancy_elimination.test(a#0, b#0, cond#1)
        let tmp%1#0: uint64 = (+ a#0 b#0)
        let tmp%2#0: bool = (== tmp%0#0 tmp%1#0)
        (assert tmp%2#0)
        goto block@2
    block@2: // for_footer_L8
        goto_nth [block@3][loop_counter%0#1] else goto block@4
    block@3: // for_header_1_L8
        let loop_counter%0#2: uint64 = 1u
        let cond#2: bool = 0u
        goto block@1
    block@4: // after_for_L8
        return 1u

subroutine test_cases.gvn.partial_redundancy_elimination.test(a: uint64, b: uint64, cond: bool) -> uint64:
    block@0: // L16
        goto cond#0 ? block@1 : block@2
    block@1: // if_body_L19
        let tmp%0#0: uint64 = (+ a#0 b#0)
        let result#0: uint64 = tmp%0#0
        let tmp%1#0: bytes = (concat "cond: " "")
        let tmp%2#0: bytes = (itob result#0)
        let tmp%3#0: bytes = (concat tmp%1#0 tmp%2#0)
        (log tmp%3#0)
        goto block@3
    block@2: // else_body_L22
        let tmp%4#0: uint64 = (+ a#0 b#0)
        let result#1: uint64 = tmp%4#0
        let tmp%5#0: bytes = (concat "!cond: " "")
        let tmp%6#0: bytes = (itob result#1)
        let tmp%7#0: bytes = (concat tmp%5#0 tmp%6#0)
        (log tmp%7#0)
        goto block@3
    block@3: // after_if_else_L18
        let result#2: uint64 = φ(result#0 <- block@1, result#1 <- block@2)
        let tmp%8#0: uint64 = (+ b#0 a#0)
        let tmp%9#0: bool = (== result#2 tmp%8#0)
        (assert tmp%9#0)
        return result#2