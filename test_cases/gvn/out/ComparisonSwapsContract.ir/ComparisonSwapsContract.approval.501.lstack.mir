// Op                                                                Stack (out)
// test_cases.gvn.comparison_swaps.ComparisonSwapsContract.approval_program() -> uint64:
subroutine main:
    main_block@0:
        // gvn/comparison_swaps.py:13
        // test_uint64_swaps(Txn.num_app_args, Txn.num_app_args + 1)
        txn NumAppArgs                                               tmp%0#0
        txn NumAppArgs                                               tmp%0#0,tmp%1#0
        l-load tmp%1#0 0                                             tmp%0#0,tmp%1#0
        int 1                                                        tmp%0#0,tmp%1#0,1
        +                                                            tmp%0#0,tmp%2#0
        l-load tmp%0#0 1                                             tmp%2#0,tmp%0#0
        l-load tmp%2#0 1                                             tmp%0#0,tmp%2#0
        callsub test_uint64_swaps
        // gvn/comparison_swaps.py:14
        // test_biguint_swaps(BigUInt(1), BigUInt(2))
        byte 0x01                                                    0x01
        byte 0x02                                                    0x01,0x02
        callsub test_biguint_swaps
        // gvn/comparison_swaps.py:15
        // return True
        int 1                                                        1
        return


// test_cases.gvn.comparison_swaps.test_uint64_swaps(a: uint64, b: uint64) -> void:
subroutine test_uint64_swaps:
    test_uint64_swaps_block@0:                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:29
        // assert a < b
        p-load a#0                                                   (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                   (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        <                                                            (𝕡) a#0,b#0 | tmp%0#0
        l-load tmp%0#0 0                                             (𝕡) a#0,b#0 | tmp%0#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:30
        // assert b > a  # converse of a < b
        p-load b#0                                                   (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                   (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        >                                                            (𝕡) a#0,b#0 | tmp%1#0
        l-load tmp%1#0 0                                             (𝕡) a#0,b#0 | tmp%1#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:32
        // assert a <= b
        p-load a#0                                                   (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                   (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        <=                                                           (𝕡) a#0,b#0 | tmp%2#0
        l-load tmp%2#0 0                                             (𝕡) a#0,b#0 | tmp%2#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:33
        // assert b >= a  # converse of a <= b
        p-load b#0                                                   (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                   (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        >=                                                           (𝕡) a#0,b#0 | tmp%3#0
        l-load tmp%3#0 0                                             (𝕡) a#0,b#0 | tmp%3#0
        assert                                                       (𝕡) a#0,b#0 |
        retsub


// test_cases.gvn.comparison_swaps.test_biguint_swaps(a: bytes, b: bytes) -> void:
subroutine test_biguint_swaps:
    test_biguint_swaps_block@0:                                      (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:39
        // assert a < b
        p-load a#0                                                   (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                   (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b<                                                           (𝕡) a#0,b#0 | tmp%0#0
        l-load tmp%0#0 0                                             (𝕡) a#0,b#0 | tmp%0#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:40
        // assert b > a  # converse of a < b
        p-load b#0                                                   (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                   (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        b>                                                           (𝕡) a#0,b#0 | tmp%1#0
        l-load tmp%1#0 0                                             (𝕡) a#0,b#0 | tmp%1#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:42
        // assert a <= b
        p-load a#0                                                   (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                   (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        b<=                                                          (𝕡) a#0,b#0 | tmp%2#0
        l-load tmp%2#0 0                                             (𝕡) a#0,b#0 | tmp%2#0
        assert                                                       (𝕡) a#0,b#0 |
        // gvn/comparison_swaps.py:43
        // assert b >= a  # converse of a <= b
        p-load b#0                                                   (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                   (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        b>=                                                          (𝕡) a#0,b#0 | tmp%3#0
        l-load tmp%3#0 0                                             (𝕡) a#0,b#0 | tmp%3#0
        assert                                                       (𝕡) a#0,b#0 |
        retsub


