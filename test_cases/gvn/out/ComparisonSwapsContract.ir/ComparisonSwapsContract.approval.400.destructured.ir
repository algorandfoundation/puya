main test_cases.gvn.comparison_swaps.ComparisonSwapsContract.approval_program:
    block@0: // L12
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let tmp%1#0: uint64 = (txn NumAppArgs)
        let tmp%2#0: uint64 = (+ tmp%1#0 1u)
        test_cases.gvn.comparison_swaps.test_uint64_swaps(tmp%0#0, tmp%2#0)
        test_cases.gvn.comparison_swaps.test_biguint_swaps(1b, 2b)
        return 1u

subroutine test_cases.gvn.comparison_swaps.test_uint64_swaps(a: uint64, b: uint64) -> void:
    block@0: // L21
        let tmp%0#0: bool = (< a#0 b#0)
        (assert tmp%0#0)
        let tmp%1#0: bool = (> b#0 a#0)
        (assert tmp%1#0)
        let tmp%2#0: bool = (<= a#0 b#0)
        (assert tmp%2#0)
        let tmp%3#0: bool = (>= b#0 a#0)
        (assert tmp%3#0)
        return 

subroutine test_cases.gvn.comparison_swaps.test_biguint_swaps(a: biguint, b: biguint) -> void:
    block@0: // L36
        let tmp%0#0: bool = (b< a#0 b#0)
        (assert tmp%0#0)
        let tmp%1#0: bool = (b> b#0 a#0)
        (assert tmp%1#0)
        let tmp%2#0: bool = (b<= a#0 b#0)
        (assert tmp%2#0)
        let tmp%3#0: bool = (b>= b#0 a#0)
        (assert tmp%3#0)
        return 