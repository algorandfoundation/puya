// Op                                                                                     Stack (out)
// test_cases.gvn.phi_congruence.PhiCongruenceContract.approval_program() -> uint64:
subroutine main:
    main_block@0:
        // gvn/phi_congruence.py:13
        // assert test_cross_assignment(UInt64(42)) == 84
        int 42                                                                            42
        callsub test_cross_assignment                                                     tmp%0#0
        int 84                                                                            tmp%0#0,84
        ==                                                                                tmp%1#0
        assert
        // gvn/phi_congruence.py:14
        // assert test_cross_assignment(UInt64(0)) == 0
        int 0                                                                             0
        callsub test_cross_assignment                                                     tmp%2#0
        !                                                                                 tmp%3#0
        assert
        // gvn/phi_congruence.py:15
        // assert test_triple_cycle(UInt64(10)) == 30
        int 10                                                                            10
        callsub test_triple_cycle                                                         tmp%4#0
        int 30                                                                            tmp%4#0,30
        ==                                                                                tmp%5#0
        assert
        // gvn/phi_congruence.py:16
        // assert test_redundant_phi(Txn.num_app_args, UInt64(5)) == Txn.num_app_args | 5
        txn NumAppArgs                                                                    tmp%6#0
        int 5                                                                             tmp%6#0,5
        callsub test_redundant_phi                                                        tmp%7#0
        txn NumAppArgs                                                                    tmp%7#0,tmp%8#0
        int 5                                                                             tmp%7#0,tmp%8#0,5
        |                                                                                 tmp%7#0,tmp%9#0
        l-load tmp%7#0 1                                                                  tmp%9#0,tmp%7#0
        l-load tmp%9#0 1                                                                  tmp%7#0,tmp%9#0
        ==                                                                                tmp%10#0
        assert
        // gvn/phi_congruence.py:17
        // return True
        int 1                                                                             1
        return


// test_cases.gvn.phi_congruence.test_redundant_phi(a: uint64, b: uint64) -> uint64:
subroutine test_redundant_phi:
    test_redundant_phi_block@0:                                                           (𝕡) a#0,b#0 |
        // gvn/phi_congruence.py:40
        // val1 = a | b
        p-load a#0                                                                        (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                                        (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        |                                                                                 (𝕡) a#0,b#0 | val1#0
        v-store val1#0                                                                    (𝕡) a#0,b#0 |
        // gvn/phi_congruence.py:41
        // val2 = b | a
        p-load b#0                                                                        (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                                        (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        |                                                                                 (𝕡) a#0,b#0 | val2#0
        v-store val2#0                                                                    (𝕡) a#0,b#0 |
        // gvn/phi_congruence.py:42
        // if a > b:
        p-load a#0                                                                        (𝕡) a#0,b#0 | a#0 (copy)
        p-load b#0                                                                        (𝕡) a#0,b#0 | a#0 (copy),b#0 (copy)
        >                                                                                 (𝕡) a#0,b#0 | tmp%2#0
        bz test_redundant_phi_else_body@2 ; b test_redundant_phi_if_body@1                (𝕡) a#0,b#0 |

    test_redundant_phi_if_body@1:                                                         (𝕡) a#0,b#0 |
        // gvn/phi_congruence.py:43
        // log(op.itob(a))  # side effect to keep branch alive
        p-load a#0                                                                        (𝕡) a#0,b#0 | a#0 (copy)
        itob                                                                              (𝕡) a#0,b#0 | tmp%3#0
        log                                                                               (𝕡) a#0,b#0 |
        v-load val1#0                                                                     (𝕡) a#0,b#0 | result#2
        x-store result#2                                                                  (𝕡) a#0,b#0 | (𝕏) result#2 |
        b test_redundant_phi_after_if_else@3                                              (𝕡) a#0,b#0 | (𝕏) result#2 |

    test_redundant_phi_else_body@2:                                                       (𝕡) a#0,b#0 |
        // gvn/phi_congruence.py:46
        // log(op.itob(b))
        p-load b#0                                                                        (𝕡) a#0,b#0 | b#0 (copy)
        itob                                                                              (𝕡) a#0,b#0 | tmp%4#0
        log                                                                               (𝕡) a#0,b#0 |
        v-load val2#0                                                                     (𝕡) a#0,b#0 | result#2
        x-store result#2                                                                  (𝕡) a#0,b#0 | (𝕏) result#2 |
        b test_redundant_phi_after_if_else@3                                              (𝕡) a#0,b#0 | (𝕏) result#2 |

    test_redundant_phi_after_if_else@3:                                                   (𝕡) a#0,b#0 | (𝕏) result#2 |
        // gvn/phi_congruence.py:48
        // return result
        x-load result#2                                                                   (𝕡) a#0,b#0 | result#2
        retsub                                                                            result#2


// test_cases.gvn.phi_congruence.test_cross_assignment(n: uint64) -> uint64:
subroutine test_cross_assignment:
    test_cross_assignment_block@0:                                                        (𝕡) n#0 |
        // gvn/phi_congruence.py:63
        // for _i in urange(10):
        int 0                                                                             (𝕡) n#0 | value_internal%0#0
        p-load n#0                                                                        (𝕡) n#0 | value_internal%0#0,y#1
        l-store-copy y#1 0                                                                (𝕡) n#0 | value_internal%0#0,y#1,y#1 (copy)
        v-store y#1                                                                       (𝕡) n#0 | value_internal%0#0,y#1
        l-load y#1 0                                                                      (𝕡) n#0 | value_internal%0#0,y#1
        v-store x#1                                                                       (𝕡) n#0 | value_internal%0#0
        l-load value_internal%0#0 0                                                       (𝕡) n#0 | value_internal%0#0
        v-store _i#0                                                                      (𝕡) n#0 |
        b test_cross_assignment_for_header@1                                              (𝕡) n#0 |

    test_cross_assignment_for_header@1:                                                   (𝕡) n#0 |
        // gvn/phi_congruence.py:63
        // for _i in urange(10):
        v-load _i#0                                                                       (𝕡) n#0 | _i#0
        int 10                                                                            (𝕡) n#0 | _i#0,10
        <                                                                                 (𝕡) n#0 | continue_looping%0#0
        bz test_cross_assignment_after_for@4 ; b test_cross_assignment_for_body@2         (𝕡) n#0 |

    test_cross_assignment_for_body@2:                                                     (𝕡) n#0 |
        // gvn/phi_congruence.py:63
        // for _i in urange(10):
        v-load _i#0                                                                       (𝕡) n#0 | _i#0
        int 1                                                                             (𝕡) n#0 | _i#0,1
        +                                                                                 (𝕡) n#0 | value_internal%0#0
        v-store _i#0                                                                      (𝕡) n#0 |
        v-load y#1                                                                        (𝕡) n#0 | parcopy%0#0
        v-load x#1                                                                        (𝕡) n#0 | parcopy%0#0,x#1
        v-store y#1                                                                       (𝕡) n#0 | parcopy%0#0
        l-load parcopy%0#0 0                                                              (𝕡) n#0 | parcopy%0#0
        v-store x#1                                                                       (𝕡) n#0 |
        b test_cross_assignment_for_header@1                                              (𝕡) n#0 |

    test_cross_assignment_after_for@4:                                                    (𝕡) n#0 |
        // gvn/phi_congruence.py:68
        // return x + y
        v-load x#1                                                                        (𝕡) n#0 | x#1
        v-load y#1                                                                        (𝕡) n#0 | x#1,y#1
        +                                                                                 (𝕡) n#0 | tmp%0#0
        retsub                                                                            tmp%0#0


// test_cases.gvn.phi_congruence.test_triple_cycle(n: uint64) -> uint64:
subroutine test_triple_cycle:
    test_triple_cycle_block@0:                                                            (𝕡) n#0 |
        // gvn/phi_congruence.py:84
        // for _i in urange(5):
        int 0                                                                             (𝕡) n#0 | value_internal%0#0
        p-load n#0                                                                        (𝕡) n#0 | value_internal%0#0,c#1
        l-store-copy c#1 0                                                                (𝕡) n#0 | value_internal%0#0,c#1,c#1 (copy)
        v-store c#1                                                                       (𝕡) n#0 | value_internal%0#0,c#1
        l-load c#1 0                                                                      (𝕡) n#0 | value_internal%0#0,b#1
        l-store-copy b#1 0                                                                (𝕡) n#0 | value_internal%0#0,b#1,b#1 (copy)
        v-store b#1                                                                       (𝕡) n#0 | value_internal%0#0,b#1
        l-load b#1 0                                                                      (𝕡) n#0 | value_internal%0#0,b#1
        v-store a#1                                                                       (𝕡) n#0 | value_internal%0#0
        l-load value_internal%0#0 0                                                       (𝕡) n#0 | value_internal%0#0
        v-store _i#0                                                                      (𝕡) n#0 |
        b test_triple_cycle_for_header@1                                                  (𝕡) n#0 |

    test_triple_cycle_for_header@1:                                                       (𝕡) n#0 |
        // gvn/phi_congruence.py:84
        // for _i in urange(5):
        v-load _i#0                                                                       (𝕡) n#0 | _i#0
        int 5                                                                             (𝕡) n#0 | _i#0,5
        <                                                                                 (𝕡) n#0 | continue_looping%0#0
        bz test_triple_cycle_after_for@4 ; b test_triple_cycle_for_body@2                 (𝕡) n#0 |

    test_triple_cycle_for_body@2:                                                         (𝕡) n#0 |
        // gvn/phi_congruence.py:84
        // for _i in urange(5):
        v-load _i#0                                                                       (𝕡) n#0 | _i#0
        int 1                                                                             (𝕡) n#0 | _i#0,1
        +                                                                                 (𝕡) n#0 | value_internal%0#0
        v-store _i#0                                                                      (𝕡) n#0 |
        v-load c#1                                                                        (𝕡) n#0 | parcopy%0#0
        v-load b#1                                                                        (𝕡) n#0 | parcopy%0#0,b#1
        v-store c#1                                                                       (𝕡) n#0 | parcopy%0#0
        v-load a#1                                                                        (𝕡) n#0 | parcopy%0#0,a#1
        v-store b#1                                                                       (𝕡) n#0 | parcopy%0#0
        l-load parcopy%0#0 0                                                              (𝕡) n#0 | parcopy%0#0
        v-store a#1                                                                       (𝕡) n#0 |
        b test_triple_cycle_for_header@1                                                  (𝕡) n#0 |

    test_triple_cycle_after_for@4:                                                        (𝕡) n#0 |
        // gvn/phi_congruence.py:91
        // return a + b + c
        v-load a#1                                                                        (𝕡) n#0 | a#1
        v-load b#1                                                                        (𝕡) n#0 | a#1,b#1
        +                                                                                 (𝕡) n#0 | tmp%0#0
        v-load c#1                                                                        (𝕡) n#0 | tmp%0#0,c#1
        +                                                                                 (𝕡) n#0 | tmp%1#0
        retsub                                                                            tmp%1#0


