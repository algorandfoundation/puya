main test_cases.gvn.phi_congruence.PhiCongruenceContract.approval_program:
    block@0: // L12
        let tmp%0#0: uint64 = test_cases.gvn.phi_congruence.test_cross_assignment(42u)
        let tmp%1#0: bool = (== tmp%0#0 84u)
        (assert tmp%1#0)
        let tmp%2#0: uint64 = test_cases.gvn.phi_congruence.test_cross_assignment(0u)
        let tmp%3#0: bool = (== tmp%2#0 0u)
        (assert tmp%3#0)
        let tmp%4#0: uint64 = test_cases.gvn.phi_congruence.test_triple_cycle(10u)
        let tmp%5#0: bool = (== tmp%4#0 30u)
        (assert tmp%5#0)
        let tmp%6#0: uint64 = (txn NumAppArgs)
        let tmp%7#0: uint64 = test_cases.gvn.phi_congruence.test_redundant_phi(tmp%6#0, 5u)
        let tmp%8#0: uint64 = (txn NumAppArgs)
        let tmp%9#0: uint64 = (| tmp%8#0 5u)
        let tmp%10#0: bool = (== tmp%7#0 tmp%9#0)
        (assert tmp%10#0)
        return 1u

subroutine test_cases.gvn.phi_congruence.test_redundant_phi(a: uint64, b: uint64) -> uint64:
    block@0: // L23
        let tmp%0#0: uint64 = (| a#0 b#0)
        let val1#0: uint64 = tmp%0#0
        let tmp%1#0: uint64 = (| b#0 a#0)
        let val2#0: uint64 = tmp%1#0
        let tmp%2#0: bool = (> a#0 b#0)
        goto tmp%2#0 ? block@1 : block@2
    block@1: // if_body_L43
        let tmp%3#0: bytes = (itob a#0)
        (log tmp%3#0)
        let result#0: uint64 = val1#0
        goto block@3
    block@2: // else_body_L46
        let tmp%4#0: bytes = (itob b#0)
        (log tmp%4#0)
        let result#0: uint64 = val2#0
        goto block@3
    block@3: // after_if_else_L42
        return result#0

subroutine test_cases.gvn.phi_congruence.test_cross_assignment(n: uint64) -> uint64:
    block@0: // L51
        let x#0: uint64 = n#0
        let y#0: uint64 = n#0
        (assert 1u) // Step cannot be zero
        let value_internal%0#0: uint64 = 0u
        goto block@1
    block@1: // for_header_L63
        let continue_looping%0#0: bool = (< value_internal%0#0 10u)
        goto continue_looping%0#0 ? block@2 : block@4
    block@2: // for_body_L64
        let tmp#0: uint64 = x#0
        let x#0: uint64 = y#0
        let y#0: uint64 = tmp#0
        goto block@3
    block@3: // for_footer_L63
        let value_internal%0#0: uint64 = (+ value_internal%0#0 1u)
        goto block@1
    block@4: // after_for_L63
        let tmp%0#0: uint64 = (+ x#0 y#0)
        return tmp%0#0

subroutine test_cases.gvn.phi_congruence.test_triple_cycle(n: uint64) -> uint64:
    block@0: // L71
        let a#0: uint64 = n#0
        let b#0: uint64 = n#0
        let c#0: uint64 = n#0
        (assert 1u) // Step cannot be zero
        let value_internal%0#0: uint64 = 0u
        goto block@1
    block@1: // for_header_L84
        let continue_looping%0#0: bool = (< value_internal%0#0 5u)
        goto continue_looping%0#0 ? block@2 : block@4
    block@2: // for_body_L85
        let tmp_a#0: uint64 = a#0
        let tmp_b#0: uint64 = b#0
        let a#0: uint64 = c#0
        let b#0: uint64 = tmp_a#0
        let c#0: uint64 = tmp_b#0
        goto block@3
    block@3: // for_footer_L84
        let value_internal%0#0: uint64 = (+ value_internal%0#0 1u)
        goto block@1
    block@4: // after_for_L84
        let tmp%0#0: uint64 = (+ a#0 b#0)
        let tmp%1#0: uint64 = (+ tmp%0#0 c#0)
        return tmp%1#0