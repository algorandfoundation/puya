subroutine test_cases.gvn.partial_redundancy_elimination.test(a: uint64, b: uint64, cond: bool) -> uint64:
    block@0: // L16
        goto cond#0 ? block@1 : block@2
    block@1: // if_body_L19
        let result#0: uint64 = (+ a#0 b#0)
        let tmp%2#0: bytes = (itob result#0)
        let tmp%3#0: bytes = (concat "cond: " tmp%2#0)
        (log tmp%3#0)
        goto block@3
    block@2: // else_body_L22
        let result#0: uint64 = (+ a#0 b#0)
        let tmp%6#0: bytes = (itob result#0)
        let tmp%7#0: bytes = (concat "!cond: " tmp%6#0)
        (log tmp%7#0)
        goto block@3
    block@3: // after_if_else_L18
        let tmp%8#0: uint64 = (+ b#0 a#0)
        let tmp%9#0: bool = (== result#0 tmp%8#0)
        (assert tmp%9#0)
        return result#0