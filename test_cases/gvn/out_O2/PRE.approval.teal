#pragma version 11
#pragma typetrack false

// test_cases.gvn.partial_redundancy_elimination.PRE.approval_program() -> uint64:
main:
    intcblock 1 0
    intc_0 // 1
    intc_1 // 0

main_for_body@1:
    pushints 3 5
    uncover 3
    callsub test
    pushint 8
    ==
    assert
    bnz main_after_for@4
    intc_1 // 0
    intc_0 // 1
    b main_for_body@1

main_after_for@4:
    intc_0 // 1
    return


// test_cases.gvn.partial_redundancy_elimination.test(a: uint64, b: uint64, cond: uint64) -> uint64:
test:
    proto 3 1
    frame_dig -1
    bz test_else_body@2
    frame_dig -3
    frame_dig -2
    +
    dup
    itob
    pushbytes "cond: "
    swap
    concat
    log
    retsub

test_else_body@2:
    frame_dig -3
    frame_dig -2
    +
    dup
    itob
    pushbytes "!cond: "
    swap
    concat
    log
    retsub
