        let (tuple_param.0#0: bool, tuple_param.1#0: uint64, tuple_param.2#0: bytes, tuple_param.3#0: biguint, tuple_param.4#0: string) = decode_bytes<(bool,uint64,bytes,biguint,string,)>(value#5)
