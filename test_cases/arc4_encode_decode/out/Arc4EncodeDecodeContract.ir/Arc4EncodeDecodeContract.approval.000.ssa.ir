subroutine test_cases.arc4_encode_decode.contract.test_native_struct() -> void:
    block@0: // L57
        let tmp%0#0: Encoded(uint64,bool1) = bytes_encode<(uint64,bool1)>(1u, 1u)
        let original#0: Encoded(uint64,bool1) = tmp%0#0
        let encoded#0: bytes = original#0
        let tmp%1#0: bool = (== encoded#0 0x000000000000000180)
        (assert tmp%1#0)
        let as_Encoded(uint64,bool1)%0#0: Encoded(uint64,bool1) = encoded#0
        let decoded#0: Encoded(uint64,bool1) = as_Encoded(uint64,bool1)%0#0
        let tmp%2#0: bool = (== decoded#0 original#0)
        (assert tmp%2#0)
        return 

