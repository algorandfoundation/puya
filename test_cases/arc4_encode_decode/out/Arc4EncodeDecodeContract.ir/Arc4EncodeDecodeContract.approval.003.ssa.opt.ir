main test_cases.arc4_encode_decode.contract.Arc4EncodeDecodeContract.approval_program:
    block@0: // L34
        let original#0: Encoded(uint64,bool1) = bytes_encode<(uint64,bool1)>(1u, 1u)
        let tmp%1#0: bool = (== original#0 0x000000000000000180)
        (assert tmp%1#0)
        let encoded#4: bytes = bytes_encode<(len+utf8[])>("hello")
        let encoded#2: bytes = bytes_encode<uint64>(42u)
        let tmp%1#2: bool = (== encoded#2 0x000000000000002a)
        (assert tmp%1#2)
        let encoded#3: bytes = bytes_encode<uint512>(42b)
        let decoded#3: biguint = decode_bytes<biguint>(encoded#3)
        let tmp%2#3: bool = (b== decoded#3 42b)
        (assert tmp%2#3)
        let tmp%1#4: bool = (== encoded#4 0x000568656c6c6f)
        (assert tmp%1#4)
        let encoded#5: bytes = bytes_encode<(len+uint8[])>(0x010203)
        let tmp%1#5: bool = (== encoded#5 0x0003010203)
        (assert tmp%1#5)
        let encoded_true#0: bytes = bytes_encode<bool8>(1u)
        let tmp%1#6: bool = (== encoded_true#0 0x80)
        (assert tmp%1#6)
        let encoded_false#0: bytes = bytes_encode<bool8>(0u)
        let tmp%4#0: bool = (== encoded_false#0 0x00)
        (assert tmp%4#0)
        let encoded#8: bytes = bytes_encode<uint64>(123u)
        let tmp%1#9: bool = (== encoded#8 0x000000000000007b)
        (assert tmp%1#9)
        let encoded#11: bytes = bytes_encode<(uint64,uint64)>(1u, 2u)
        let tmp%1#12: bool = (== encoded#11 0x00000000000000010000000000000002)
        (assert tmp%1#12)
        return 1u