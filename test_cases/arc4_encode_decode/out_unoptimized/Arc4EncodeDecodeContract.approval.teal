test_tuple_block@0:
    // arc4_encode_decode/contract.py:171
    // value = (UInt64(1), UInt64(2))
    intc_1 // 1
    // arc4_encode_decode/contract.py:172
    // encoded = arc4.encode(value)
    itob
    bytec_2 // 0x
    uncover 1
    concat
    // arc4_encode_decode/contract.py:171
    // value = (UInt64(1), UInt64(2))
    intc_3 // 2
    // arc4_encode_decode/contract.py:172
    // encoded = arc4.encode(value)
    itob
    concat
    // arc4_encode_decode/contract.py:173
    // assert encoded == Bytes.from_hex("00000000000000010000000000000002")
    dup
    pushbytes 0x00000000000000010000000000000002
    ==
    assert
    // arc4_encode_decode/contract.py:174
    // decoded = arc4.decode(tuple[UInt64, UInt64], encoded)
    dup
    len
    pushint 16
    ==
    assert // invalid number of bytes for tuple<uint64,uint64>
    dup
    intc_0 // 0
    intc_2 // 8
    extract3
    btoi
    cover 1
    intc_2 // 8
    intc_2 // 8
    extract3
    btoi
    cover 1
    // arc4_encode_decode/contract.py:171
    // value = (UInt64(1), UInt64(2))
    intc_1 // 1
    // arc4_encode_decode/contract.py:175
    // assert decoded == value
    ==
    cover 1
    // arc4_encode_decode/contract.py:171
    // value = (UInt64(1), UInt64(2))
    intc_3 // 2
    // arc4_encode_decode/contract.py:175
    // assert decoded == value
    ==
    &&
    assert
    retsub


