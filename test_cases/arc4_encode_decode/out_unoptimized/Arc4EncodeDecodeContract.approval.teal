    assert // invalid number of bytes for uint64
    btoi
    // arc4_encode_decode/contract.py:76
    // value = UInt64(42)
    pushint 42
    // arc4_encode_decode/contract.py:81
    // assert decoded == value
    ==
    assert
    retsub


