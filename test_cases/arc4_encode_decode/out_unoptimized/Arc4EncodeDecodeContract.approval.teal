// test_cases.arc4_encode_decode.contract.test_native_struct() -> void:
test_native_struct:
    b test_native_struct_block@0

test_native_struct_block@0:
    // arc4_encode_decode/contract.py:59
    // original = NativeStruct(a=UInt64(1), b=True)
    intc_1 // 1
    itob
    bytec_2 // 0x
    uncover 1
    concat
    bytec_3 // 0x00
    intc_0 // 0
    intc_1 // 1
    setbit
    concat
    // arc4_encode_decode/contract.py:60
    // encoded = arc4.encode(original)
    dupn 2
    // arc4_encode_decode/contract.py:61
    // assert encoded == Bytes.from_hex("000000000000000180")
    pushbytes 0x000000000000000180
    ==
    assert
    // arc4_encode_decode/contract.py:62
    // decoded = arc4.decode(NativeStruct, encoded)
    dup
    len
    pushint 9
    ==
    assert // invalid number of bytes for test_cases.arc4_encode_decode.contract.NativeStruct
    // arc4_encode_decode/contract.py:63
    // assert decoded == original
    ==
    assert
    retsub


// test_cases.arc4_encode_decode.contract.test_arc4_struct() -> void:
test_arc4_struct:
    b test_arc4_struct_block@0

test_arc4_struct_block@0:
    // arc4_encode_decode/contract.py:68
    // original = Arc4Struct(x=arc4.UInt64(42), y=arc4.String("hello"))
    bytec_1 // "hello"
    len
    itob
    extract 6 2
    bytec_1 // "hello"
    concat
    bytec_2 // 0x
    bytec_0 // 0x000000000000002a
    concat
    pushint 10
    itob
    extract 6 2
    concat
    uncover 1
    concat
    // arc4_encode_decode/contract.py:69
    // encoded = arc4.encode(original)
    dupn 2
    // arc4_encode_decode/contract.py:70
    // decoded = arc4.decode(Arc4Struct, encoded)
    len
    cover 1
    dup
    intc_2 // 8
    extract_uint16 // on error: invalid tuple encoding
    dup
    pushint 10
    ==
    assert // invalid tail pointer at index 1 of (uint64,(len+utf8[]))
    dig 1
    uncover 1
    uncover 3
    substring3
    intc_0 // 0
    extract_uint16 // on error: invalid array length header
    intc_1 // 1
    *
    intc_3 // 2
    +
    pushint 10
    +
    dig 1
    len
    ==
    assert // invalid number of bytes for test_cases.arc4_encode_decode.contract.Arc4Struct
    // arc4_encode_decode/contract.py:71
    // assert decoded == original
    ==
    assert
    retsub


