        subroutine test_cases.compile.factory.HelloFactory.test_logicsig() -> bytes:
            block@0: // L86
                let tmp%0#0: uint64 = (len addr U3ZXEUNFRSUDPPNFC6U7OBYO4S4AUOEP4RDBI23L2Q5TX3K5LTSVWQOKFM)
