                let check%0#0: bool = tmp%1#0
                (assert check%0#0) // Address length is 32 bytes
                return addr U3ZXEUNFRSUDPPNFC6U7OBYO4S4AUOEP4RDBI23L2Q5TX3K5LTSVWQOKFM
        
