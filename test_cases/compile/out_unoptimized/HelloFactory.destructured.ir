contract test_cases.compile.factory.HelloFactory:
    program approval:
        subroutine test_cases.compile.factory.HelloFactory.approval_program() -> bool:
            block@0: // L84
                let tmp%0#0: bool = (txn NumAppArgs)
                goto tmp%0#0 ? block@1 : block@13
            block@1: // abi_routing_L84
                let tmp%1#0: bytes = (txna ApplicationArgs 0)
                switch tmp%1#0 {method "test_logicsig()address" => block@2, method "test_get_program()void" => block@3, method "test_get_program_tmpl()void" => block@4, method "test_get_program_prfx()void" => block@5, method "test_get_program_large()void" => block@6, method "test_abi_call()void" => block@7, method "test_abi_call_tmpl()void" => block@8, method "test_abi_call_prfx()void" => block@9, method "test_abi_call_large()void" => block@10, * => block@11}
            block@2: // test_logicsig_route_L86
                let tmp%2#0: uint64 = (txn OnCompletion)
                let tmp%3#0: bool = (== tmp%2#0 NoOp)
                (assert tmp%3#0) // OnCompletion is NoOp
                let tmp%4#0: bool = (txn ApplicationID)
                (assert tmp%4#0) // is not creating
                let tmp%5#0: bytes = test_cases.compile.factory.HelloFactory.test_logicsig()
                let tmp%6#0: bytes = (concat 0x151f7c75 tmp%5#0)
