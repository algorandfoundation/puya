contract test_cases.compile.apps.LargeProgram:
    program approval:
        subroutine test_cases.compile.apps.LargeProgram.approval_program() -> bool:
            block@0: // L23
                let tmp%0#0: bytes = (txna ApplicationArgs 0)
                switch tmp%0#0 {method "get_big_bytes_length()uint64" => block@1, method "create()void" => block@2, method "delete()void" => block@3, * => block@4}
            block@1: // get_big_bytes_length_route_L25
                let tmp%1#0: uint64 = (txn OnCompletion)
                let tmp%2#0: bool = (== tmp%1#0 NoOp)
                (assert tmp%2#0) // OnCompletion is NoOp
                let tmp%3#0: bool = (txn ApplicationID)
                (assert tmp%3#0) // is not creating
                let tmp%4#0: uint64 = test_cases.compile.apps.LargeProgram.get_big_bytes_length()
                let val_as_bytes%0#0: bytes = (itob tmp%4#0)
                let tmp%5#0: bytes = (concat 0x151f7c75 val_as_bytes%0#0)
                (log tmp%5#0)
                return 1u
            block@2: // create_route_L29
                let tmp%6#0: uint64 = (txn OnCompletion)
                let tmp%7#0: bool = (== tmp%6#0 NoOp)
                (assert tmp%7#0) // OnCompletion is NoOp
                let tmp%8#0: bool = (txn ApplicationID)
                let tmp%9#0: bool = (! tmp%8#0)
                (assert tmp%9#0) // is creating
                test_cases.compile.apps.LargeProgram.create()
                return 1u
            block@3: // delete_route_L33
                let tmp%10#0: uint64 = (txn OnCompletion)
                let tmp%11#0: bool = (== tmp%10#0 DeleteApplication)
                (assert tmp%11#0) // OnCompletion is DeleteApplication
                let tmp%12#0: bool = (txn ApplicationID)
                (assert tmp%12#0) // is not creating
                test_cases.compile.apps.LargeProgram.delete()
                return 1u
            block@4: // switch_case_default_L23
                goto block@5
            block@5: // switch_case_next_L23
                fail // reject transaction
        
        subroutine test_cases.compile.apps.LargeProgram.get_big_bytes_length() -> uint64:
            block@0: // L25
                let tmp%0#0: bytes = test_cases.compile.apps.get_big_bytes()
                let tmp%1#0: uint64 = (len tmp%0#0)
                return tmp%1#0
        
        subroutine test_cases.compile.apps.get_big_bytes() -> bytes:
            block@0: // L38
                return 
        
        subroutine test_cases.compile.apps.LargeProgram.create() -> void:
            block@0: // L29
                return 
        
        subroutine test_cases.compile.apps.LargeProgram.delete() -> void:
            block@0: // L33
                return 
    
    program clear-state:
        subroutine test_cases.compile.apps.LargeProgram.clear_state_program() -> bool:
            block@0: // L23
                return 1u