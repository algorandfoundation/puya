#pragma version 10

test_cases.compile.factory.HelloFactory.approval_program:
    txn NumAppArgs
    bz main_bare_routing@13
    method "test_logicsig()address"
    method "test_get_program()void"
    method "test_get_program_tmpl()void"
    method "test_get_program_prfx()void"
    method "test_get_program_large()void"
    method "test_abi_call()void"
    method "test_abi_call_tmpl()void"
    method "test_abi_call_prfx()void"
    method "test_abi_call_large()void"
    txna ApplicationArgs 0
    match main_test_logicsig_route@2 main_test_get_program_route@3 main_test_get_program_tmpl_route@4 main_test_get_program_prfx_route@5 main_test_get_program_large_route@6 main_test_abi_call_route@7 main_test_abi_call_tmpl_route@8 main_test_abi_call_prfx_route@9 main_test_abi_call_large_route@10
    err // reject transaction

main_test_logicsig_route@2:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_logicsig
    byte 0x151f7c75
    swap
    concat
    log
    int 1
    return

main_test_get_program_route@3:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_get_program
    int 1
    return

main_test_get_program_tmpl_route@4:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_get_program_tmpl
    int 1
    return

main_test_get_program_prfx_route@5:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_get_program_prfx
    int 1
    return

main_test_get_program_large_route@6:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_get_program_large
    int 1
    return

main_test_abi_call_route@7:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_abi_call
    int 1
    return

main_test_abi_call_tmpl_route@8:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_abi_call_tmpl
    int 1
    return

main_test_abi_call_prfx_route@9:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_abi_call_prfx
    int 1
    return

main_test_abi_call_large_route@10:
    txn OnCompletion
    !
    assert // OnCompletion is NoOp
    txn ApplicationID
    assert // is not creating
    callsub test_abi_call_large
    int 1
    return

main_bare_routing@13:
    txn OnCompletion
    !
    assert // reject transaction
    txn ApplicationID
    !
    assert // is creating
    int 1
    return


// test_cases.compile.factory.HelloFactory.test_logicsig() -> bytes:
test_logicsig:
    proto 0 1
    addr U3ZXEUNFRSUDPPNFC6U7OBYO4S4AUOEP4RDBI23L2Q5TX3K5LTSVWQOKFM
    retsub


// test_cases.compile.factory.HelloFactory.test_get_program() -> void:
test_get_program:
    proto 0 0
    itxn_begin
    int 1
    itxn_field GlobalNumByteSlice
    byte base64 CoEBQw==
    itxn_field ClearStateProgramPages
    byte base64 CiABASYBCGdyZWV0aW5nMRhAAAOIAH2CAwQg3zpUBCQ3jTwE0KKCADYaAI4DAAEAFAAiADEZFEQxGBRENhoBVwIAiAAzIkMxGYEFEkQxGESIAC0iQzEZFEQxGEQ2GgFXAgCIAB9JFRZXBgJMUIAEFR98dUxQsCJDigEAKIv/Z4mKAACJigEBgQAoZUSAASBQi/9QiYoAACiAAGeJ
    itxn_field ApprovalProgramPages
    method "create(string)void"
    itxn_field ApplicationArgs
    byte 0x000568656c6c6f
    itxn_field ApplicationArgs
    int appl
    itxn_field TypeEnum
    int 0
    itxn_field Fee
    itxn_submit
    itxn CreatedApplicationID
    itxn_begin
    dup
    itxn_field ApplicationID
    method "greet(string)string"
    itxn_field ApplicationArgs
    byte 0x0005776f726c64
    itxn_field ApplicationArgs
    int appl
    itxn_field TypeEnum
    int 0
    itxn_field Fee
    itxn_submit
    itxn LastLog
    dup
    extract 4 0
    swap
    extract 0 4
    byte 0x151f7c75
    ==
    assert // ARC4 prefix is valid
    itxn_begin
    int DeleteApplication
    itxn_field OnCompletion
    method "delete()void"
    itxn_field ApplicationArgs
    swap
    itxn_field ApplicationID
    int appl
    itxn_field TypeEnum
    int 0
    itxn_field Fee
    itxn_submit
    byte 0x000b68656c6c6f20776f726c64
    ==
    assert
    retsub


