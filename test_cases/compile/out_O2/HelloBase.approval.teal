#pragma version 10
#pragma typetrack false

// test_cases.compile.apps.HelloBase.__algopy_entrypoint_with_init() -> uint64:
main:
    intcblock 0 1
    bytecblock "greeting"
    intc_1 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    bytec_0 // "greeting"
    pushbytes ""
    app_global_put

main_after_if_else@2:
    txn NumAppArgs
    bz main_bare_routing@9
    txn ApplicationID
    !
    intc_1 // 1
    txn OnCompletion
    shl
    +
    pushint 10 // 10
    intc_0 // 0
    uncover 2
    match main_switch_case_0@5 main_switch_case_1@7
    err

main_switch_case_1@7:
    pushbytes 0xd0a28200 // method "greet(string)string"
    txna ApplicationArgs 0
    match main_greet_route@8
    err

main_greet_route@8:
    txna ApplicationArgs 1
    extract 2 0
    intc_0 // 0
    bytec_0 // "greeting"
    app_global_get_ex
    assert // check self.greeting exists
    pushbytes " "
    concat
    swap
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    return

main_switch_case_0@5:
    pushbytes 0x24378d3c // method "delete()void"
    txna ApplicationArgs 0
    match main_delete_route@6
    err

main_delete_route@6:
    return

main_bare_routing@9:
    pushint 4 // 4
    intc_0 // 0
    txn OnCompletion
    match main_update@10 main___algopy_default_create@11
    err

main___algopy_default_create@11:
    txn ApplicationID
    !
    assert // can only call when creating
    return

main_update@10:
    txn ApplicationID
    assert // can only call when not creating
    return
