#pragma version 10
#pragma typetrack false

// test_cases.compile.apps.Hello.__algopy_entrypoint_with_init() -> uint64:
main:
    intcblock 1 0
    bytecblock "greeting"
    intc_0 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    bytec_0 // "greeting"
    pushbytes ""
    app_global_put

main_after_if_else@2:
    txn NumAppArgs
    bz main_bare_routing@11
    txn ApplicationID
    !
    txn OnCompletion
    intc_0 // 1
    shl
    +
    intc_0 // 1
    pushint 10 // 10
    intc_1 // 0
    uncover 3
    match main_switch_case_0@5 main_switch_case_1@7 main_switch_case_2@9
    err

main_switch_case_2@9:
    pushbytes 0xd0a28200 // method "greet(string)string"
    txna ApplicationArgs 0
    match main_greet_route@10
    err

main_greet_route@10:
    txna ApplicationArgs 1
    extract 2 0
    intc_1 // 0
    bytec_0 // "greeting"
    app_global_get_ex
    assert // check self.greeting exists
    pushbytes " "
    concat
    swap
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    return

main_switch_case_1@7:
    pushbytes 0x24378d3c // method "delete()void"
    txna ApplicationArgs 0
    match main_delete_route@8
    err

main_delete_route@8:
    return

main_switch_case_0@5:
    pushbytes 0x20df3a54 // method "create(string)void"
    txna ApplicationArgs 0
    match main_create_route@6
    err

main_create_route@6:
    txna ApplicationArgs 1
    extract 2 0
    bytec_0 // "greeting"
    swap
    app_global_put
    return

main_bare_routing@11:
    pushint 4 // 4
    txn OnCompletion
    match main_update@12
    err

main_update@12:
    txn ApplicationID
    assert // can only call when not creating
    return
