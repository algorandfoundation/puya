#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@13
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    pushints 0 10 // 0, 10
    uncover 2
    match main_switch_case_0@3 main_switch_case_1@7
    err

main_switch_case_1@7:
    pushbytes 0x24378d3c // method "delete()void"
    txna ApplicationArgs 0
    match main_delete_route@8
    err

main_delete_route@8:
    return

main_switch_case_0@3:
    pushbytes 0xf5e4fd4d // method "get_big_bytes_length()uint64"
    txna ApplicationArgs 0
    match main_get_big_bytes_length_route@4
    err

main_get_big_bytes_length_route@4:
    pushbytes 0x151f7c750000000000001000
    log
    return

main_bare_routing@13:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
