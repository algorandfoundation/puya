#pragma version 10
#pragma typetrack false

// test_cases.compile.apps.HelloPrfx.__algopy_entrypoint_with_init() -> uint64:
main:
    bytecblock "greeting" PRFX_GREETING
    pushint 1 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    bytec_0 // "greeting"
    bytec_1 // PRFX_GREETING
    app_global_put

main_after_if_else@2:
    txn NumAppArgs
    bz main_bare_routing@10
    txn OnCompletion
    bnz main_other_routes@7
    txn ApplicationID
    assert // can only call when not creating
    pushbytes 0xd0a28200 // method "greet(string)string"
    txna ApplicationArgs 0
    match main_greet_route@6
    err

main_greet_route@6:
    txna ApplicationArgs 1
    extract 2 0
    pushint 0 // 0
    bytec_0 // "greeting"
    app_global_get_ex
    assert // check self.greeting exists
    pushbytes " "
    concat
    swap
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    return

main_other_routes@7:
    pushbytess 0x4c5c61ba 0x24378d3c // method "create()void", method "delete()void"
    txna ApplicationArgs 0
    match main_create_route@8 main_delete_route@9
    err

main_delete_route@9:
    txn OnCompletion
    pushint 5 // DeleteApplication
    ==
    assert // OnCompletion is not DeleteApplication
    txn ApplicationID
    assert // can only call when not creating
    return

main_create_route@8:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    !
    assert // can only call when creating
    return

main_bare_routing@10:
    pushint 4 // 4
    txn OnCompletion
    match main_update@11
    err

main_update@11:
    txn ApplicationID
    assert // can only call when not creating
    return
