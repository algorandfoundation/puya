#pragma version 10
#pragma typetrack false

// test_cases.compile.apps.HelloOtherConstants.__algopy_entrypoint_with_init() -> uint64:
main:
    intcblock 1 0
    bytecblock "greeting" "num" "address" "method" TMPL_GREETING TMPL_NUM TMPL_ACCOUNT TMPL_METHOD
    intc_0 // 1
    txn ApplicationID
    bnz main_after_if_else@2
    bytec_0 // "greeting"
    bytec 4 // TMPL_GREETING
    app_global_put
    bytec_1 // "num"
    bytec 5 // TMPL_NUM
    app_global_put
    bytec_2 // "address"
    bytec 6 // TMPL_ACCOUNT
    app_global_put
    bytec_3 // "method"
    bytec 7 // TMPL_METHOD
    app_global_put

main_after_if_else@2:
    txn ApplicationID
    !
    txn OnCompletion
    intc_0 // 1
    shl
    +
    intc_0 // 1
    pushint 10 // 10
    intc_1 // 0
    uncover 3
    match main_switch_case_0@4 main_switch_case_1@6 main_switch_case_2@8
    err

main_switch_case_2@8:
    pushbytes 0x5b0c2375 // method "greet(string)byte[]"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_greet_route@9
    err

main_greet_route@9:
    txna ApplicationArgs 1
    extract 2 0
    intc_1 // 0
    bytec_1 // "num"
    app_global_get_ex
    assert // check self.num exists
    pushbytes 0x30
    b+
    dup
    len
    intc_0 // 1
    -
    intc_0 // 1
    extract3
    intc_1 // 0
    bytec_0 // "greeting"
    app_global_get_ex
    assert // check self.greeting exists
    pushbytes 0x20
    concat
    uncover 2
    concat
    swap
    concat
    intc_1 // 0
    bytec_2 // "address"
    app_global_get_ex
    assert // check self.address exists
    concat
    intc_1 // 0
    bytec_3 // "method"
    app_global_get_ex
    assert // check self.method exists
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    return

main_switch_case_1@6:
    pushbytes 0x24378d3c // method "delete()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_delete_route@7
    err

main_delete_route@7:
    return

main_switch_case_0@4:
    pushbytes 0xd9285a74 // method "create()uint64"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_create_route@5
    err

main_create_route@5:
    pushbytes 0x151f7c750000000000000001
    log
    return
