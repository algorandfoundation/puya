main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@12
    block@2: // abi_routing_L37
        let tmp%2#0: uint64 = (txn OnCompletion)
        goto tmp%2#0 ? block@7 : block@3
    block@3: // simple_routes_L37
        let tmp%4#0: uint64 = (txn ApplicationID)
        (assert tmp%4#0) // can only call when not creating
        let tmp%6#0: bytes = (txna ApplicationArgs 0)
        switch tmp%6#0 {method "get_big_bytes_length()uint64" => block@4, * => block@16}
    block@4: // get_big_bytes_length_route_L38
        test_cases.compile.apps.LargeProgram.get_big_bytes_length[routing]()
        exit 1u
    block@7: // other_routes_L37
        let tmp%7#0: bytes = (txna ApplicationArgs 0)
        switch tmp%7#0 {method "delete()void" => block@8, * => block@16}
    block@8: // delete_route_L42
        let tmp%8#0: uint64 = (txn OnCompletion)
        let tmp%9#0: bool = (== tmp%8#0 DeleteApplication)
        (assert tmp%9#0) // OnCompletion is not DeleteApplication
        let tmp%10#0: uint64 = (txn ApplicationID)
        (assert tmp%10#0) // can only call when not creating
        exit 1u
    block@12: // bare_routing_L37
        let tmp%12#0: uint64 = (txn OnCompletion)
        let not%tmp%12#0: bool = (! tmp%12#0)
        (assert not%tmp%12#0)
        let tmp%13#0: uint64 = (txn ApplicationID)
        let tmp%14#0: bool = (! tmp%13#0)
        (assert tmp%14#0) // can only call when creating
        exit 1u
    block@16: // after_if_else_L37
        fail

subroutine test_cases.compile.apps.LargeProgram.get_big_bytes_length[routing]() -> void:
    block@0: // L37
        let tmp%1#1: uint64 = 4096u
        let tmp%1#0: Encoded(uint64) = bytes_encode<uint64>(4096u)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
        (log tmp%2#0)
        return 