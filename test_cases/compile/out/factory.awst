logicsig always_approve_sig
{
  return true
}

contract HelloBase
{
  globals {
    ['greeting']: string
  }
  
  constructor()
  {
    GlobalState['greeting']: string = ''
  }
  
  abimethod delete(): void
  {
  }
  
  abimethod greet(name: string): string
  {
    return GlobalState['greeting'] + ' ' + name
  }
}

contract LargeProgram
{
  abimethod get_big_bytes_length(): uint64
  {
    return len(test_cases.compile.factory::get_big_bytes())
  }
  
  abimethod create(): void
  {
  }
  
  abimethod delete(): void
  {
  }
}

subroutine get_big_bytes(): bytes
{
  return hex<"">
}

contract Hello extends (test_cases.compile.factory::HelloBase)
{
  abimethod create(greeting: string): void
  {
    GlobalState['greeting']: string = greeting
  }
}

contract HelloTmpl extends (test_cases.compile.factory::HelloBase)
{
  constructor()
  {
    GlobalState['greeting']: string = TemplateVar[string](TMPL_GREETING)
  }
  
  abimethod create(): void
  {
  }
}

contract HelloPrfx extends (test_cases.compile.factory::HelloBase)
{
  constructor()
  {
    GlobalState['greeting']: string = TemplateVar[string](PRFX_GREETING)
  }
  
  abimethod create(): void
  {
  }
}

contract HelloFactory
{
  abimethod test_logicsig(): arc4.static_array<arc4.uint8, 32>
  {
    return checked_maybe((reinterpret_cast<arc4.static_array<arc4.uint8, 32>>(SINGLE_EVAL(id=0, source=compiled('test_cases.compile.factory.always_approve_sig', field=account))), 32u == len(SINGLE_EVAL(id=0, source=compiled('test_cases.compile.factory.always_approve_sig', field=account)))))
  }
  
  abimethod test_get_program(): void
  {
    hello_app: application = submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("create(string)void"), reinterpret_cast<bytes>(arc4_encode('hello', arc4.dynamic_array<arc4.uint8>))), ApprovalProgramPages=(compiled('test_cases.compile.factory.Hello', field=approval), compiled('test_cases.compile.factory.Hello', field=approval)), ClearStateProgramPages=(compiled('test_cases.compile.factory.Hello', field=clear_state), compiled('test_cases.compile.factory.Hello', field=clear_state)), GlobalNumByteSlice=1u)).CreatedApplicationID
    txn: inner_transaction_appl = submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("greet(string)string"), reinterpret_cast<bytes>(arc4_encode('world', arc4.dynamic_array<arc4.uint8>))), ApplicationID=hello_app))
    result: arc4.dynamic_array<arc4.uint8> = checked_maybe((extract<4, 0>(SINGLE_EVAL(id=1, source=txn.LastLog)), extract<0, 4>(SINGLE_EVAL(id=1, source=txn.LastLog)) == hex<"151F7C75">))
    submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationID=hello_app, ApplicationArgs=(Method("delete()void")), OnCompletion=DeleteApplication))
    assert(result == arc4_encode('hello world', arc4.dynamic_array<arc4.uint8>))
  }
  
  abimethod test_get_program_tmpl(): void
  {
