  abimethod test_abi_call_large(): void
  {
    app: application = submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("create()void")), ApprovalProgramPages=(compiled_contract('test_cases.compile.apps.LargeProgram')[0], compiled_contract('test_cases.compile.apps.LargeProgram')[1]), ClearStateProgramPages=(compiled_contract('test_cases.compile.apps.LargeProgram')[2], compiled_contract('test_cases.compile.apps.LargeProgram')[3]), GlobalNumUint=compiled_contract('test_cases.compile.apps.LargeProgram')[5], GlobalNumByteSlice=compiled_contract('test_cases.compile.apps.LargeProgram')[6], LocalNumUint=compiled_contract('test_cases.compile.apps.LargeProgram')[7], LocalNumByteSlice=compiled_contract('test_cases.compile.apps.LargeProgram')[8], ExtraProgramPages=compiled_contract('test_cases.compile.apps.LargeProgram')[4])).CreatedApplicationID
    (result, _txn): tuple<uint64,inner_transaction_appl> = (arc4_decode(checked_maybe((extract<4, 0>(SINGLE_EVAL(id=10, source=SINGLE_EVAL(id=11, source=submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("get_big_bytes_length()uint64")), ApplicationID=app))).LastLog)), extract<0, 4>(SINGLE_EVAL(id=10, source=SINGLE_EVAL(id=11, source=submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("get_big_bytes_length()uint64")), ApplicationID=app))).LastLog)) == hex<"151F7C75">)), uint64), SINGLE_EVAL(id=11, source=submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("get_big_bytes_length()uint64")), ApplicationID=app))))
    assert(result == 4096u)
    submit_txn(create_inner_transaction(Fee=0u, TypeEnum=appl, ApplicationArgs=(Method("delete()void")), ApplicationID=app, OnCompletion=DeleteApplication))
