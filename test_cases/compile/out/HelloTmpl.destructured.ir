contract test_cases.compile.factory.HelloTmpl:
    program approval:
        subroutine test_cases.compile.factory.HelloTmpl.approval_program() -> bool:
            block@0: // L64
                let app_id%0#0: uint64 = (txn ApplicationID)
                goto app_id%0#0 ? block@2 : block@1
            block@1: // on_create_L66
                test_cases.compile.factory.HelloTmpl.__init__()
                goto block@2
            block@2: // entrypoint_L66
                let tmp%0#0: bytes = (txna ApplicationArgs 0)
                switch tmp%0#0 {method "create()void" => block@3, method "delete()void" => block@4, method "greet(string)string" => block@5, * => fail // reject transaction}
            block@3: // create_route_L69
                let tmp%1#0: uint64 = (txn OnCompletion)
                let tmp%2#0: bool = (! tmp%1#0)
                (assert tmp%2#0) // OnCompletion is NoOp
                let tmp%3#0: bool = (txn ApplicationID)
                let tmp%4#0: bool = (! tmp%3#0)
                (assert tmp%4#0) // is creating
                test_cases.compile.factory.HelloTmpl.create()
                return 1u
            block@4: // delete_route_L28
                let tmp%5#0: uint64 = (txn OnCompletion)
                let tmp%6#0: bool = (== tmp%5#0 DeleteApplication)
                (assert tmp%6#0) // OnCompletion is DeleteApplication
                let tmp%7#0: bool = (txn ApplicationID)
                (assert tmp%7#0) // is not creating
                test_cases.compile.factory.HelloBase.delete()
                return 1u
            block@5: // greet_route_L32
                let tmp%8#0: uint64 = (txn OnCompletion)
                let tmp%9#0: bool = (! tmp%8#0)
                (assert tmp%9#0) // OnCompletion is NoOp
                let tmp%10#0: bool = (txn ApplicationID)
                (assert tmp%10#0) // is not creating
                let tmp%11#0: bytes = (txna ApplicationArgs 1)
                let tmp%12#0: bytes = ((extract 2 0) tmp%11#0)
                let tmp%13#0: bytes = test_cases.compile.factory.HelloBase.greet(tmp%12#0)
                let length%0#0: uint64 = (len tmp%13#0)
                let as_bytes%0#0: bytes = (itob length%0#0)
                let length_uint16%0#0: bytes = ((extract 6 2) as_bytes%0#0)
                let encoded_value%0#0: bytes = (concat length_uint16%0#0 tmp%13#0)
                let tmp%14#0: bytes = (concat 0x151f7c75 encoded_value%0#0)
                (log tmp%14#0)
                return 1u
        
        subroutine test_cases.compile.factory.HelloTmpl.create() -> void:
            block@0: // L69
                return 
        
        subroutine test_cases.compile.factory.HelloBase.delete() -> void:
            block@0: // L28
                return 
        
        subroutine test_cases.compile.factory.HelloBase.greet(name: bytes) -> bytes:
            block@0: // L32
                let (maybe_value%0#0: bytes, maybe_exists%0#0: bool) = (app_global_get_ex 0u "greeting")
                (assert maybe_exists%0#0) // check self.greeting exists
                let tmp%0#0: bytes = (concat maybe_value%0#0 " ")
                let tmp%1#0: bytes = (concat tmp%0#0 name#0)
                return tmp%1#0
        
        subroutine test_cases.compile.factory.HelloTmpl.__init__() -> void:
            block@0: // L66
                (app_global_put "greeting" TemplateVar[bytes](TMPL_GREETING))
                return 
    
    program clear-state:
        subroutine test_cases.compile.factory.HelloTmpl.clear_state_program() -> bool:
            block@0: // L64
                return 1u