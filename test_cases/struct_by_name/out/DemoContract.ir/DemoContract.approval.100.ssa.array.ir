    block@0: // L18
        let aggregate%head%0#0: bytes = (concat 0x 0x01)
        let aggregate%head%1#0: bytes = (concat aggregate%head%0#0 0x01)
        let aggregate%as_Encoded(uint8,uint8)%0#0: Encoded(uint8,uint8) = aggregate%head%1#0
