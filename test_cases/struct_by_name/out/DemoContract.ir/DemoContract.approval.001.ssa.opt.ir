subroutine test_cases.struct_by_name.contract.DemoContract.get_one[routing]() -> void:
    block@0: // L18
        let tmp%2#0: Encoded(uint8,uint8) = bytes_encode<(uint8,uint8)>(0x01, 0x01)
        let tmp%3#0: bytes = (concat 0x151f7c75 tmp%2#0)
