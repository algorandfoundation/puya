#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@12
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    !
    assert
    pushbytess 0x3d694b70 0x7fb34e8a 0x8ba7c4c2 0x46dadea3 // method "get_one()(uint8,uint8)", method "get_two()(uint8,uint8)", method "get_three()(uint8,uint8)", method "compare()bool"
    txna ApplicationArgs 0
    match main_get_one_route@4 main_get_one_route@4 main_get_one_route@4 main_compare_route@7
    err

main_compare_route@7:
    pushbytes 0x151f7c7580
    log
    return

main_get_one_route@4:
    pushbytes 0x151f7c750101
    log
    return

main_bare_routing@12:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
