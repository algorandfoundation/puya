#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@9
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    !
    assert
    pushbytes 0xd3479e65 // method "some_value()uint64"
    txna ApplicationArgs 0
    match main_some_value_route@4
    err

main_some_value_route@4:
    global GroupSize
    txn GroupIndex
    pushint 1 // 1
    +
    *
    itob
    pushbytes 0x151f7c75
    swap
    concat
    log
    return

main_bare_routing@9:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
