        (assert gtxn_type_matches%0#0) // transaction type is appl
        let tmp%1#0: uint64 = (txn GroupIndex)
        let txn2#0: uint64 = (- tmp%1#0 2u)
        let gtxn_type%1#0: uint64 = ((gtxns TypeEnum) txn2#0)
        let gtxn_type_matches%1#0: bool = (== gtxn_type%1#0 appl)
        (assert gtxn_type_matches%1#0) // transaction type is appl
        let tmp%2#0: uint64 = (txn GroupIndex)
        let txn3#0: uint64 = (- tmp%2#0 1u)
        let gtxn_type%2#0: uint64 = ((gtxns TypeEnum) txn3#0)
        let gtxn_type_matches%2#0: bool = (== gtxn_type%2#0 appl)
        (assert gtxn_type_matches%2#0) // transaction type is appl
        let index#0: uint64 = 0u
        let app#1: uint64 = txn1#0
        goto block@2
    block@2: // for_body_L119
        let tmp%0#0: uint64 = ((gtxns GroupIndex) app#1)
        let tmp%1#1: bool = (== tmp%0#0 index#0)
        (assert tmp%1#1)
        goto_nth [block@4, block@5][index#0] else goto block@6
    block@4: // for_header_1_L118
        let index#0: uint64 = 1u
        let app#1: uint64 = txn2#0
        goto block@2
    block@5: // for_header_2_L118
        let index#0: uint64 = 2u
        let app#1: uint64 = txn3#0
        goto block@2
    block@6: // after_for_L118
        return 

