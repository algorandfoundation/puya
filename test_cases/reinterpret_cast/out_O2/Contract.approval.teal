#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@10
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    !
    assert
    pushbytess 0x4034b731 0x7e9fd4cf // method "bytes_to_bool()bool", method "test_bytes_to_biguint()void"
    txna ApplicationArgs 0
    match main_bytes_to_bool_route@4 main_test_bytes_to_biguint_route@5
    err

main_test_bytes_to_biguint_route@5:
    pushint 0 // 0
    assert
    return

main_bytes_to_bool_route@4:
    pushbytes 0x151f7c7500
    log
    return

main_bare_routing@10:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
