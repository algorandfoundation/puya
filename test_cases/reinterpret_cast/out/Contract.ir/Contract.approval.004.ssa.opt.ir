main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@7
    block@2: // abi_routing_L4
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: bool = (! tmp%2#0)
        (assert tmp%3#0) // OnCompletion is not NoOp
        let tmp%4#0: uint64 = (txn ApplicationID)
        (assert tmp%4#0) // can only call when not creating
        let tmp%6#0: bytes = (txna ApplicationArgs 0)
        switch tmp%6#0 {method "bytes_to_bool()bool" => block@3, method "test_bytes_to_biguint()void" => block@4, * => block@11}
    block@3: // bytes_to_bool_route_L5
        test_cases.reinterpret_cast.contract.Contract.bytes_to_bool[routing]()
        goto block@11
    block@4: // test_bytes_to_biguint_route_L9
        (assert 0u)
        exit 1u
    block@7: // bare_routing_L4
        let tmp%7#0: uint64 = (txn OnCompletion)
        let not%tmp%7#0: bool = (! tmp%7#0)
        (assert not%tmp%7#0)
        let tmp%8#0: uint64 = (txn ApplicationID)
        let tmp%9#0: bool = (! tmp%8#0)
        (assert tmp%9#0) // can only call when creating
        exit 1u
    block@11: // after_if_else_L4
        fail

subroutine test_cases.reinterpret_cast.contract.Contract.bytes_to_bool[routing]() -> void:
    block@0: // L4
        let tmp%1#0: Encoded(bool8) = bytes_encode<bool8>(0u)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
        (log tmp%2#0)
        exit 1u