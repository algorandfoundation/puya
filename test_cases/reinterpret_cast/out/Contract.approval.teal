#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    // reinterpret_cast/contract.py:4
    // class Contract(ARC4Contract):
    txn NumAppArgs
    bz main_bare_routing@7
    pushbytess 0x4034b731 0x7e9fd4cf // method "bytes_to_bool()bool", method "test_bytes_to_biguint()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_bytes_to_bool_route@3 main_test_bytes_to_biguint_route@4
    err

main_test_bytes_to_biguint_route@4:
    // reinterpret_cast/contract.py:9
    // @arc4.abimethod()
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    // reinterpret_cast/contract.py:4
    // class Contract(ARC4Contract):
    callsub test_bytes_to_biguint
    // reinterpret_cast/contract.py:9
    // @arc4.abimethod()
    pushint 1 // 1
    return

main_bytes_to_bool_route@3:
    // reinterpret_cast/contract.py:5
    // @arc4.abimethod()
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    // reinterpret_cast/contract.py:4
    // class Contract(ARC4Contract):
    callsub bytes_to_bool
    // reinterpret_cast/contract.py:5
    // @arc4.abimethod()
    pushint 1 // 1
    return

main_bare_routing@7:
    // reinterpret_cast/contract.py:4
    // class Contract(ARC4Contract):
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    pushint 1 // 1
    return


// test_cases.reinterpret_cast.contract.Contract.bytes_to_bool[routing]() -> void:
bytes_to_bool:
    // reinterpret_cast/contract.py:5
    // @arc4.abimethod()
    pushbytes 0x151f7c7500
    log
    retsub


// test_cases.reinterpret_cast.contract.Contract.test_bytes_to_biguint[routing]() -> void:
test_bytes_to_biguint:
    // reinterpret_cast/contract.py:11
    // assert bytes_to_biguint()
    pushint 0 // 0
    assert
    retsub
