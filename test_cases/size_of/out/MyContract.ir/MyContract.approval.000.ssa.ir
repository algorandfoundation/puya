main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#0: bool = test_cases.size_of.contract.MyContract.__puya_arc4_router__()
        return tmp%0#0

subroutine test_cases.size_of.contract.MyContract.__puya_arc4_router__() -> bool:
    block@0: // L11
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let tmp%1#0: bool = (!= tmp%0#0 0u)
        goto tmp%1#0 ? block@1 : block@8
    block@1: // abi_routing_L11
        let tmp%2#0: bool = (txn ApplicationID)
        let tmp%3#0: bool = (! tmp%2#0)
        let tmp%4#0: uint64 = (txn OnCompletion)
        let tmp%5#0: uint64 = (shl tmp%4#0 1u)
        let tmp%6#0: uint64 = (+ tmp%3#0 tmp%5#0)
        switch tmp%6#0 {0u => block@2, * => block@6}
    block@2: // switch_case_0_L11
        let tmp%7#0: bytes = (txna ApplicationArgs 0)
        switch tmp%7#0 {method "test()void" => block@3, * => block@4}
    block@3: // test_route_L12
        test_cases.size_of.contract.MyContract.test[routing]()
        goto block@5
    block@4: // switch_case_default_L11
        goto block@5
    block@5: // switch_case_next_L11
        goto block@7
    block@6: // switch_case_default_L11
        goto block@7
    block@7: // switch_case_next_L11
        goto block@12
    block@8: // bare_routing_L11
        let tmp%8#0: uint64 = (txn OnCompletion)
        switch tmp%8#0 {0u => block@9, * => block@10}
    block@9: // __algopy_default_create_L1
        let tmp%9#0: uint64 = (txn ApplicationID)
        let tmp%10#0: bool = (== tmp%9#0 0u)
        (assert tmp%10#0) // can only call when creating
        test_cases.size_of.contract.MyContract.__algopy_default_create()
        exit 1u
    block@10: // switch_case_default_L11
        goto block@11
    block@11: // switch_case_next_L11
        goto block@12
    block@12: // after_if_else_L11
        exit 0u

subroutine test_cases.size_of.contract.MyContract.test[routing]() -> void:
    block@0: // L11
        test_cases.size_of.contract.MyContract.test()
        exit 1u

subroutine test_cases.size_of.contract.MyContract.test() -> void:
    block@0: // L12
        let tmp%0#0: bool = (== 8u 8u)
        (assert tmp%0#0)
        let tmp%1#0: bool = (== 8u 8u)
        (assert tmp%1#0)
        let tmp%2#0: bool = (== 32u 32u)
        (assert tmp%2#0)
        let tmp%3#0: bool = (== 32u 32u)
        (assert tmp%3#0)
        let tmp%4#0: bool = (== 8u 8u)
        (assert tmp%4#0)
        let tmp%5#0: bool = (== 8u 8u)
        (assert tmp%5#0)
        let tmp%6#0: bool = (== 8u 8u)
        (assert tmp%6#0)
        let tmp%7#0: bool = (== 1u 1u)
        (assert tmp%7#0)
        let tmp%8#0: bool = (== 1u 1u)
        (assert tmp%8#0)
        let tmp%9#0: bool = (== 2u 2u)
        (assert tmp%9#0)
        let tmp%10#0: bool = (== 9u 9u)
        (assert tmp%10#0)
        let tmp%11#0: bool = (== 7u 7u)
        (assert tmp%11#0)
        let tmp%12#0: bool = (== 2u 2u)
        (assert tmp%12#0)
        return 

subroutine test_cases.size_of.contract.MyContract.__algopy_default_create() -> void:
    block@0: // L1
