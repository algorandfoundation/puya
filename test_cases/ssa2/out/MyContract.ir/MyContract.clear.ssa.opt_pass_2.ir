main test_cases.ssa2.contract.MyContract.clear_state_program:
    block@0: // L37
        let a#0: uint64 = 25u
        let b#0: uint64 = 2u
        let tmp%0#1: bool = 1u
        goto tmp%0#1 ? block@2 : block@3
    block@2: // if_body_L46
        let b#1: uint64 = 1u
        let a#1: uint64 = 100u
        goto block@3
    block@3: // after_if_else_L45
        let b#2: uint64 = φ(b#0 <- block@0, b#1 <- block@2)
        let a#2: uint64 = φ(a#0 <- block@0, a#1 <- block@2)
        let b#3: uint64 = (* b#2 b#2)
        let tmp%1#0: uint64 = (* a#2 b#3)
        return tmp%1#0