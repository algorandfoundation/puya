main test_cases.bytes_ops.contract.BiguintBinaryOps.approval_program:
    block@0: // L5
        let left#0: bytes = 0xff
        let right#0: bytes = 0x0f
        let concat#0: bytes = 0xff0f
        let bitwise_or#0: bytes = 0xff
        let bitwise_xor#0: bytes = 0xf0
        let bitwise_and#0: bytes = 0x0f
        goto block@1
    block@1: // L21
        let result#0: bytes = (concat left#0 right#0)
        let tmp%0#0: bool = (== result#0 concat#0)
        (assert tmp%0#0)
        let result#1: bytes = (b| left#0 right#0)
        let tmp%1#0: bool = (== result#1 bitwise_or#0)
        (assert tmp%1#0)
        let result#2: bytes = (b^ left#0 right#0)
        let tmp%2#0: bool = (== result#2 bitwise_xor#0)
        (assert tmp%2#0)
        let result#3: bytes = (b& left#0 right#0)
        let tmp%3#0: bool = (== result#3 bitwise_and#0)
        (assert tmp%3#0)
        goto block@2
    block@2: // split from inlining callsub op of 0 at index 0_L5
        let seed#0: bytes = 0xff
        goto block@3
    block@3: // L41
        let seed#1: bytes = (b& seed#0 0x00)
        let tmp%0#1: bool = (== seed#1 0x00)
        (assert tmp%0#1)
        let five#0: bytes = 0x05
        let seed#2: bytes = (b| seed#1 five#0)
        let tmp%1#1: bool = (== seed#2 five#0)
        (assert tmp%1#1)
        let sixteen#0: bytes = 0x10
        let seed#3: bytes = (b^ seed#2 sixteen#0)
        let tmp%2#1: bool = (== seed#3 0x15)
        (assert tmp%2#1)
        let seed#4: bytes = (b^ seed#3 five#0)
        let tmp%3#1: bool = (== seed#4 sixteen#0)
        (assert tmp%3#1)
        let seed#5: bytes = (concat seed#4 five#0)
        let tmp%4#0: bool = (== seed#5 0x1005)
        (assert tmp%4#0)
        goto block@4
    block@4: // split from inlining callsub op of 2 at index 0_L5
        return 1u