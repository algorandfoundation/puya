main test_cases.bytes_ops.contract.BiguintBinaryOps.approval_program:
    block@0: // L5
        let result#0: bytes = 0xff0f
        let tmp%0#0: bool = (== result#0 0xff0f)
        (assert tmp%0#0)
        let result#1: bytes = 0xff
        let tmp%1#0: bool = (== result#1 0xff)
        (assert tmp%1#0)
        let result#2: bytes = 0xf0
        let tmp%2#0: bool = (== result#2 0xf0)
        (assert tmp%2#0)
        let result#3: bytes = 0x0f
        let tmp%3#0: bool = (== result#3 0x0f)
        (assert tmp%3#0)
        let seed#1: bytes = 0x00
        let tmp%0#1: bool = (== seed#1 0x00)
        (assert tmp%0#1)
        let seed#2: bytes = (b| seed#1 0x05)
        let tmp%1#1: bool = (== seed#2 0x05)
        (assert tmp%1#1)
        let seed#3: bytes = (b^ seed#2 0x10)
        let tmp%2#1: bool = (== seed#3 0x15)
        (assert tmp%2#1)
        let seed#4: bytes = (b^ seed#3 0x05)
        let tmp%3#1: bool = (== seed#4 0x10)
        (assert tmp%3#1)
        let seed#5: bytes = (concat seed#4 0x05)
        let tmp%4#0: bool = (== seed#5 0x1005)
        (assert tmp%4#0)
        return 1u