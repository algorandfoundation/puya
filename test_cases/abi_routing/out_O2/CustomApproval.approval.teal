#pragma version 10

// test_cases.abi_routing.custom_approval.CustomApproval.__algopy_entrypoint_with_init() -> uint64:
main:
    pushbytes ""
    txn ApplicationID
    bnz main_after_if_else@2
    txn ApplicationID
    !
    assert // nonsense assert just to generate an init method

main_after_if_else@2:
    txn NumAppArgs
    pushint 2 // 2
    ==
    bz main_after_if_else@6
    txna ApplicationArgs 1
    pushint 42 // 42
    itob
    ==
    bz main_after_if_else@6
    pushbytes "\xf0\x9f\x8e\x89\xf0\x9f\x8e\x89\xf0\x9f\x8e\x89"
    log

main_after_if_else@6:
    txn NumAppArgs
    bz main_bare_routing@17
    pushbytes 0x03b5c0af // method "add_one(uint64)uint64"
    txna ApplicationArgs 0
    match main_add_one_route@14

main_after_if_else@21:
    pushint 0 // 0
    bury 1

main_split_from_inlining_callsub_op_of_10_at_index_0@22:
    dup
    bnz main_after_if_else@8
    pushbytes "this will never be seen unless you're running in simulation mode anyway so I can say whatever I want here"
    log

main_after_if_else@8:
    dup
    return

main_add_one_route@14:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    txna ApplicationArgs 1
    btoi
    callsub add_one
    itob
    pushbytes 0x151f7c75
    swap
    concat
    log
    pushint 1 // 1
    bury 1
    b main_split_from_inlining_callsub_op_of_10_at_index_0@22

main_bare_routing@17:
    txn OnCompletion
    bnz main_after_if_else@21
    txn ApplicationID
    !
    assert // can only call when creating
    pushint 1 // 1
    bury 1
    b main_split_from_inlining_callsub_op_of_10_at_index_0@22


// test_cases.abi_routing.custom_approval.CustomApproval.add_one(x: uint64) -> uint64:
add_one:
    proto 1 1
    frame_dig -1
    pushint 1 // 1
    +
    retsub
