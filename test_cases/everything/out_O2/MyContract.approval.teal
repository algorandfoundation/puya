#pragma version 10
#pragma typetrack false

// test_cases.everything.contract.Everything.__algopy_entrypoint_with_init() -> uint64:
main:
    intcblock 0 1
    bytecblock "counter" base32(VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJPQ) "name" 0xbd6099e5 0x151f7c75
    intc_0 // 0
    intc_1 // 1
    txn ApplicationID
    !
    txn OnCompletion
    intc_1 // 1
    shl
    +
    switch main_switch_case_1@6 main_switch_case_0@4 main_switch_case_2@10 main_switch_case_next@14 main_switch_case_3@12

main_switch_case_next@14:
    err

main_switch_case_3@12:
    pushbytes 0x1658aa2f // method "close_out()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_close_out_route@13
    err

main_close_out_route@13:
    intc_0 // 0
    bytec_0 // "counter"
    app_global_get_ex
    assert // check self.counter exists
    intc_1 // 1
    -
    bytec_0 // "counter"
    swap
    app_global_put
    return

main_switch_case_2@10:
    bytec_3 // method "register(string)void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match register
    err

main_switch_case_0@4:
    pushbytes 0x4c5c61ba // method "create()void"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match main_create_route@5
    err

main_create_route@5:
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    pushbytes "creator"
    txn Sender
    app_global_put
    bytec_0 // "counter"
    intc_0 // 0
    app_global_put
    return

main_switch_case_1@6:
    bytec_3 // method "register(string)void"
    pushbytess 0x5d5c84c7 0xfd07264e // method "say_hello()string", method "calculate(uint64,uint64)uint64"
    txna ApplicationArgs 0 // on error: contract does not allow bare method calls
    match register main_say_hello_route@8 main_calculate_route@9
    err

main_calculate_route@9:
    txna ApplicationArgs 2
    txna ApplicationArgs 1
    btoi
    swap
    btoi
    swap
    dig 1
    +
    *
    itob
    bytec 4 // 0x151f7c75
    swap
    concat
    log
    return

main_say_hello_route@8:
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    intc_0 // 0
    dup
    bytec_2 // "name"
    app_local_get_ex
    swap
    bury 3
    bnz main_after_if_else@21
    pushbytes 0x000f486f77647920737472616e67657221

main_after_inlined_test_cases.everything.contract.Everything.say_hello@22:
    bytec 4 // 0x151f7c75
    swap
    concat
    log
    return

main_after_if_else@21:
    dig 1
    extract 2 0
    pushbytes 0x000748656c6c6f2c20
    swap
    concat // on error: max array length exceeded
    dup
    extract 2 0
    len
    itob
    extract 6 2
    replace2 0
    pushbytes 0x21
    concat // on error: max array length exceeded
    dup
    extract 2 0
    len
    itob
    extract 6 2
    replace2 0
    b main_after_inlined_test_cases.everything.contract.Everything.say_hello@22


// test_cases.everything.contract.Everything.register[routing]() -> void:
register:
    txna ApplicationArgs 1
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    txn OnCompletion
    intc_1 // OptIn
    ==
    bz register_after_if_else@5
    intc_0 // 0
    dup
    bytec_2 // "name"
    app_local_get_ex
    bury 1
    bnz register_after_if_else@5
    intc_0 // 0
    bytec_0 // "counter"
    app_global_get_ex
    assert // check self.counter exists
    intc_1 // 1
    +
    bytec_0 // "counter"
    swap
    app_global_put

register_after_if_else@5:
    intc_0 // 0
    bytec_2 // "name"
    frame_dig 0
    app_local_put
    intc_1 // 1
    return
