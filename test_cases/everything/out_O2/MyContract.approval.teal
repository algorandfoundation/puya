#pragma version 10

// test_cases.everything.contract.Everything.__algopy_entrypoint_with_init() -> uint64:
main:
    intcblock 1 0
    bytecblock "counter" base32(VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJPQ) "name" 0x151f7c75
    txn NumAppArgs
    bz main_after_if_else@15
    pushbytess 0x4c5c61ba 0xbd6099e5 0x5d5c84c7 0xfd07264e 0x1658aa2f // method "create()void", method "register(string)void", method "say_hello()string", method "calculate(uint64,uint64)uint64", method "close_out()void"
    txna ApplicationArgs 0
    match main_create_route@7 main_register_route@8 main_say_hello_route@9 main_calculate_route@10 main_close_out_route@11

main_after_if_else@15:
    intc_1 // 0
    return

main_close_out_route@11:
    txn OnCompletion
    pushint 2 // CloseOut
    ==
    assert // OnCompletion is not CloseOut
    txn ApplicationID
    assert // can only call when not creating
    callsub close_out
    intc_0 // 1
    return

main_calculate_route@10:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    txna ApplicationArgs 1
    txna ApplicationArgs 2
    callsub calculate
    bytec_3 // 0x151f7c75
    swap
    concat
    log
    intc_0 // 1
    return

main_say_hello_route@9:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    callsub say_hello
    bytec_3 // 0x151f7c75
    swap
    concat
    log
    intc_0 // 1
    return

main_register_route@8:
    intc_0 // 1
    txn OnCompletion
    shl
    pushint 3 // 3
    &
    assert // OnCompletion is not one of NoOp, OptIn
    txn ApplicationID
    assert // can only call when not creating
    txna ApplicationArgs 1
    callsub register
    intc_0 // 1
    return

main_create_route@7:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    !
    assert // can only call when creating
    callsub create
    intc_0 // 1
    return


// test_cases.everything.contract.Everything.create() -> void:
create:
    proto 0 0
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    pushbytes "creator"
    txn Sender
    app_global_put
    bytec_0 // "counter"
    intc_1 // 0
    app_global_put
    retsub


// test_cases.everything.contract.Everything.register(name: bytes) -> void:
register:
    proto 1 0
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    txn OnCompletion
    intc_0 // OptIn
    ==
    bz register_after_if_else@4
    intc_1 // 0
    dup
    bytec_2 // "name"
    app_local_get_ex
    bury 1
    bnz register_after_if_else@4
    intc_1 // 0
    bytec_0 // "counter"
    app_global_get_ex
    assert // check self.counter exists
    intc_0 // 1
    +
    bytec_0 // "counter"
    swap
    app_global_put

register_after_if_else@4:
    intc_1 // 0
    bytec_2 // "name"
    frame_dig -1
    app_local_put
    retsub


// test_cases.everything.contract.Everything.say_hello() -> bytes:
say_hello:
    proto 0 1
    txn Sender
    bytec_1 // addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA
    !=
    assert // You are banned, goodbye
    intc_1 // 0
    dup
    bytec_2 // "name"
    app_local_get_ex
    bnz say_hello_after_if_else@2
    pushbytes 0x000f486f77647920737472616e67657221
    swap
    retsub

say_hello_after_if_else@2:
    frame_dig 0
    extract 2 0
    pushbytes 0x48656c6c6f2c20
    swap
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    extract 2 0
    pushbytes 0x21
    concat
    dup
    len
    itob
    extract 6 2
    swap
    concat
    swap
    retsub


// test_cases.everything.contract.Everything.calculate(a: bytes, b: bytes) -> bytes:
calculate:
    proto 2 1
    frame_dig -2
    btoi
    frame_dig -1
    btoi
    swap
    dig 1
    +
    itob
    btoi
    *
    itob
    retsub


// test_cases.everything.contract.Everything.close_out() -> void:
close_out:
    proto 0 0
    intc_1 // 0
    bytec_0 // "counter"
    app_global_get_ex
    assert // check self.counter exists
    intc_0 // 1
    -
    bytec_0 // "counter"
    swap
    app_global_put
    retsub
