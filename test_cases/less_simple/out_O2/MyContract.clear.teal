#pragma version 10
#pragma typetrack false

// test_cases.less_simple.contract.MyContract.clear_state_program() -> uint64:
main:
    pushbytes ""
    pushints 0 1 // 0, 1

main_for_header@1:
    dup
    pushint 100 // 100
    <
    bz main_did_loop@8
    dupn 2
    sqrt
    dup
    *
    ==
    dig 2
    bury 4
    bz main_after_if_else@4
    dup2
    +
    bury 3

main_after_if_else@4:
    dig 2
    dup
    bury 3
    pushint 200 // 200
    >
    bz main_after_if_else@6

main_if_body@5:
    dig 1
    bury 3

main_after_for@10:
    dig 2
    return

main_after_if_else@6:
    dup
    pushint 1 // 1
    +
    bury 1
    b main_for_header@1

main_did_loop@8:
    dup
    pushint 1 // 1
    !=
    dig 2
    bury 4
    bnz main_if_body@5
    b main_after_for@10
