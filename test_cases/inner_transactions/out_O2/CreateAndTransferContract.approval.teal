#pragma version 10

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    intcblock 0 1 1000
    txn NumAppArgs
    bz main_bare_routing@6
    pushbytes 0x48e9ed7c // method "create_and_transfer()void"
    txna ApplicationArgs 0
    match main_create_and_transfer_route@3

main_after_if_else@10:
    intc_0 // 0
    return

main_create_and_transfer_route@3:
    txn OnCompletion
    !
    assert // OnCompletion is not NoOp
    txn ApplicationID
    assert // can only call when not creating
    callsub create_and_transfer
    intc_1 // 1
    return

main_bare_routing@6:
    txn OnCompletion
    bnz main_after_if_else@10
    txn ApplicationID
    !
    assert // can only call when creating
    intc_1 // 1
    return


// test_cases.inner_transactions.asset_transfer.CreateAndTransferContract.create_and_transfer() -> void:
create_and_transfer:
    proto 0 0
    itxn_begin
    global CurrentApplicationAddress
    dup
    itxn_field ConfigAssetClawback
    itxn_field ConfigAssetManager
    intc_0 // 0
    itxn_field ConfigAssetDecimals
    pushbytes "TST"
    itxn_field ConfigAssetUnitName
    pushbytes "test"
    itxn_field ConfigAssetName
    intc_2 // 1000
    itxn_field ConfigAssetTotal
    pushint 3 // acfg
    itxn_field TypeEnum
    intc_0 // 0
    itxn_field Fee
    itxn_submit
    itxn CreatedAssetID
    itxn_begin
    dup
    asset_params_get AssetCreator
    assert // asset exists
    global CurrentApplicationAddress
    uncover 2
    itxn_field XferAsset
    intc_2 // 1000
    itxn_field AssetAmount
    itxn_field AssetReceiver
    itxn_field AssetSender
    pushint 4 // axfer
    itxn_field TypeEnum
    intc_0 // 0
    itxn_field Fee
    itxn_submit
    retsub
