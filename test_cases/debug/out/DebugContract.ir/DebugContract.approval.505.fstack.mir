        <                                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | tmp%7#0
        bz test_else_body@7 ; b test_if_body@6            (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 |

