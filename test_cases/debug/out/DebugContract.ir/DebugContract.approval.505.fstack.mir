        +                                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | a#0
        f-store a#0                                       (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 |
