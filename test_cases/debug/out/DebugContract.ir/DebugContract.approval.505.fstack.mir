        l-load-copy b#0 0                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0 | z#0,b#0,b#0 (copy)
        l-load z#0 2                                      (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0 | b#0,b#0 (copy),z#0
        *                                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0 | b#0,c#0
        l-store-copy c#0 0                                (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0 | b#0,c#0,c#0 (copy)
        f-store c#0                                       (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | b#0,c#0
        // debug/contract.py:10
