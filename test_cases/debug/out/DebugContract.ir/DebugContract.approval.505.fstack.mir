        l-load b#0 1                                      (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | c#0,b#0
        l-load c#0 1                                      (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | b#0,c#0
        <                                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | tmp%3#1
        bz test_else_body@3 ; b test_if_body@2            (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 |

    test_if_body@2:                                       (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 |
