        <                                                 (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 | tmp%5#1
        bz test_else_body@5 ; b test_if_body@4            (𝕗) bee#0,cea#0,a#30,b#10,y#0,z#0,a#0,b#0,c#0 |

