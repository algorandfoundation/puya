main test_cases.callsub.contract.MyContract.approval_program:
    block@0: // L5
        let tmp%0#0: bytes = (itob 42u)
        (log tmp%0#0)
        let a#0: uint64 = 1u
        let b#0: uint64 = 2u
        goto block@1
    block@1: // L10
        let tmp%0#1: bytes = (itob a#0)
        (log tmp%0#1)
        let tmp%1#0: bytes = (itob b#0)
        (log tmp%1#0)
        goto block@2
    block@2: // split from inlining callsub op of 0 at index 2_L5
        return 1u