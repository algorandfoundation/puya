    while (global<OpcodeBudget>() > 350u) {
      assert(sha3_256(reinterpret_cast<bytes>(txn<Sender>())) != reinterpret_cast<bytes>(txn<Sender>()))
    }
    if (c > 0u) {
      x: uint64 = c + 2u
    } else {
      x: uint64 = c + 2u
    }
    assert(x - 2u == c)
  }
  
  baremethod test_cases.regression_tests.issue_434.Issue434.__algopy_default_create(): void
  {
  }
  
