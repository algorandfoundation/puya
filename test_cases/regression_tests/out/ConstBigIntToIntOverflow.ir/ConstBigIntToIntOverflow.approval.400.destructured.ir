main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let lifted%return#0: bool = 1u
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@7
    block@2: // abi_routing_L4
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: bool = (! tmp%2#0)
        (assert tmp%3#0) // OnCompletion is not NoOp
        let tmp%4#0: bytes = (txna ApplicationArgs 0)
        switch tmp%4#0 {method "get_abs_bound1(uint64)uint64" => block@3, method "get_abs_bound2()uint64" => block@4, * => block@11}
    block@3: // get_abs_bound1_route_L5
        let tmp%5#0: uint64 = (txn ApplicationID)
        (assert tmp%5#0) // can only call when not creating
        test_cases.regression_tests.biguint_opt.ConstBigIntToIntOverflow.get_abs_bound1[routing]()
        exit lifted%return#0
    block@4: // get_abs_bound2_route_L17
        let tmp%7#0: uint64 = (txn ApplicationID)
        (assert tmp%7#0) // can only call when not creating
        test_cases.regression_tests.biguint_opt.ConstBigIntToIntOverflow.get_abs_bound2[routing]()
        exit lifted%return#0
    block@7: // bare_routing_L4
        let tmp%9#0: uint64 = (txn OnCompletion)
        let not%tmp%9#0: bool = (! tmp%9#0)
        (assert not%tmp%9#0)
        let tmp%10#0: uint64 = (txn ApplicationID)
        let tmp%11#0: bool = (! tmp%10#0)
        (assert tmp%11#0) // can only call when creating
        exit lifted%return#0
    block@11: // after_if_else_L4
        fail

subroutine test_cases.regression_tests.biguint_opt.ConstBigIntToIntOverflow.get_abs_bound1[routing]() -> void:
    block@0: // L4
        let reinterpret_Encoded(uint64)%0#0: Encoded(uint64) = (txna ApplicationArgs 1)
        let upper_bound#0: uint64 = (btoi reinterpret_Encoded(uint64)%0#0)
        let abs_bound#0: uint64 = 0u
        goto upper_bound#0 ? block@2 : block@3
    block@2: // if_body_L13
        let abs_bound#0: uint64 = (btoi 18446744073709551616b)
        goto block@3
    block@3: // after_if_else_L8
        let aggregate%val_as_bytes%0#0: bytes[8] = (itob abs_bound#0)
        let tmp%3#0: bytes = (concat 0x151f7c75 aggregate%val_as_bytes%0#0)
        (log tmp%3#0)
        return 

subroutine test_cases.regression_tests.biguint_opt.ConstBigIntToIntOverflow.get_abs_bound2[routing]() -> void:
    block@0: // L4
        let abs_bound#0: uint64 = (btoi 18446744073709551616b)
        let aggregate%val_as_bytes%0#0: bytes[8] = (itob abs_bound#0)
        let tmp%2#0: bytes = (concat 0x151f7c75 aggregate%val_as_bytes%0#0)
        (log tmp%2#0)
        return 