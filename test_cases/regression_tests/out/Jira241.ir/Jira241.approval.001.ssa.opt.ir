main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        let tmp%1#0: bool = (!= tmp%0#1 0u)
        goto tmp%0#1 ? block@2 : block@7
    block@2: // abi_routing_L4
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: bool = (! tmp%2#0)
        (assert tmp%3#0) // OnCompletion is not NoOp
        let tmp%4#0: bytes = (txna ApplicationArgs 0)
        switch tmp%4#0 {method "oh_no(bool)void" => block@3, method "oh_yes(bool)void" => block@4, * => block@11}
    block@3: // oh_no_route_L5
        let tmp%5#0: uint64 = (txn ApplicationID)
        let tmp%6#0: bool = (!= tmp%5#0 0u)
        (assert tmp%5#0) // can only call when not creating
        test_cases.regression_tests.jira_241.Jira241.oh_no[routing]()
        exit 1u
    block@4: // oh_yes_route_L9
        let tmp%7#0: uint64 = (txn ApplicationID)
        let tmp%8#0: bool = (!= tmp%7#0 0u)
        (assert tmp%7#0) // can only call when not creating
        test_cases.regression_tests.jira_241.Jira241.oh_yes[routing]()
        exit 1u
    block@7: // bare_routing_L4
        let tmp%9#0: uint64 = (txn OnCompletion)
        goto tmp%9#0 ? block@11 : block@8
    block@8: // __algopy_default_create_L1
        let tmp%10#0: uint64 = (txn ApplicationID)
        let tmp%11#0: bool = (! tmp%10#0)
        (assert tmp%11#0) // can only call when creating
        test_cases.regression_tests.jira_241.Jira241.__algopy_default_create()
        exit 1u
    block@11: // after_if_else_L4
        fail

subroutine test_cases.regression_tests.jira_241.Jira241.oh_no[routing]() -> void:
    block@0: // L4
        return 

subroutine test_cases.regression_tests.jira_241.Jira241.oh_yes[routing]() -> void:
    block@0: // L4
        return 

subroutine test_cases.regression_tests.jira_241.Jira241.__algopy_default_create() -> void:
    block@0: // L1
        return 