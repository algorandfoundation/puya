main test_cases.regression_tests.setbit_fold_oob_uint64.SetBitFoldOOBUInt64.approval_program:
    block@0: // L5
        let tmp%0#0: uint64 = (setbit 0u 64u 1u)
        let tmp%1#0: bool = (== tmp%0#0 0u)
        (assert tmp%1#0)
        let tmp%2#0: uint64 = (setbit 42u 64u 0u)
        let tmp%3#0: bool = (== tmp%2#0 42u)
        (assert tmp%3#0)
        return 1u