// Op                                                                 Stack (out)
// test_cases.regression_tests.slot_allocation_inlining.SlotAllocationInlining.approval_program() -> uint64:
subroutine main:
    declare uint64 lifted%return#0
    main_while_top@2:                                                 (𝕗) lifted%return#0 |
        // regression_tests/slot_allocation_inlining.py:16
        // return True
        int 1                                                         (𝕗) lifted%return#0 | lifted%return#0
        f-store lifted%return#0                                       (𝕗) lifted%return#0 |
        global OpcodeBudget                                           (𝕗) lifted%return#0 | tmp%1#0
        int 810                                                       (𝕗) lifted%return#0 | tmp%1#0,810
        l-load tmp%1#0 1                                              (𝕗) lifted%return#0 | 810,tmp%1#0
        >                                                             (𝕗) lifted%return#0 | tmp%2#0
        bz main_after_while@8 ; b main_while_body@3                   (𝕗) lifted%return#0 |

    main_while_body@3:                                                (𝕗) lifted%return#0 |
        itxn_begin                                                    (𝕗) lifted%return#0 |
        int appl                                                      (𝕗) lifted%return#0 | appl
        itxn_field TypeEnum                                           (𝕗) lifted%return#0 |
        int DeleteApplication                                         (𝕗) lifted%return#0 | DeleteApplication
        itxn_field OnCompletion                                       (𝕗) lifted%return#0 |
        byte 0x068101                                                 (𝕗) lifted%return#0 | 0x068101
        itxn_field ApprovalProgram                                    (𝕗) lifted%return#0 |
        byte 0x068101                                                 (𝕗) lifted%return#0 | 0x068101
        itxn_field ClearStateProgram                                  (𝕗) lifted%return#0 |
        int 0                                                         (𝕗) lifted%return#0 | 0
        itxn_field Fee                                                (𝕗) lifted%return#0 |
        itxn_submit                                                   (𝕗) lifted%return#0 |
        b main_while_top@2                                            (𝕗) lifted%return#0 |

    main_after_while@8:                                               (𝕗) lifted%return#0 |
        // regression_tests/slot_allocation_inlining.py:25
        // arr = ReferenceArray[UInt64]()
        callsub _puya_lib.mem.new_slot                                (𝕗) lifted%return#0 | arr#0
        l-load-copy arr#0 0                                           (𝕗) lifted%return#0 | arr#0,arr#0 (copy)
        byte 0x                                                       (𝕗) lifted%return#0 | arr#0,arr#0 (copy),0x
        stores                                                        (𝕗) lifted%return#0 | arr#0
        // regression_tests/slot_allocation_inlining.py:26
        // append_to_array(arr)
        l-load-copy arr#0 0                                           (𝕗) lifted%return#0 | arr#0,arr#0 (copy)
        callsub append_to_array                                       (𝕗) lifted%return#0 | arr#0
        // regression_tests/slot_allocation_inlining.py:27
        // assert arr.length == 32, "expected array of length 32"
        l-load arr#0 0                                                (𝕗) lifted%return#0 | arr#0
        loads                                                         (𝕗) lifted%return#0 | aggregate%slot_contents%0#0
        len                                                           (𝕗) lifted%return#0 | aggregate%bytes_len%0#0
        int 8                                                         (𝕗) lifted%return#0 | aggregate%bytes_len%0#0,8
        /                                                             (𝕗) lifted%return#0 | aggregate%array_len%0#0
        int 32                                                        (𝕗) lifted%return#0 | aggregate%array_len%0#0,32
        ==                                                            (𝕗) lifted%return#0 | tmp%1#1
        assert // expected array of length 32                         (𝕗) lifted%return#0 |
        // regression_tests/slot_allocation_inlining.py:16
        // return True
        f-load lifted%return#0                                        (𝕗) lifted%return#0 | lifted%return#0
        return                                                        (𝕗) lifted%return#0 |


// test_cases.regression_tests.slot_allocation_inlining.append_to_array(arr: uint64) -> void:
subroutine append_to_array:
    append_to_array_block@0:                                          (𝕡) arr#0 |
        // regression_tests/slot_allocation_inlining.py:32
        // for b in Txn.sender.bytes:
        txn Sender                                                    (𝕡) arr#0 | tmp%0#0
        f-store tmp%0#0                                               (𝕡) arr#0 | (𝕗) tmp%0#0 |
        int 0                                                         (𝕡) arr#0 | (𝕗) tmp%0#0 | item_index_internal%0#0
        f-store item_index_internal%0#0                               (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |
        b append_to_array_for_header@1                                (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |

    append_to_array_for_header@1:                                     (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |
        // regression_tests/slot_allocation_inlining.py:32
        // for b in Txn.sender.bytes:
        f-load item_index_internal%0#0                                (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0
        int 32                                                        (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,32
        <                                                             (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | continue_looping%0#0
        bz append_to_array_after_for@4 ; b append_to_array_for_body@2 (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |

    append_to_array_for_body@2:                                       (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |
        // regression_tests/slot_allocation_inlining.py:33
        // arr.append(op.btoi(b))
        f-load tmp%0#0                                                (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | tmp%0#0
        f-load item_index_internal%0#0                                (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | tmp%0#0,item_index_internal%0#0
        l-store-copy item_index_internal%0#0 1                        (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,tmp%0#0,item_index_internal%0#0 (copy)
        getbyte                                                       (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,tmp%1#0
        p-load arr#0                                                  (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,tmp%1#0,arr#0 (copy)
        loads                                                         (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,tmp%1#0,slot_contents%0#0
        l-load tmp%1#0 1                                              (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,slot_contents%0#0,tmp%1#0
        itob                                                          (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,slot_contents%0#0,aggregate%val_as_bytes%0#0
        l-load slot_contents%0#0 1                                    (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,aggregate%val_as_bytes%0#0,slot_contents%0#0
        l-load aggregate%val_as_bytes%0#0 1                           (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,slot_contents%0#0,aggregate%val_as_bytes%0#0
        concat // on error: max array length exceeded                 (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,concat%0#0
        p-load arr#0                                                  (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,concat%0#0,arr#0 (copy)
        l-load concat%0#0 1                                           (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,arr#0 (copy),concat%0#0
        stores                                                        (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0
        l-load item_index_internal%0#0 0                              (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0
        int 1                                                         (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0,1
        +                                                             (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 | item_index_internal%0#0
        f-store item_index_internal%0#0                               (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |
        b append_to_array_for_header@1                                (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |

    append_to_array_after_for@4:                                      (𝕡) arr#0 | (𝕗) tmp%0#0,item_index_internal%0#0 |
        retsub


// _puya_lib.mem.new_slot() -> uint64:
subroutine _puya_lib.mem.new_slot:
    _puya_lib.mem.new_slot@entry:
        load 0                                                        slot_allocations
        bitlen                                                        free_slot#0
        load 0                                                        free_slot#0,slot_allocations
        int 256                                                       free_slot#0,slot_allocations,256
        l-load-copy free_slot#0 2                                     free_slot#0,slot_allocations,256,free_slot#0 (copy)
        -                                                             free_slot#0,slot_allocations,free_slot_idx
        int 0                                                         free_slot#0,slot_allocations,free_slot_idx,0
        setbit // on error: no available slots                        free_slot#0,new_slot_allocations
        store 0                                                       free_slot#0
        l-load free_slot#0 0                                          free_slot#0
        retsub                                                        free_slot#0


