main test_cases.regression_tests.uint64_triple_overflow_fold.UInt64TripleAddOverflow.approval_program:
    block@0: // L5
        let x#0: uint64 = (global GroupSize)
        let tmp%1#0: uint64 = (+ x#0 10000000000000000000u)
        let tmp%2#0: uint64 = (+ tmp%1#0 10000000000000000000u)
        (assert tmp%2#0)
        return 1u