#pragma version 11
#pragma typetrack false

// test_cases.regression_tests.op_variant_selection.ExtractOpSelection.approval_program() -> uint64:
main:
    bytecblock 
    b main_block@0

main_block@0:
    // regression_tests/op_variant_selection.py:15-16
    // # start > 255 forces extract3 (uint64 stack args) over extract (uint8 immediates)
    // assert op.extract(b"\xab" * 260, 256, 3) == b"\xab\xab\xab"
    pushbytes 
    pushint 256
    pushint 3
    extract3
    pushbytes 0xababab
    ==
    assert
    // regression_tests/op_variant_selection.py:17-18
    // # length > 255 does the same
    // assert op.extract(b"\xcd" * 300, 0, 300) == b"\xcd" * 300
    bytec_0 // 
    pushint 0
    pushint 300
    extract3
    bytec_0 // 
    ==
    assert
    // regression_tests/op_variant_selection.py:19
    // return True
    pushint 1
    return
