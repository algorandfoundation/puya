#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    pushint 1 // 1
    txn NumAppArgs
    bz main_bare_routing@9
    txn ApplicationID
    !
    txn OnCompletion
    pushint 1 // 1
    shl
    +
    !
    assert
    pushbytes 0xebb6cc95 // method "battle()void"
    txna ApplicationArgs 0
    match main_battle_route@4
    err

main_battle_route@4:
    pushbytes 0x00000000000000c8
    log
    return

main_bare_routing@9:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    return
