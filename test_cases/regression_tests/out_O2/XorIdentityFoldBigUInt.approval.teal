#pragma version 11
#pragma typetrack false

// test_cases.regression_tests.xor_identity_fold_biguint.XorIdentityFoldBigUInt.approval_program() -> uint64:
main:
    pushbytes 0xffffffff
    callsub self_xor
    pushint 4
    bzero
    dig 1
    ==
    assert
    len
    pushint 4
    ==
    assert
    pushint 1
    return


// test_cases.regression_tests.xor_identity_fold_biguint.self_xor(x: bytes) -> bytes:
self_xor:
    proto 1 1
    frame_dig -1
    dup
    b^
    retsub
