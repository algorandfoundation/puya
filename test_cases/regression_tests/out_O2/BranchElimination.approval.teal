    dup2
    extract_uint16
    intc_2 // 8
    *
    intc_3 // 2
    +
    extract3
    dup
    bury 19
    intc_0 // 0
    extract_uint16
    dup
    bury 13
    intc_1 // 1
    -
    bury 6
    intc_0 // 0
    bury 7

main_for_header@18:
