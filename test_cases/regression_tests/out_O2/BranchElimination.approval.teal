    bury 20
    dig 7
    intc_2 // 8
    *
    intc_2 // 8
    extract3 // on error: index access is out of bounds
    dup
    bury 16
    dig 16
    b>=
    dig 5
    bury 5
    dig 2
    bury 2
    bz main_after_if_else@25
    dig 6
    dig 6
    <
    dig 5
    bury 5
    dig 2
    bury 2
    bz main_after_if_else@24
    dig 1
    intc_1 // 1
    +
    dup
    bury 3
    dig 7
    intc_1 // 1
    +
    intc_2 // 8
    *
    dig 20
    swap
    intc_2 // 8
    extract3 // on error: index access is out of bounds
    dig 16
    b>
    dig 6
    bury 6
    swap
    bury 2
    bz main_after_if_else@23
    dig 1
    intc_3 // 2
    *
    dig 5
    intc_1 // 1
    +
    bury 5
    bury 1

main_after_if_else@23:
    dup
    dig 4
    bury 5
    bury 1

main_after_if_else@24:
    dup
    dig 4
    bury 5
    bury 1

main_after_if_else@25:
    dig 3
    bury 5
    dup
    bury 2
    dig 6
    intc_1 // 1
    +
    bury 7
    b main_for_header@18

main_after_for@26:
    dig 7
    intc_1 // 1
    +
    bury 8
    b main_for_header@16

main_if_body@37:
    intc_1 // 1
    return

main_umm2_route@4:
    txn ApplicationID
    assert // can only call when not creating
    intc_0 // 0
    bury 11

main_while_top@30:
    callsub hmm
    dig 11
    bury 11
    bz main_after_if_else@36
    callsub hmm
    dig 11
    bury 11
    bz main_after_if_else@36
    callsub hmm
    dig 11
    bury 11
    bz main_after_if_else@36
    callsub hmm
