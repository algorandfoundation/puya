        // test_self_ref_phi()
        callsub test_self_ref_phi                                                {test_self_ref_phi}
        pop 1
        // unssa/no_inlining.py:11
        // result1 = test_swap(UInt64(1))
        int 1                                                                    1
        callsub test_swap                                                        result1#0
        l-store-copy result1#0 0                                                 result1#0,result1#0 (copy)
        v-store result1#0                                                        result1#0
        // unssa/no_inlining.py:12
        // log(op.itob(result1))
        l-load-copy result1#0 0                                                  result1#0,result1#0 (copy)
        itob                                                                     result1#0,tmp%1#0
        log                                                                      result1#0
        // unssa/no_inlining.py:13
        // assert 1 <= result1 <= 2
        l-load result1#0 0                                                       result1#0
        bz main_bool_false@3 ; b main_and_contd@1

    main_and_contd@1:
        // unssa/no_inlining.py:13
        // assert 1 <= result1 <= 2
        v-load result1#0                                                         result1#0
        int 2                                                                    result1#0,2
        <=                                                                       tmp%3#0
        bz main_bool_false@3 ; b main_bool_true@2

    main_bool_true@2:
        int 1                                                                    1
        v-store and_result%0#0
        b main_bool_merge@4

    main_bool_false@3:
        int 0                                                                    0
        v-store and_result%0#0
        b main_bool_merge@4

    main_bool_merge@4:
        // unssa/no_inlining.py:13
        // assert 1 <= result1 <= 2
        v-load and_result%0#0                                                    and_result%0#0
        assert
        // unssa/no_inlining.py:14
        // result2 = test_swap(UInt64(2))
        int 2                                                                    2
        callsub test_swap                                                        result2#0
        l-store-copy result2#0 0                                                 result2#0,result2#0 (copy)
        v-store result2#0                                                        result2#0
        // unssa/no_inlining.py:15
        // log(op.itob(result2))
        l-load-copy result2#0 0                                                  result2#0,result2#0 (copy)
        itob                                                                     result2#0,tmp%5#0
        log                                                                      result2#0
        // unssa/no_inlining.py:16
        // assert 1 <= result2 <= 2
        l-load result2#0 0                                                       result2#0
        bz main_bool_false@7 ; b main_and_contd@5

    main_and_contd@5:
        // unssa/no_inlining.py:16
        // assert 1 <= result2 <= 2
        v-load result2#0                                                         result2#0
        int 2                                                                    result2#0,2
        <=                                                                       tmp%7#0
        bz main_bool_false@7 ; b main_bool_true@6

    main_bool_true@6:
        int 1                                                                    1
        v-store and_result%1#0
        b main_bool_merge@8

    main_bool_false@7:
        int 0                                                                    0
        v-store and_result%1#0
        b main_bool_merge@8

    main_bool_merge@8:
        // unssa/no_inlining.py:16
        // assert 1 <= result2 <= 2
        v-load and_result%1#0                                                    and_result%1#0
        assert
        // unssa/no_inlining.py:17
        // test_swap_loop(UInt64(7), UInt64(11))
        int 7                                                                    7
        int 11                                                                   7,11
        callsub test_swap_loop                                                   {test_swap_loop}
        pop 1
        // unssa/no_inlining.py:18
        // assert test_param_update_with_reentrant_entry_block(UInt64(0)) == 10
        int 0                                                                    0
        callsub test_param_update_with_reentrant_entry_block                     tmp%8#0
        int 10                                                                   tmp%8#0,10
        ==                                                                       tmp%9#0
        assert
        // unssa/no_inlining.py:19
        // test_param_update_with_reentrant_entry_block_v2(UInt64(0))
        int 0                                                                    0
        callsub test_param_update_with_reentrant_entry_block_v2                  {test_param_update_with_reentrant_entry_block_v2}
        pop 1
        // unssa/no_inlining.py:20
        // test_param_update_with_reentrant_entry_block_v3()
        callsub test_param_update_with_reentrant_entry_block_v3
        // unssa/no_inlining.py:21
        // test_swap_args()
        callsub test_swap_args
        // unssa/no_inlining.py:23
        // (a, b) = test_tuple_swap(UInt64(100), UInt64(200), UInt64(0))
        int 100                                                                  100
        int 200                                                                  100,200
        int 0                                                                    100,200,0
        callsub test_tuple_swap                                                  a#0,b#0
        // unssa/no_inlining.py:24
        // assert a == UInt64(100)
