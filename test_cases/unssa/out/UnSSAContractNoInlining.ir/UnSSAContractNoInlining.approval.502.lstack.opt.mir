        int 100                                                                  b#0,a#0,100
        ==                                                                       b#0,tmp%12#0
        assert                                                                   b#0
        // unssa/no_inlining.py:25
        // assert b == UInt64(200)
        l-load b#0 0                                                             b#0
        int 200                                                                  b#0,200
        ==                                                                       tmp%13#0
        assert
        // unssa/no_inlining.py:26
        // (a, b) = test_tuple_swap(UInt64(100), UInt64(200), UInt64(1))
        int 100                                                                  100
        int 200                                                                  100,200
        int 1                                                                    100,200,1
        callsub test_tuple_swap                                                  a#0,b#0
        // unssa/no_inlining.py:27
        // assert a == UInt64(200)
        l-load a#0 1                                                             b#0,a#0
        int 200                                                                  b#0,a#0,200
        ==                                                                       b#0,tmp%16#0
        assert                                                                   b#0
        // unssa/no_inlining.py:28
        // assert b == UInt64(100)
        l-load b#0 0                                                             b#0
        int 100                                                                  b#0,100
        ==                                                                       tmp%17#0
        assert
        // unssa/no_inlining.py:30
        // return True
        int 1                                                                    1
        return


// test_cases.unssa.no_inlining.test_self_ref_phi() -> uint64:
subroutine test_self_ref_phi:
    test_self_ref_phi_block@0:
        // unssa/no_inlining.py:38
        // a = UInt64(1)
        int 1                                                                    1
        v-store a#0
        b test_self_ref_phi_while_top@1

    test_self_ref_phi_while_top@1:
        // unssa/no_inlining.py:39
        // while a < 100:
        v-load a#0                                                               a#0
        int 100                                                                  a#0,100
        <                                                                        tmp%0#0
        bz test_self_ref_phi_after_while@7 ; b test_self_ref_phi_while_body@2

    test_self_ref_phi_while_body@2:
        // unssa/no_inlining.py:40
        // if a % 105 == 0:
        v-load a#0                                                               a#0
        int 105                                                                  a#0,105
        %                                                                        tmp%1#0
        bz test_self_ref_phi_while_top@1 ; b test_self_ref_phi_after_if_else@4

    test_self_ref_phi_after_if_else@4:
        // unssa/no_inlining.py:42
        // if not a % 21:
        v-load a#0                                                               a#0
        int 21                                                                   a#0,21
        %                                                                        tmp%3#0
        bz test_self_ref_phi_after_while@7 ; b test_self_ref_phi_after_if_else@6

    test_self_ref_phi_after_if_else@6:
        // unssa/no_inlining.py:44
        // a += 1
        v-load a#0                                                               a#0
        int 1                                                                    a#0,1
        +                                                                        a#0
        v-store a#0
        b test_self_ref_phi_while_top@1

    test_self_ref_phi_after_while@7:
        // unssa/no_inlining.py:45
        // return a
        v-load a#0                                                               a#0
        retsub                                                                   a#0


// test_cases.unssa.no_inlining.test_swap(i: uint64) -> uint64:
subroutine test_swap:
    test_swap_block@0:                                                           (𝕡) i#0 |
        // unssa/no_inlining.py:50
        // x = UInt64(1)
        int 1                                                                    (𝕡) i#0 | 1
        v-store x#0                                                              (𝕡) i#0 |
        // unssa/no_inlining.py:51
        // y = UInt64(2)
        int 2                                                                    (𝕡) i#0 | 2
        v-store y#0                                                              (𝕡) i#0 |
        b test_swap_while_top@1                                                  (𝕡) i#0 |

    test_swap_while_top@1:                                                       (𝕡) i#0 |
        // unssa/no_inlining.py:52
        // while i > 0:
        p-load i#0                                                               (𝕡) i#0 | i#0 (copy)
        bz test_swap_after_while@3 ; b test_swap_while_body@2                    (𝕡) i#0 |

    test_swap_while_body@2:                                                      (𝕡) i#0 |
        // unssa/no_inlining.py:56
        // i = i - 1
        p-load i#0                                                               (𝕡) i#0 | i#0 (copy)
        int 1                                                                    (𝕡) i#0 | i#0 (copy),1
        -                                                                        (𝕡) i#0 | i#0
        p-store i#0                                                              (𝕡) i#0 |
        v-load y#0                                                               (𝕡) i#0 | parcopy%0#0
        v-load x#0                                                               (𝕡) i#0 | parcopy%0#0,x#0
        v-store y#0                                                              (𝕡) i#0 | parcopy%0#0
        l-load parcopy%0#0 0                                                     (𝕡) i#0 | parcopy%0#0
        v-store x#0                                                              (𝕡) i#0 |
        b test_swap_while_top@1                                                  (𝕡) i#0 |

    test_swap_after_while@3:                                                     (𝕡) i#0 |
        // unssa/no_inlining.py:57
        // return x
        v-load x#0                                                               (𝕡) i#0 | x#0
        retsub                                                                   x#0


// test_cases.unssa.no_inlining.test_swap_loop(i: uint64, j: uint64) -> uint64:
subroutine test_swap_loop:
    test_swap_loop_block@0:                                                      (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:62
        // x = UInt64(1)
        int 1                                                                    (𝕡) i#0,j#0 | 1
        v-store x#0                                                              (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:63
        // y = UInt64(2)
        int 2                                                                    (𝕡) i#0,j#0 | 2
        v-store y#0                                                              (𝕡) i#0,j#0 |
        b test_swap_loop_while_top@1                                             (𝕡) i#0,j#0 |

    test_swap_loop_while_top@1:                                                  (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:64
        // while i > 0:
        p-load i#0                                                               (𝕡) i#0,j#0 | i#0 (copy)
        bz test_swap_loop_after_while@6 ; b test_swap_loop_while_top@3           (𝕡) i#0,j#0 |

    test_swap_loop_while_top@3:                                                  (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:65
        // while j > 0:
        p-load j#0                                                               (𝕡) i#0,j#0 | j#0 (copy)
        bz test_swap_loop_after_while@5 ; b test_swap_loop_while_body@4          (𝕡) i#0,j#0 |

    test_swap_loop_while_body@4:                                                 (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:69
        // j = j - 1
        p-load j#0                                                               (𝕡) i#0,j#0 | j#0 (copy)
        int 1                                                                    (𝕡) i#0,j#0 | j#0 (copy),1
        -                                                                        (𝕡) i#0,j#0 | j#0
        p-store j#0                                                              (𝕡) i#0,j#0 |
        v-load y#0                                                               (𝕡) i#0,j#0 | parcopy%0#0
        v-load x#0                                                               (𝕡) i#0,j#0 | parcopy%0#0,x#0
        v-store y#0                                                              (𝕡) i#0,j#0 | parcopy%0#0
        l-load parcopy%0#0 0                                                     (𝕡) i#0,j#0 | parcopy%0#0
        v-store x#0                                                              (𝕡) i#0,j#0 |
        b test_swap_loop_while_top@3                                             (𝕡) i#0,j#0 |

    test_swap_loop_after_while@5:                                                (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:70
        // i = i - 1
        p-load i#0                                                               (𝕡) i#0,j#0 | i#0 (copy)
        int 1                                                                    (𝕡) i#0,j#0 | i#0 (copy),1
        -                                                                        (𝕡) i#0,j#0 | i#0
        p-store i#0                                                              (𝕡) i#0,j#0 |
        b test_swap_loop_while_top@1                                             (𝕡) i#0,j#0 |

    test_swap_loop_after_while@6:                                                (𝕡) i#0,j#0 |
        // unssa/no_inlining.py:71
        // return x
        v-load x#0                                                               (𝕡) i#0,j#0 | x#0
        retsub                                                                   x#0


// test_cases.unssa.no_inlining.test_tuple_swap(a: uint64, b: uint64, i: uint64) -> uint64, uint64:
subroutine test_tuple_swap:
    test_tuple_swap_block@0:                                                     (𝕡) a#0,b#0,i#0 |
        // unssa/no_inlining.py:76
        // for _item in urange(i):
        int 0                                                                    (𝕡) a#0,b#0,i#0 | value_internal%0#0
        v-store _item#0                                                          (𝕡) a#0,b#0,i#0 |
        b test_tuple_swap_for_header@1                                           (𝕡) a#0,b#0,i#0 |

    test_tuple_swap_for_header@1:                                                (𝕡) a#0,b#0,i#0 |
        // unssa/no_inlining.py:76
        // for _item in urange(i):
        v-load _item#0                                                           (𝕡) a#0,b#0,i#0 | _item#0
        p-load i#0                                                               (𝕡) a#0,b#0,i#0 | _item#0,i#0 (copy)
        <                                                                        (𝕡) a#0,b#0,i#0 | continue_looping%0#0
        bz test_tuple_swap_after_for@4 ; b test_tuple_swap_for_body@2            (𝕡) a#0,b#0,i#0 |

    test_tuple_swap_for_body@2:                                                  (𝕡) a#0,b#0,i#0 |
        // unssa/no_inlining.py:76
        // for _item in urange(i):
        v-load _item#0                                                           (𝕡) a#0,b#0,i#0 | _item#0
        int 1                                                                    (𝕡) a#0,b#0,i#0 | _item#0,1
        +                                                                        (𝕡) a#0,b#0,i#0 | value_internal%0#0
        v-store _item#0                                                          (𝕡) a#0,b#0,i#0 |
        p-load a#0                                                               (𝕡) a#0,b#0,i#0 | parcopy%0#0
        p-load b#0                                                               (𝕡) a#0,b#0,i#0 | parcopy%0#0,b#0 (copy)
        p-store a#0                                                              (𝕡) a#0,b#0,i#0 | parcopy%0#0
        l-load parcopy%0#0 0                                                     (𝕡) a#0,b#0,i#0 | parcopy%0#0
        p-store b#0                                                              (𝕡) a#0,b#0,i#0 |
        b test_tuple_swap_for_header@1                                           (𝕡) a#0,b#0,i#0 |

    test_tuple_swap_after_for@4:                                                 (𝕡) a#0,b#0,i#0 |
        // unssa/no_inlining.py:78
        // return a, b
        p-load a#0                                                               (𝕡) a#0,b#0,i#0 | a#0 (copy)
        p-load b#0                                                               (𝕡) a#0,b#0,i#0 | a#0 (copy),b#0 (copy)
        retsub                                                                   a#0 (copy),b#0 (copy)


// test_cases.unssa.no_inlining.test_param_update_with_reentrant_entry_block(x: uint64) -> uint64:
subroutine test_param_update_with_reentrant_entry_block:
    test_param_update_with_reentrant_entry_block_while_top@1:                    (𝕡) x#0 |
        // unssa/no_inlining.py:84
        // x = x + 1
        p-load x#0                                                               (𝕡) x#0 | x#0 (copy)
        int 1                                                                    (𝕡) x#0 | x#0 (copy),1
        +                                                                        (𝕡) x#0 | x#0
        p-store x#0                                                              (𝕡) x#0 |
        // unssa/no_inlining.py:85
        // if x >= 10:
        p-load x#0                                                               (𝕡) x#0 | x#0 (copy)
        int 10                                                                   (𝕡) x#0 | x#0 (copy),10
        >=                                                                       (𝕡) x#0 | tmp%1#0
        bz test_param_update_with_reentrant_entry_block_while_top@1 ; b test_param_update_with_reentrant_entry_block_if_body@3 (𝕡) x#0 | 

    test_param_update_with_reentrant_entry_block_if_body@3:                      (𝕡) x#0 |
        // unssa/no_inlining.py:87
        // return x
        p-load x#0                                                               (𝕡) x#0 | x#0 (copy)
        retsub                                                                   x#0 (copy)


