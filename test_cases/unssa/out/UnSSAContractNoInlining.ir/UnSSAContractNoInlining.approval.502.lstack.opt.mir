    test_param_update_with_reentrant_entry_block_v2_while_top@1:                 (𝕡) x#0 |
        // unssa/no_inlining.py:94
        // if x >= 1:
        p-load x#0                                                               (𝕡) x#0 | x#0 (copy)
        bz test_param_update_with_reentrant_entry_block_v2_while_top@1 ; b test_param_update_with_reentrant_entry_block_v2_if_body@3 (𝕡) x#0 | 

    test_param_update_with_reentrant_entry_block_v2_if_body@3:                   (𝕡) x#0 |
