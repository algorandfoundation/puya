// test_cases.unssa.no_inlining.one() -> uint64:
subroutine one:
    one_block@0:
        // unssa/no_inlining.py:108
        // return UInt64(1)
        int 1                                                                    1
        retsub                                                                   1


// test_cases.unssa.no_inlining.swap_args(a: uint64, b: uint64) -> uint64, uint64:
subroutine swap_args:
    swap_args_block@0:                                                           (𝕡) a#0,b#0 |
        // unssa/no_inlining.py:113
        // return b, a
        p-load b#0                                                               (𝕡) a#0,b#0 | b#0 (copy)
        p-load a#0                                                               (𝕡) a#0,b#0 | b#0 (copy),a#0 (copy)
        retsub                                                                   b#0 (copy),a#0 (copy)


// test_cases.unssa.no_inlining.test_swap_args() -> void:
subroutine test_swap_args:
    test_swap_args_block@0:
        // unssa/no_inlining.py:118
        // a = one() + 123
        callsub one                                                              tmp%0#0
        int 123                                                                  tmp%0#0,123
        +                                                                        a#0
        // unssa/no_inlining.py:119
        // b = one() + 234
        callsub one                                                              a#0,tmp%2#0
        int 234                                                                  a#0,tmp%2#0,234
        +                                                                        a#0,b#0
        // unssa/no_inlining.py:120
        // a, b = swap_args(a, b)
        l-load a#0 1                                                             b#0,a#0
        l-load b#0 1                                                             a#0,b#0
        callsub swap_args                                                        a#0,b#0
        // unssa/no_inlining.py:121
        // assert a == 235, "a == 235"
        l-load a#0 1                                                             b#0,a#0
        int 235                                                                  b#0,a#0,235
        ==                                                                       b#0,tmp%6#0
        assert // a == 235                                                       b#0
        // unssa/no_inlining.py:122
        // assert b == 124, "b = 124"
        l-load b#0 0                                                             b#0
        int 124                                                                  b#0,124
        ==                                                                       tmp%7#0
        assert // b = 124
        retsub


