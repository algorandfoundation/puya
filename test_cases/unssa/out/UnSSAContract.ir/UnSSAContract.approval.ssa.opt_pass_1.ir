        let a#1: uint64 = φ(a#0 <- block@0, b#1 <- block@2)
        let continue_looping%0#0: bool = (< _item#1 i#0)
        goto continue_looping%0#0 ? block@2 : block@4
    block@2: // for_body_L73
        let _item#2: uint64 = (+ _item#1 1u)
        goto block@1
    block@4: // after_for_L72
        return a#1 b#1