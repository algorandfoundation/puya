    callsub swap_args
    // unssa/no_inlining.py:121
    // assert a == 235, "a == 235"
    swap
    pushint 235
    ==
    assert // a == 235
    // unssa/no_inlining.py:122
    // assert b == 124, "b = 124"
    pushint 124
    ==
    assert // b = 124
    retsub
