// test_cases.unssa.no_inlining.UnSSAContractNoInlining.approval_program() -> uint64:
main:
    intcblock 1 0 2 100 200
    pushbytes ""
    // unssa/no_inlining.py:10
    // test_self_ref_phi()
    callsub test_self_ref_phi
    pop
    // unssa/no_inlining.py:11
    // result1 = test_swap(UInt64(1))
    intc_0 // 1
    callsub test_swap
    dupn 2
    // unssa/no_inlining.py:12
    // log(op.itob(result1))
    itob
    log
    // unssa/no_inlining.py:13
    // assert 1 <= result1 <= 2
    bz main_bool_false@3
    dup
    intc_2 // 2
    <=
    bz main_bool_false@3
    intc_0 // 1

main_bool_merge@4:
    // unssa/no_inlining.py:13
    // assert 1 <= result1 <= 2
    assert
    // unssa/no_inlining.py:14
    // result2 = test_swap(UInt64(2))
    intc_2 // 2
    callsub test_swap
    dup
    bury 3
    // unssa/no_inlining.py:15
    // log(op.itob(result2))
    dup
    itob
    log
    // unssa/no_inlining.py:16
    // assert 1 <= result2 <= 2
    bz main_bool_false@7
    dig 1
    intc_2 // 2
    <=
    bz main_bool_false@7
    intc_0 // 1

main_bool_merge@8:
    // unssa/no_inlining.py:16
    // assert 1 <= result2 <= 2
    assert
    // unssa/no_inlining.py:17
    // test_swap_loop(UInt64(7), UInt64(11))
    pushints 7 11
    callsub test_swap_loop
    pop
    // unssa/no_inlining.py:18
    // assert test_param_update_with_reentrant_entry_block(UInt64(0)) == 10
    intc_1 // 0
    callsub test_param_update_with_reentrant_entry_block
    pushint 10
    ==
    assert
    // unssa/no_inlining.py:19
    // test_param_update_with_reentrant_entry_block_v2(UInt64(0))
    intc_1 // 0
    callsub test_param_update_with_reentrant_entry_block_v2
    pop
    // unssa/no_inlining.py:20
    // test_param_update_with_reentrant_entry_block_v3()
    callsub test_param_update_with_reentrant_entry_block_v3
    // unssa/no_inlining.py:21
    // test_swap_args()
    callsub test_swap_args
    // unssa/no_inlining.py:23
    // (a, b) = test_tuple_swap(UInt64(100), UInt64(200), UInt64(0))
    intc_3 // 100
    intc 4 // 200
    intc_1 // 0
    callsub test_tuple_swap
    // unssa/no_inlining.py:24
    // assert a == UInt64(100)
    swap
    intc_3 // 100
    ==
    assert
    // unssa/no_inlining.py:25
    // assert b == UInt64(200)
    intc 4 // 200
    ==
    assert
    // unssa/no_inlining.py:26
    // (a, b) = test_tuple_swap(UInt64(100), UInt64(200), UInt64(1))
    intc_3 // 100
    intc 4 // 200
    intc_0 // 1
    callsub test_tuple_swap
    // unssa/no_inlining.py:27
    // assert a == UInt64(200)
    swap
    intc 4 // 200
    ==
    assert
    // unssa/no_inlining.py:28
    // assert b == UInt64(100)
    intc_3 // 100
    ==
    assert
    // unssa/no_inlining.py:30
    // return True
    intc_0 // 1
    return

main_bool_false@7:
    intc_1 // 0
    b main_bool_merge@8

main_bool_false@3:
    intc_1 // 0
    b main_bool_merge@4


