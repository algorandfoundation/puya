subroutine test_cases.unssa.no_inlining.test_swap_args() -> void:
    block@0: // L116
        let tmp%0#0: uint64 = test_cases.unssa.no_inlining.one()
        let a#0: uint64 = (+ tmp%0#0 123u)
        let tmp%2#0: uint64 = test_cases.unssa.no_inlining.one()
        let b#0: uint64 = (+ tmp%2#0 234u)
