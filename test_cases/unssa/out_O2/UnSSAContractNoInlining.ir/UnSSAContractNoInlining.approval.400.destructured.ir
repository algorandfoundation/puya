main test_cases.unssa.no_inlining.UnSSAContractNoInlining.approval_program:
    block@0: // L9
        test_cases.unssa.no_inlining.test_self_ref_phi()
        let result1#0: uint64 = test_cases.unssa.no_inlining.test_swap(1u)
        let tmp%1#0: bytes = (itob result1#0)
        (log tmp%1#0)
        goto result1#0 ? block@1 : block@3
    block@1: // and_contd_L13
        let tmp%3#0: bool = (<= result1#0 2u)
        goto tmp%3#0 ? block@2 : block@3
    block@2: // bool_true_L13
        let and_result%0#0: bool = 1u
        goto block@4
    block@3: // bool_false_L13
        let and_result%0#0: bool = 0u
        goto block@4
    block@4: // bool_merge_L13
        (assert and_result%0#0)
        let result2#0: uint64 = test_cases.unssa.no_inlining.test_swap(2u)
        let tmp%5#0: bytes = (itob result2#0)
        (log tmp%5#0)
        goto result2#0 ? block@5 : block@7
    block@5: // and_contd_L16
        let tmp%7#0: bool = (<= result2#0 2u)
        goto tmp%7#0 ? block@6 : block@7
    block@6: // bool_true_L16
        let and_result%1#0: bool = 1u
        goto block@8
    block@7: // bool_false_L16
        let and_result%1#0: bool = 0u
        goto block@8
    block@8: // bool_merge_L16
        (assert and_result%1#0)
        test_cases.unssa.no_inlining.test_swap_loop(7u, 11u)
        let tmp%8#0: uint64 = test_cases.unssa.no_inlining.test_param_update_with_reentrant_entry_block(0u)
        let tmp%9#0: bool = (== tmp%8#0 10u)
        (assert tmp%9#0)
        test_cases.unssa.no_inlining.test_param_update_with_reentrant_entry_block_v2(0u)
        test_cases.unssa.no_inlining.test_param_update_with_reentrant_entry_block_v3()
        test_cases.unssa.no_inlining.test_swap_args()
        let (a#0: uint64, b#0: uint64) = test_cases.unssa.no_inlining.test_tuple_swap(100u, 200u, 0u)
        let tmp%12#0: bool = (== a#0 100u)
        (assert tmp%12#0)
        let tmp%13#0: bool = (== b#0 200u)
        (assert tmp%13#0)
        let (a#0: uint64, b#0: uint64) = test_cases.unssa.no_inlining.test_tuple_swap(100u, 200u, 1u)
        let tmp%16#0: bool = (== a#0 200u)
        (assert tmp%16#0)
        let tmp%17#0: bool = (== b#0 100u)
        (assert tmp%17#0)
        return 1u

