        let a#1: uint64 = φ(a#0 <- block@0, a#13 <- block@30)
        let x#10: uint64 = φ(x#0 <- block@0, x#8 <- block@30)
        let continue_looping%0#0: bool = (< a#1 2u)
        goto continue_looping%0#0 ? block@2 : block@34
