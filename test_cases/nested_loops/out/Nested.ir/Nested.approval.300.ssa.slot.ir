    block@9: // for_header_L15
        let e#1: uint64 = φ(e#0 <- block@8, e#3 <- block@14)
        let x#3: uint64 = φ(x#4 <- block@8, x#1 <- block@14)
        let continue_looping%4#0: bool = (< e#1 2u)
