main test_cases.arc4_types.structs.Arc4StructsTypeContract.approval_program:
    block@0: // L35
        let val#0: bytes = 0x0000001079f7e42e
        let val#2: bytes = 0x0000004607097084
        let loop_counter%0#0: uint64 = 0u
        goto block@1
    block@1: // for_body_L40
        let loop_counter%0#1: uint64 = φ(loop_counter%0#0 <- block@0, loop_counter%0#2 <- block@3)
        let val#1: bytes = φ(val#0 <- block@0, val#2 <- block@3)
        (log val#1)
        goto loop_counter%0#1 ? block@4 : block@3
    block@3: // for_header_1_L39
        let loop_counter%0#2: uint64 = 1u
        goto block@1
    block@4: // after_for_L39
        let encoded_bool%0#1: bytes = 0x80
        let tmp%0#1: bool = (getbit encoded_bool%0#1 0u)
        (assert tmp%0#1)
        let encoded_bool%1#1: bytes = 0x00
        let tmp%1#1: bool = (getbit encoded_bool%1#1 0u)
        let tmp%2#1: bool = (! tmp%1#1)
        (assert tmp%2#1)
        let encoded_bool%2#1: bytes = 0x80
        let tmp%3#1: bool = (getbit encoded_bool%2#1 0u)
        (assert tmp%3#1)
        let encoded_bool%3#1: bytes = 0x00
        let tmp%4#1: bool = (getbit encoded_bool%3#1 0u)
        let tmp%5#1: bool = (! tmp%4#1)
        (assert tmp%5#1)
        (log 0xa0)
        let tmp%0#2: bytes = 0x000000083cfbf217000000230384b842
        let tmp%1#2: bytes = ((extract 0 8) tmp%0#2) // on error: Index access is out of bounds
        let tmp%2#2: bytes = (itob 35382882839u)
        let tmp%3#2: bool = (== tmp%1#2 tmp%2#2)
        (assert tmp%3#2)
        let tmp%4#2: bytes = 0xa0
        let is_true%0#2: uint64 = (getbit tmp%4#2 2u)
        let encoded_bool%0#2: bytes = (setbit 0x00 0u is_true%0#2)
        let tmp%5#2: bool = (getbit encoded_bool%0#2 0u)
        (assert tmp%5#2)
        let concatenated%0#0: bytes = 0x2a
        let len_%0#0: uint64 = (len concatenated%0#0)
        let as_bytes%2#0: bytes = (itob len_%0#0)
        let len_16_bit%0#0: bytes = ((extract 6 2) as_bytes%2#0)
        let concat_result%0#0: bytes = (concat len_16_bit%0#0 concatenated%0#0)
        let copy#1: bytes = (concat 0x0002 concat_result%0#0)
        let tmp%4#0: bool = (!= 0x00020000 copy#1)
        (assert tmp%4#0) // expected copy is different
        return 1u