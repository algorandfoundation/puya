main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@10
    block@2: // abi_routing_L4
        let tmp%2#0: bool = (txn ApplicationID)
        let tmp%3#0: bool = (! tmp%2#0)
        let tmp%4#0: uint64 = (txn OnCompletion)
        let tmp%5#0: uint64 = (shl tmp%4#0 1u)
        let tmp%6#0: uint64 = (+ tmp%3#0 tmp%5#0)
        let not%tmp%6#0: bool = (! tmp%6#0)
        (assert not%tmp%6#0)
        let tmp%7#0: bytes = (txna ApplicationArgs 0)
        switch tmp%7#0 {method "xyz()string[]" => block@4, method "xyz_raw()string[]" => block@5, * => block@14}
    block@4: // xyz_route_L5
        test_cases.arc4_types.dynamic_string_array.Arc4DynamicStringArrayContract.xyz[routing]()
        goto block@14
    block@5: // xyz_raw_route_L13
        test_cases.arc4_types.dynamic_string_array.Arc4DynamicStringArrayContract.xyz_raw[routing]()
        goto block@14
    block@10: // bare_routing_L4
        let tmp%8#0: uint64 = (txn OnCompletion)
        let not%tmp%8#0: bool = (! tmp%8#0)
        (assert not%tmp%8#0)
        let tmp%9#0: uint64 = (txn ApplicationID)
        let tmp%10#0: bool = (! tmp%9#0)
        (assert tmp%10#0) // can only call when creating
        exit 1u
    block@14: // after_if_else_L4
        fail

subroutine test_cases.arc4_types.dynamic_string_array.Arc4DynamicStringArrayContract.xyz[routing]() -> void:
    block@0: // L4
        (log 0x151f7c75000300060009000c00015800015900015a)
        exit 1u

subroutine test_cases.arc4_types.dynamic_string_array.Arc4DynamicStringArrayContract.xyz_raw[routing]() -> void:
    block@0: // L4
        (log 0x151f7c75000300060009000c00015800015900015a)
        exit 1u