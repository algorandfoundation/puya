main test_cases.stubs.biguint.BigUIntContract.approval_program:
    block@0: // L5
        let one#0: biguint = 1b
        let two#0: biguint = 2b
        goto block@1
    block@1: // L20
        let tmp%0#1: bool = (b< one#0 two#0)
        (assert tmp%0#1)
        let tmp%1#0: bool = (b<= one#0 two#0)
        (assert tmp%1#0)
        let tmp%2#1: bool = (b== one#0 one#0)
        (assert tmp%2#1)
        let tmp%3#1: bool = (b> two#0 one#0)
        (assert tmp%3#1)
        let tmp%4#1: bool = (b>= two#0 one#0)
        (assert tmp%4#1)
        let tmp%5#1: bool = (b!= one#0 two#0)
        (assert tmp%5#1)
        goto block@2
    block@2: // split from inlining callsub op of 0 at index 0_L5
        let one#1: biguint = 1b
        let two#1: uint64 = 2u
        goto block@3
    block@3: // L30
        let tmp%0#2: biguint = (itob two#1)
        let tmp%1#1: bool = (b< one#1 tmp%0#2)
        (assert tmp%1#1)
        let tmp%2#2: biguint = (itob two#1)
        let tmp%3#2: bool = (b<= one#1 tmp%2#2)
        (assert tmp%3#2)
        let tmp%4#2: bool = (b== one#1 one#1)
        (assert tmp%4#2)
        let tmp%5#2: biguint = (itob two#1)
        let tmp%6#1: bool = (b< one#1 tmp%5#2)
        (assert tmp%6#1)
        let tmp%7#1: biguint = (itob two#1)
        let tmp%8#0: bool = (b<= one#1 tmp%7#1)
        (assert tmp%8#0)
        let tmp%9#0: biguint = (itob two#1)
        let tmp%10#0: bool = (b!= one#1 tmp%9#0)
        (assert tmp%10#0)
        goto block@4
    block@4: // split from inlining callsub op of 2 at index 0_L5
        let one#2: uint64 = 1u
        let two#2: biguint = 2b
        goto block@5
    block@5: // L40
        let tmp%0#3: biguint = (itob one#2)
        let tmp%1#2: bool = (b> two#2 tmp%0#3)
        (assert tmp%1#2)
        let tmp%2#3: biguint = (itob one#2)
        let tmp%3#3: bool = (b>= two#2 tmp%2#3)
        (assert tmp%3#3)
        let tmp%4#3: bool = (== one#2 one#2)
        (assert tmp%4#3)
        let tmp%5#3: biguint = (itob one#2)
        let tmp%6#2: bool = (b> two#2 tmp%5#3)
        (assert tmp%6#2)
        let tmp%7#2: biguint = (itob one#2)
        let tmp%8#1: bool = (b>= two#2 tmp%7#2)
        (assert tmp%8#1)
        let tmp%9#1: biguint = (itob one#2)
        let tmp%10#1: bool = (b!= two#2 tmp%9#1)
        (assert tmp%10#1)
        goto block@6
    block@6: // split from inlining callsub op of 4 at index 0_L5
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let tmp%2#0: biguint = (select 5b 1b tmp%0#0)
        let tmp%3#0: bool = (b== tmp%2#0 5b)
        (assert tmp%3#0) // constructor expressions supported
        let tmp%4#0: biguint = 3b
        let tmp%5#0: biguint = 3b
        let tmp%6#0: bool = (b== tmp%4#0 tmp%5#0)
        (assert tmp%6#0)
        let tmp%7#0: bool = 1u
        (assert tmp%7#0)
        return 1u