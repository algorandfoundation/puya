    block@13: // L52
        let tmp%0#6: bytes = (itob val#4)
        (log tmp%0#6)
        goto block@14
    block@14: // split from inlining callsub op of 12 at index 5_L14
        let tmp%14#0: bool = (!= 2u val#4)
        let tmp%15#0: bool = (|| tmp%12#0 tmp%14#0)
        (assert tmp%15#0)
        let tmp%16#0: bool = (== 1u 3u)
