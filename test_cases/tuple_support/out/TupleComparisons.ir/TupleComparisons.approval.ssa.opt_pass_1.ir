    block@11: // L52
        let tmp%0#5: bytes = (itob val#3)
        (log tmp%0#5)
        goto block@12
    block@12: // split from inlining callsub op of 10 at index 4_L14
        let tmp%10#0: bool = (!= val#3 val#3)
        let tmp#1: bool = (&& tmp%9#0 tmp%10#0)
        let tmp%11#0: bool = (! tmp#1)
        (assert tmp%11#0)
        let tmp%12#0: bool = (!= 1u 3u)
        let val#4: uint64 = 46u
