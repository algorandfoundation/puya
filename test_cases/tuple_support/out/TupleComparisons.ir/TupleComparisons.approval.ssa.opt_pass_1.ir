    block@16: // split from inlining callsub op of 14 at index 4_L14
        let tmp%18#0: bool = (== 2u val#5)
        let tmp#2: bool = (&& tmp%16#0 tmp%18#0)
        let tmp%19#0: bool = (! tmp#2)
