main test_cases.tuple_support.tuple_comparisons.TupleComparisons.approval_program:
    block@0: // L5
        goto block@1
    block@1: // L14
        let tmp%0#0: bool = (!= "abc" "abc")
        let val#0: uint64 = 42u
