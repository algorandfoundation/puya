main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@8
    block@2: // abi_routing_L4
        let tmp%2#0: uint64 = (txn OnCompletion)
        let tmp%3#0: bool = (! tmp%2#0)
        (assert tmp%3#0) // OnCompletion is not NoOp
        let tmp%4#0: uint64 = (txn ApplicationID)
        (assert tmp%4#0) // can only call when not creating
        let tmp%6#0: bytes = (txna ApplicationArgs 0)
        switch tmp%6#0 {method "discard_op()void" => block@3, method "discard_subroutine()void" => block@4, method "discard_constants()void" => block@5, * => block@12}
    block@3: // discard_op_route_L5
        exit 1u
    block@4: // discard_subroutine_route_L9
        test_cases.unassigned_expression.contract.Unassigned.discard_subroutine[routing]()
        goto block@12
    block@5: // discard_constants_route_L13
        exit 1u
    block@8: // bare_routing_L4
        let tmp%7#0: uint64 = (txn OnCompletion)
        let not%tmp%7#0: bool = (! tmp%7#0)
        (assert not%tmp%7#0)
        let tmp%8#0: uint64 = (txn ApplicationID)
        let tmp%9#0: bool = (! tmp%8#0)
        (assert tmp%9#0) // can only call when creating
        exit 1u
    block@12: // after_if_else_L4
        fail

subroutine test_cases.unassigned_expression.contract.Unassigned.discard_subroutine[routing]() -> void:
    block@0: // L4
        exit 1u