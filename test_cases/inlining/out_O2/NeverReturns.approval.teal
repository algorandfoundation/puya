#pragma version 10
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    txn NumAppArgs
    bz main_bare_routing@9
    txn ApplicationID
    !
    pushint 1 // 1
    txn OnCompletion
    shl
    +
    !
    assert
    txna ApplicationArgs 0
    pop
    err

main_bare_routing@9:
    txn OnCompletion
    !
    assert
    txn ApplicationID
    !
    assert // can only call when creating
    pushint 1 // 1
    return
