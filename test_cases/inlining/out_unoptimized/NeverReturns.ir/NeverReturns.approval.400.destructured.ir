main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        goto block@1
    block@1: // L34
        let tmp%0#1: uint64 = (txn NumAppArgs)
        let tmp%1#0: bool = (!= tmp%0#1 0u)
        goto tmp%1#0 ? block@2 : block@9
    block@2: // abi_routing_L34
        let tmp%2#0: bool = (txn ApplicationID)
        let tmp%3#0: bool = (! tmp%2#0)
        let tmp%4#0: uint64 = (txn OnCompletion)
        let tmp%5#0: uint64 = (shl tmp%4#0 1u)
        let tmp%6#0: uint64 = (+ tmp%3#0 tmp%5#0)
        switch tmp%6#0 {0u => block@3, * => block@7}
    block@3: // switch_case_0_L34
        let tmp%7#0: bytes = (txna ApplicationArgs 0)
        switch tmp%7#0 {method "err()void" => block@4, * => block@5}
    block@4: // err_route_L35
        test_cases.inlining.contract.NeverReturns.err[routing]()
        goto block@6
    block@5: // switch_case_default_L34
        goto block@6
    block@6: // switch_case_next_L34
        goto block@8
    block@7: // switch_case_default_L34
        goto block@8
    block@8: // switch_case_next_L34
        goto block@13
    block@9: // bare_routing_L34
        let tmp%8#0: uint64 = (txn OnCompletion)
        switch tmp%8#0 {0u => block@10, * => block@11}
    block@10: // __algopy_default_create_L1
        let tmp%9#0: uint64 = (txn ApplicationID)
        let tmp%10#0: bool = (== tmp%9#0 0u)
        (assert tmp%10#0) // can only call when creating
        goto block@15
    block@15: // L1
        goto block@16
    block@16: // after_inlined_test_cases.inlining.contract.NeverReturns.__algopy_default_create_L1
        exit 1u
    block@11: // switch_case_default_L34
        goto block@12
    block@12: // switch_case_next_L34
        goto block@13
    block@13: // after_if_else_L34
        exit 0u
    block@14: // after_inlined_test_cases.inlining.contract.NeverReturns.__puya_arc4_router___L1
        let tmp%0#0: bool = undefined
        return tmp%0#0

subroutine test_cases.inlining.contract.NeverReturns.err[routing]() -> void:
    block@0: // L34
        test_cases.inlining.contract.NeverReturns.err()
        exit 1u

subroutine test_cases.inlining.contract.NeverReturns.err() -> void:
    block@0: // L35
        fail