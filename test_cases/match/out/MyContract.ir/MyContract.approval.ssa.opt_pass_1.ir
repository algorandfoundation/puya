main test_cases.match.contract.MyContract.approval_program:
    block@0: // L5
        (app_global_put "case_one" 1u)
        (app_global_put "case_two" 2u)
        goto block@1
    block@1: // L16
        let n#0: uint64 = (txn NumAppArgs)
        switch n#0 {0u => block@2, 10u => block@3, * => block@4}
    block@2: // switch_case_0_L21
        let hello#0: bytes = 0x48656c6c6f
        (log hello#0)
        goto block@5
    block@3: // switch_case_1_L24
        let hello#1: bytes = 0x48656c6c6f205468657265
        (log hello#1)
        goto block@5
    block@4: // switch_case_default_L19
        goto block@5
    block@5: // switch_case_next_L19
        goto block@6
    block@6: // split from inlining callsub op of 0 at index 2_L5
        goto block@7
    block@7: // L38
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let tmp%1#0: biguint = (itob tmp%0#0)
        let n#1: biguint = (b* tmp%1#0 10b)
        switch n#1 {0b => block@8, 10b => block@9, * => block@10}
    block@8: // switch_case_0_L43
        let hello#2: bytes = 0x48656c6c6f2062696775696e74
        (log hello#2)
        goto block@11
    block@9: // switch_case_1_L46
        let hello#3: bytes = 0x48656c6c6f2054686572652062696775696e74
        (log hello#3)
        goto block@11
    block@10: // switch_case_default_L41
        goto block@11
    block@11: // switch_case_next_L41
        goto block@12
    block@12: // split from inlining callsub op of 6 at index 0_L5
        goto block@13
    block@13: // L27
        let n#2: bytes = (txna ApplicationArgs 0)
        switch n#2 {0x => block@14, 0x3130 => block@15, * => block@16}
    block@14: // switch_case_0_L32
        let hello#4: bytes = 0x48656c6c6f206279746573
        (log hello#4)
        goto block@17
    block@15: // switch_case_1_L35
        let hello#5: bytes = 0x48656c6c6f205468657265206279746573
        (log hello#5)
        goto block@17
    block@16: // switch_case_default_L30
        goto block@17
    block@17: // switch_case_next_L30
        goto block@18
    block@18: // split from inlining callsub op of 12 at index 0_L5
        goto block@19
    block@19: // L49
        let n#3: bytes = (txn Sender)
        switch n#3 {addr AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAY5HFKQ => block@20, addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA => block@21, * => block@22}
    block@20: // switch_case_0_L54
        let hello#6: bytes = 0x48656c6c6f2061646472657373
        (log hello#6)
        goto block@23
    block@21: // switch_case_1_L57
        let hello#7: bytes = 0x48656c6c6f2054686572652061646472657373
        (log hello#7)
        goto block@23
    block@22: // switch_case_default_L52
        goto block@23
    block@23: // switch_case_next_L52
        goto block@24
    block@24: // split from inlining callsub op of 18 at index 0_L5
        goto block@25
    block@25: // L60
        let n#4: uint64 = (txn NumAppArgs)
        let (maybe_value%0#0: uint64, maybe_exists%0#0: bool) = (app_global_get_ex 0u "case_one")
        (assert maybe_exists%0#0) // check self.case_one exists
        let (maybe_value%1#0: uint64, maybe_exists%1#0: bool) = (app_global_get_ex 0u "case_two")
        (assert maybe_exists%1#0) // check self.case_two exists
        switch n#4 {maybe_value%0#0 => block@26, maybe_value%1#0 => block@27, * => block@28}
    block@26: // switch_case_0_L65
        let hello#8: bytes = 0x48656c6c6f206f6e65
        (log hello#8)
        goto block@29
    block@27: // switch_case_1_L68
        let hello#9: bytes = 0x48656c6c6f2074776f
        (log hello#9)
        goto block@29
    block@28: // switch_case_default_L71
        let hello#10: bytes = 0x48656c6c6f2064656661756c74
        (log hello#10)
        goto block@29
    block@29: // switch_case_next_L63
        goto block@30
    block@30: // split from inlining callsub op of 24 at index 0_L5
        goto block@31
    block@31: // L74
        let tmp%0#1: uint64 = (txn NumAppArgs)
        let n#5: bool = (> tmp%0#1 0u)
        switch n#5 {1u => block@32, 0u => block@33, * => block@34}
    block@32: // switch_case_0_L79
        let hello#11: bytes = 0x48656c6c6f2054727565
        (log hello#11)
        goto block@35
    block@33: // switch_case_1_L82
        let hello#12: bytes = 0x48656c6c6f2046616c7365
        (log hello#12)
        goto block@35
    block@34: // switch_case_default_L77
        goto block@35
    block@35: // switch_case_next_L77
        goto block@36
    block@36: // split from inlining callsub op of 30 at index 0_L5
        return 1u