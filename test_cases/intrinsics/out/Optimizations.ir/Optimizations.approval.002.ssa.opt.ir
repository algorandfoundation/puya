subroutine test_cases.intrinsics.optimizations.Optimizations.all[routing]() -> void:
    block@0: // L4
        let reinterpret_Encoded(len+uint8[])%0#0: Encoded(len+uint8[]) = (txna ApplicationArgs 1)
        let value_to_hash#0: bytes = decode_bytes<bytes>(reinterpret_Encoded(len+uint8[])%0#0)
        let tmp%0#1: bytes = (sha256 value_to_hash#0)
        let tmp%1#1: bytes = (sha3_256 value_to_hash#0)
        let tmp%2#1: bytes = (sha512_256 value_to_hash#0)
        let tmp%3#1: bytes = (keccak256 value_to_hash#0)
        let tmp%5#0: Encoded((len+uint8[]),(len+uint8[]),(len+uint8[]),(len+uint8[])) = bytes_encode<((len+uint8[]),(len+uint8[]),(len+uint8[]),(len+uint8[]))>(tmp%0#1, tmp%1#1, tmp%2#1, tmp%3#1)
        let tmp%6#0: bytes = (concat 0x151f7c75 tmp%5#0)
        (log tmp%6#0)
        exit 1u