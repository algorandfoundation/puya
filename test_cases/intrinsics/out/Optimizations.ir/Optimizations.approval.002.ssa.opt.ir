subroutine test_cases.intrinsics.optimizations.Optimizations.keccak256[routing]() -> void:
    block@0: // L4
        let tmp%1#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0x592fa743889fc7f92ac2a37bb1f5ba1daf2a5c84741ca0e0061d243a2e6707ba)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
