main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        goto tmp%0#1 ? block@2 : block@13
    block@2: // abi_routing_L4
        let tmp%2#0: bool = (txn ApplicationID)
        let tmp%3#0: bool = (! tmp%2#0)
        let tmp%4#0: uint64 = (txn OnCompletion)
        let tmp%5#0: uint64 = (shl tmp%4#0 1u)
        let tmp%6#0: uint64 = (+ tmp%3#0 tmp%5#0)
        let not%tmp%6#0: bool = (! tmp%6#0)
        (assert not%tmp%6#0)
        let tmp%7#0: bytes = (txna ApplicationArgs 0)
        switch tmp%7#0 {method "sha256()byte[]" => block@4, method "sha3_256()byte[]" => block@5, method "sha512_256()byte[]" => block@6, method "keccak256()byte[]" => block@7, method "all(byte[])(byte[],byte[],byte[],byte[])" => block@8, * => block@17}
    block@4: // sha256_route_L5
        test_cases.intrinsics.optimizations.Optimizations.sha256[routing]()
        goto block@17
    block@5: // sha3_256_route_L9
        test_cases.intrinsics.optimizations.Optimizations.sha3_256[routing]()
        goto block@17
    block@6: // sha512_256_route_L13
        test_cases.intrinsics.optimizations.Optimizations.sha512_256[routing]()
        goto block@17
    block@7: // keccak256_route_L17
        test_cases.intrinsics.optimizations.Optimizations.keccak256[routing]()
        goto block@17
    block@8: // all_route_L21
        test_cases.intrinsics.optimizations.Optimizations.all[routing]()
        goto block@17
    block@13: // bare_routing_L4
        let tmp%8#0: uint64 = (txn OnCompletion)
        let not%tmp%8#0: bool = (! tmp%8#0)
        (assert not%tmp%8#0)
        let tmp%9#0: uint64 = (txn ApplicationID)
        let tmp%10#0: bool = (! tmp%9#0)
        (assert tmp%10#0) // can only call when creating
        exit 1u
    block@17: // after_if_else_L4
        fail

subroutine test_cases.intrinsics.optimizations.Optimizations.sha256[routing]() -> void:
    block@0: // L4
        let tmp%1#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0xa591a6d40bf420404a011733cfb7b190d62c65bf0bcda32b57b277d9ad9f146e)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
        (log tmp%2#0)
        exit 1u

subroutine test_cases.intrinsics.optimizations.Optimizations.sha3_256[routing]() -> void:
    block@0: // L4
        let tmp%1#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0xe167f68d6563d75bb25f3aa49c29ef612d41352dc00606de7cbd630bb2665f51)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
        (log tmp%2#0)
        exit 1u

subroutine test_cases.intrinsics.optimizations.Optimizations.sha512_256[routing]() -> void:
    block@0: // L4
        let tmp%1#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0xff20018851481c25bfc2e5d0c1e1fa57dac2a237a1a96192f99a10da47aa5442)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
